@page "/bug-reports"
@page "/bug-reports/{Id}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Helpers
@inject ITrueDeskApiService Api
@inject ISnackbar Snackbar
@inject LocalizationService L

<PageTitle>@L.T("bugreport.admin_title") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("bugreport.admin_title")</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_reports.Count == 0)
{
    <MudAlert Severity="Severity.Success">@L.T("bugreport.empty")</MudAlert>
}
else
{
    <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
        @string.Format(L.T("bugreport.count"), _reports.Count(r => !r.Resolved), _reports.Count)
    </MudText>

    @foreach (var report in _reports)
    {
        var ctx = report.Context;
        <MudCard Class="mb-3" Elevation="@(report.Resolved ? 1 : 3)" id="@($"bug-{report.Id}")">
            <MudCardContent>
                <div class="d-flex align-center flex-wrap gap-2 mb-2">
                    <MudIcon Icon="@(report.Resolved ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.BugReport)"
                             Color="@(report.Resolved ? Color.Success : Color.Error)" />
                    <MudText Typo="Typo.h6" Style="word-break: break-word;">@report.Title</MudText>
                    @if (report.Resolved)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                            @L.T("bugreport.resolved")
                        </MudChip>
                    }
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                        @report.CreatedAt.ToLocalDisplayString("dd.MM.yyyy HH:mm")
                    </MudText>
                </div>

                @if (report.ReportedBy != null)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                        @L.T("bugreport.from") @(report.ReportedBy.Fullname ?? report.ReportedBy.Username)
                    </MudText>
                }

                @if (!string.IsNullOrWhiteSpace(report.Description))
                {
                    <MudPaper Elevation="0" Class="pa-3 mb-2" Style="background: var(--mud-palette-background-grey); white-space: pre-wrap;">
                        <MudText Typo="Typo.body2">@report.Description</MudText>
                    </MudPaper>
                }

                @if (ctx != null && ctx.Count > 0)
                {
                    <MudExpansionPanels Elevation="0" Class="mt-2">
                        <MudExpansionPanel Text="@L.T("bugreport.context")">
                            @foreach (var kv in ctx)
                            {
                                @if (kv.Key == "consoleTail") continue;
                                <div class="d-flex flex-wrap gap-2 mb-1">
                                    <MudText Typo="Typo.caption" Style="font-weight: 600; min-width: 120px;">@kv.Key</MudText>
                                    <MudText Typo="Typo.caption" Style="word-break: break-all;">@kv.Value?.ToString()</MudText>
                                </div>
                            }
                            @if (ctx.TryGetValue("consoleTail", out var tailObj) && tailObj != null)
                            {
                                <MudDivider Class="my-2" />
                                <MudText Typo="Typo.caption" Style="font-weight: 600;">consoleTail</MudText>
                                <pre style="white-space: pre-wrap; word-break: break-all; font-size: 11px; max-height: 200px; overflow-y: auto; background: var(--mud-palette-background); padding: 8px; border-radius: 4px;">@tailObj.ToString()</pre>
                            }
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            </MudCardContent>
            <MudCardActions>
                @if (!report.Resolved)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="@(() => SetResolvedAsync(report, true))" Disabled="_busy">
                        @L.T("bugreport.mark_resolved")
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.RestartAlt"
                               OnClick="@(() => SetResolvedAsync(report, false))" Disabled="_busy">
                        @L.T("bugreport.reopen")
                    </MudButton>
                }
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="@(() => DeleteAsync(report))" Disabled="_busy">
                    @L.T("common.delete")
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
}

@code {
    [Parameter] public string? Id { get; set; }

    private bool _loading = true;
    private bool _busy;
    private List<BugReport> _reports = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // If a notification deep-link routed us to /bug-reports/<id>,
        // scroll the matching card into view after the list rendered.
        if (firstRender && !string.IsNullOrEmpty(Id))
        {
            await Task.Delay(150);
            await ScrollToAsync($"bug-{Id}");
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _reports = await Api.ListBugReportsAsync();
        }
        catch
        {
            _reports = new();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task SetResolvedAsync(BugReport report, bool resolved)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var ok = await Api.SetBugReportResolvedAsync(report.Id, resolved);
            if (ok)
            {
                report.Resolved = resolved;
                report.ResolvedAt = resolved ? DateTime.UtcNow : null;
                Snackbar.Add(L.T(resolved ? "bugreport.resolved_ok" : "bugreport.reopened_ok"), Severity.Success);
            }
            else
            {
                Snackbar.Add(L.T("common.error"), Severity.Error);
            }
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(BugReport report)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var ok = await Api.DeleteBugReportAsync(report.Id);
            if (ok)
            {
                _reports.Remove(report);
                Snackbar.Add(L.T("bugreport.deleted"), Severity.Success);
            }
            else
            {
                Snackbar.Add(L.T("common.error"), Severity.Error);
            }
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    [Inject] IJSRuntime JS { get; set; } = default!;
    private async Task ScrollToAsync(string elementId)
    {
        try { await JS.InvokeVoidAsync("pwaHelpers.scrollToElement", elementId); }
        catch { }
    }
}
