@page "/tickets/add"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject ILookupService Lookup
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.LocalizationService L
@inject THWTicketApp.Web.Services.LocalStorageService LocalStorage
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject ISyncService SyncService
@inject IJSRuntime JsRuntime
@using Microsoft.JSInterop
@implements IDisposable

<PageTitle>@L.T("tickets.create_title") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("tickets.create_title")</MudText>

@if (_isLoading && _ticketTypes.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-6">
        <MudSkeleton Width="100%" Height="56px" Class="mb-4" />
        <MudSkeleton Width="100%" Height="120px" Class="mb-4" />
        <MudGrid>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
        </MudGrid>
    </MudPaper>
}
else
{

<MudPaper Elevation="2" Class="pa-6">
    @if (_templates.Count > 0)
    {
        <MudSelect T="TicketTemplate" Label="@L.T("tickets.use_template")" Variant="Variant.Outlined"
                   Clearable="true" Class="mb-4"
                   ToStringFunc="@(t => t?.Name ?? "")"
                   ValueChanged="OnTemplateSelected">
            @foreach (var tpl in _templates)
            {
                <MudSelectItem Value="tpl">@tpl.Name</MudSelectItem>
            }
        </MudSelect>
        @if (_templateChecklist.Count > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-4" Style="margin-top:-8px;">
                @string.Format(L.T("tickets.template_checklist_info"), _templateChecklist.Count)
            </MudText>
        }
    }

    @if (_draftRestoredBanner)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _draftRestoredBanner = false)">
            <div class="d-flex align-center justify-space-between" style="width:100%;">
                <MudText>@L.T("tickets.draft_restored")</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="DiscardDraftAsync">
                    @L.T("tickets.draft_discard")
                </MudButton>
            </div>
        </MudAlert>
    }

    <MudForm @ref="_form">
        <MudTextField Value="@_subject" ValueChanged="@OnSubjectChanged" T="string"
                      Label="@L.T("detail.subject")" Variant="Variant.Outlined"
                      Required="true" RequiredError="@L.T("tickets.subject_required")"
                      Counter="200" MaxLength="200" Immediate="true" Class="mb-4" />

        <MudTextField Value="@_issue" ValueChanged="@OnIssueChanged" T="string"
                      Label="@L.T("detail.description")" Variant="Variant.Outlined"
                      Lines="5" Required="true" RequiredError="@L.T("tickets.description_required")"
                      Class="mb-4" />

        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudSelect T="TicketType" Value="_selectedType" ValueChanged="OnTypeChanged" Label="@L.T("detail.type")" Variant="Variant.Outlined"
                           ToStringFunc="@(t => t?.TranslatedName ?? "")" Class="mb-4">
                    @foreach (var type in _ticketTypes)
                    {
                        <MudSelectItem Value="type">@type.TranslatedName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="Priority" @bind-Value="_selectedPriority" Label="@L.T("detail.priority")" Variant="Variant.Outlined"
                           ToStringFunc="@(p => p?.TranslatedName ?? "")" Class="mb-4">
                    @foreach (var priority in _priorities)
                    {
                        <MudSelectItem Value="priority">@priority.TranslatedName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="Group" @bind-Value="_selectedGroup" Label="@L.T("detail.group")" Variant="Variant.Outlined"
                           Required="true" RequiredError="@L.T("tickets.group_required")"
                           ToStringFunc="@(g => g?.Name ?? "")" Class="mb-4">
                    @foreach (var group in _groups)
                    {
                        <MudSelectItem Value="group">@group.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (_noVisibleGroups)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
                        @L.T("tickets.no_visible_groups")
                    </MudAlert>
                }
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="User" @bind-Value="_selectedAssignee" Label="@L.T("detail.assignee")" Variant="Variant.Outlined"
                           Clearable="true"
                           ToStringFunc="@(u => u?.Fullname ?? "")" Class="mb-4">
                    @foreach (var user in _users)
                    {
                        <MudSelectItem Value="user">@user.Fullname</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_dueDate"
                               Label="@L.T("detail.due")" Variant="Variant.Outlined"
                               PickerVariant="PickerVariant.Dialog"
                               Clearable="true" Editable="false" Class="mb-4" />
            </MudItem>
        </MudGrid>

        @* Attachment picker — pre-create. Files are kept in memory and
           pushed to the new ticket *after* the create succeeds. This
           was bug-report #2 from the PWA: customers couldn't add a
           photo at the moment they were filing the ticket. We allow
           multiple files; each is size-checked client-side against the
           same 25 MB ceiling the server enforces. *@
        <MudText Typo="Typo.body2" Class="mb-2">@L.T("tickets.attachments_label")</MudText>
        @* Same drag&drop hookup as TicketDetail: dropzone-interop.js forwards
           dropped files into the hidden InputFile, so OnFilesPicked handles
           click-pick and drop identically. *@
        <div id="new-ticket-dropzone" class="pwa-dropzone pa-2 mb-4">
            <div class="d-flex gap-2 align-center flex-wrap">
                <InputFile id="new-ticket-attachments" OnChange="OnFilesPicked" hidden multiple
                           accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.heic,.heif,.tif,.tiff,.doc,.docx,.xls,.xlsx,.txt,.zip,.mp3,.wav" />
                <MudButton HtmlTag="label" Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AttachFile" for="new-ticket-attachments"
                           Disabled="_isLoading">
                    @L.T("tickets.attachments_pick")
                </MudButton>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("attachments.drop_hint")</MudText>
                @if (_pendingAttachments.Count > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @string.Format(L.T("tickets.attachments_selected"), _pendingAttachments.Count)
                    </MudText>
                }
            </div>
            @if (_pendingAttachments.Count > 0)
            {
                <div class="d-flex flex-column gap-1 mt-2">
                    @foreach (var (file, idx) in _pendingAttachments.Select((f, i) => (f, i)))
                    {
                        var capturedIdx = idx;
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" />
                            <MudText Typo="Typo.body2" Style="flex:1; overflow:hidden; text-overflow:ellipsis;">
                                @file.Name <span style="color:var(--mud-palette-text-secondary);">(@FormatBytes(file.Size))</span>
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           OnClick="@(() => RemovePendingAttachment(capturedIdx))"
                                           aria-label="@L.T("tickets.attachments_remove")" />
                        </div>
                    }
                </div>
            }
        </div>

        <div class="d-flex gap-3 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="CreateTicketAsync" Disabled="_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @L.T("tickets.create")
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("tickets"))">
                @L.T("common.cancel")
            </MudButton>
        </div>
    </MudForm>
</MudPaper>

}

@code {
    // localStorage key for the unsubmitted draft. Cleared on successful
    // create, on explicit "Verwerfen", or when the user lands on the page
    // with no stored content.
    internal const string DraftKey = "draft_new_ticket";

    private MudForm _form = null!;
    private bool _isLoading;
    private string _subject = string.Empty;
    private string _issue = string.Empty;
    private bool _draftRestoredBanner;
    private System.Threading.Timer? _saveDebounce;
    private TicketType? _selectedType;
    private Priority? _selectedPriority;
    private Group? _selectedGroup;
    private User? _selectedAssignee;
    private DateTime? _dueDate;
    private List<TicketType> _ticketTypes = [];
    // Union of all priorities across types (fallback when a type defines
    // none of its own); _priorities is the filtered list the select renders.
    private List<Priority> _allPriorities = [];
    private List<Priority> _priorities = [];
    private List<Group> _groups = [];
    private List<User> _users = [];
    private List<TicketTemplate> _templates = [];
    // Checklist titles of the currently selected template. Sent as part of
    // the create payload (trudesk PR #106 validates `checklist` on the
    // ticketsV2 create and stores the items with completed:false).
    private List<string> _templateChecklist = [];
    // True when the user profile resolved to zero reachable groups —
    // surface a warning instead of letting them pick a group that the
    // server-side check (trudesk PR #97) would 403 anyway.
    private bool _noVisibleGroups;

    // Files the user picked before saving. Uploaded after the create POST
    // returns the new ticket id. Capped per file at the same 25 MB
    // ceiling TicketDetail uses; the server compresses images to 2400 px
    // after receiving them.
    private const long MaxAttachmentBytes = 25L * 1024 * 1024;
    private readonly List<IBrowserFile> _pendingAttachments = new();

    private IJSObjectReference? _dropzoneModule;
    private bool _dropzoneRegistered;

    protected override async Task OnInitializedAsync()
    {
        await TryRestoreDraftAsync();
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The dropzone div only exists once the skeleton phase is over, so
        // keep trying on each render until register() reports it bound.
        if (_dropzoneRegistered) return;
        try
        {
            _dropzoneModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/dropzone-interop.js");
            _dropzoneRegistered = await _dropzoneModule.InvokeAsync<bool>("register",
                "new-ticket-dropzone", "new-ticket-attachments");
        }
        catch { /* drag-drop is optional — button still works */ }
    }

    private async Task TryRestoreDraftAsync()
    {
        var raw = await LocalStorage.GetItemAsync(DraftKey);
        if (string.IsNullOrEmpty(raw)) return;
        try
        {
            var draft = JsonSerializer.Deserialize<DraftDto>(raw);
            if (draft == null) return;
            if (string.IsNullOrWhiteSpace(draft.Subject) && string.IsNullOrWhiteSpace(draft.Issue)) return;
            _subject = draft.Subject ?? string.Empty;
            _issue = draft.Issue ?? string.Empty;
            _draftRestoredBanner = true;
        }
        catch { /* corrupted draft — ignore, user just types again */ }
    }

    private void OnSubjectChanged(string value)
    {
        _subject = value;
        ScheduleDraftSave();
    }

    private void OnIssueChanged(string value)
    {
        _issue = value;
        ScheduleDraftSave();
    }

    private void ScheduleDraftSave()
    {
        // Debounce: persist 500ms after the last keystroke so we don't
        // hammer localStorage on every character.
        _saveDebounce?.Dispose();
        _saveDebounce = new System.Threading.Timer(async _ =>
        {
            try
            {
                if (string.IsNullOrWhiteSpace(_subject) && string.IsNullOrWhiteSpace(_issue))
                {
                    await LocalStorage.RemoveItemAsync(DraftKey);
                }
                else
                {
                    var json = JsonSerializer.Serialize(new DraftDto { Subject = _subject, Issue = _issue });
                    await LocalStorage.SetItemAsync(DraftKey, json);
                }
            }
            catch { /* offline / quota / serialization — non-fatal */ }
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task DiscardDraftAsync()
    {
        _subject = string.Empty;
        _issue = string.Empty;
        _draftRestoredBanner = false;
        _saveDebounce?.Dispose();
        await LocalStorage.RemoveItemAsync(DraftKey);
    }

    public void Dispose()
    {
        _saveDebounce?.Dispose();
        // Fire-and-forget — same pattern as Tickets.razor's pull-to-refresh
        // module: detach the global drop listeners, then drop the module ref.
        if (_dropzoneModule != null)
        {
            try { _ = _dropzoneModule.InvokeVoidAsync("unregister", "new-ticket-dropzone"); } catch { }
            _ = _dropzoneModule.DisposeAsync();
        }
    }

    private sealed class DraftDto
    {
        public string? Subject { get; set; }
        public string? Issue { get; set; }
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            // Core data: types and groups are essential for ticket creation.
            // Profile is loaded in parallel to scope the group dropdown to
            // the user's reachable groups (Team→Department for admin/agent,
            // direct membership for customer) — same source the kanban
            // filter uses (see PR #144). Server-side enforcement landed in
            // trudesk PR #97; this just stops users from picking a group
            // that would 403 on submit.
            var lookupTask = Lookup.GetTypesAndPrioritiesAsync();
            var groupsTask = ApiService.GetGroupsAsync();
            var profileTask = ApiService.GetCurrentUserProfileAsync();
            await Task.WhenAll(lookupTask, groupsTask, profileTask);

            // Types + Priorities — cached lookup, raw server names; the
            // select renders TranslatedName, so no Name mutation here.
            var (types, allPriorities) = lookupTask.Result;
            _ticketTypes = types.ToList();
            _allPriorities = allPriorities.ToList();
            if (_ticketTypes.Count > 0) _selectedType = _ticketTypes[0];
            _priorities = TypePriorityCoupling.PrioritiesForType(_selectedType, _allPriorities);
            // Match by the raw (English) server name — Name stays untranslated.
            _selectedPriority = _priorities.FirstOrDefault(p =>
                string.Equals(p.Name, "Normal", StringComparison.OrdinalIgnoreCase));

            // Groups — filter to the visible set when we have a profile;
            // fall back to the raw list if the profile lookup failed so the
            // form still works (the server check is the real gate).
            var groupResponse = JsonSerializer.Deserialize<GetGroupResponse>(groupsTask.Result, options);
            var rawGroups = groupResponse?.Groups ?? new List<Group>();
            var visibleGroupIds = profileTask.Result?.Groups;
            _groups = FilterGroupsByVisibility(rawGroups, visibleGroupIds);
            _noVisibleGroups = visibleGroupIds != null && _groups.Count == 0;
            if (_groups.Count > 0) _selectedGroup = _groups[0];

            // Optional data: assignees (requires Agent/Admin role) and templates
            // (v2 endpoint, fails with v1 accesstoken). Fetched separately so a
            // failure doesn't break the whole form — the dropdowns just stay empty.
            try
            {
                var usersJson = await ApiService.GetAssigneesAsync();
                var userResponse = JsonSerializer.Deserialize<GetUserResponse>(usersJson, options);
                if (userResponse?.Users != null)
                    _users = userResponse.Users;
            }
            catch { /* Assignees unavailable for this role — hide dropdown */ }

            try
            {
                var templatesJson = await ApiService.GetTicketTemplatesAsync();
                _templates = TicketTemplateParser.ParseTemplates(templatesJson);
            }
            catch { /* Templates endpoint failed (v2 auth mismatch) — skip */ }
        }
        catch { Snackbar.Add(L.T("tickets.form_load_error"), Severity.Error); }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateTicketAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            if (!AppState.IsOnline)
            {
                await QueueOfflineCreateAsync();
                return;
            }

            var created = await ApiService.CreateTicketAsync(
                _subject, _issue,
                _selectedType?.Id, _selectedPriority?.Id,
                _selectedGroup?.Id, _selectedAssignee?.Id,
                _dueDate, _templateChecklist);

            if (created == null)
            {
                Snackbar.Add($"{L.T("common.error")}: {ApiService.LastError ?? L.T("tickets.server_rejected")}", Severity.Error);
                return;
            }

            // Successful submit — drop the draft so the next /tickets/add
            // visit starts fresh.
            _saveDebounce?.Dispose();
            await LocalStorage.RemoveItemAsync(DraftKey);

            // Upload any pre-picked attachments before we navigate. If the
            // server didn't echo back an id (older trudesk or malformed
            // response) we skip the upload step — the ticket itself is
            // created, the user just can't attach via this flow. Partial
            // failures still let the create stand.
            var failedUploads = 0;
            if (_pendingAttachments.Count > 0 && !string.IsNullOrEmpty(created.Id))
            {
                Snackbar.Add(L.T("tickets.attachments_uploading"), Severity.Info);
                foreach (var file in _pendingAttachments)
                {
                    try
                    {
                        using var stream = file.OpenReadStream(MaxAttachmentBytes);
                        if (!await ApiService.UploadAttachmentAsync(created.Id, stream, file.Name))
                            failedUploads++;
                    }
                    catch { failedUploads++; }
                }
            }

            if (failedUploads > 0)
            {
                Snackbar.Add(string.Format(L.T("tickets.attachments_partial"),
                    failedUploads, _pendingAttachments.Count), Severity.Warning);
            }
            else
            {
                Snackbar.Add(L.T("tickets.created"), Severity.Success);
            }
            Navigation.NavigateTo("tickets");
        }
        catch (HttpRequestException)
        {
            // Network died between the IsOnline check and the POST — same
            // recovery as the offline branch (pattern from TicketDetail).
            await QueueOfflineCreateAsync();
        }
        catch
        {
            Snackbar.Add(L.T("common.network_error"), Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // Offline path: park the ticket (incl. due date + template checklist —
    // both ride in the create payload since trudesk PR #106) in the
    // IndexedDB sync queue and leave the page as if the create succeeded.
    // Pre-picked attachments can't be queued: uploading needs the server-
    // assigned ticket id, which doesn't exist yet — tell the user instead
    // of dropping them silently.
    private async Task QueueOfflineCreateAsync()
    {
        await SyncService.EnqueueCreateTicketAsync(
            _subject, _issue,
            _selectedType?.Id, _selectedPriority?.Id,
            _selectedGroup?.Id, _selectedAssignee?.Id,
            _dueDate, _templateChecklist);

        _saveDebounce?.Dispose();
        await LocalStorage.RemoveItemAsync(DraftKey);

        if (_pendingAttachments.Count > 0)
        {
            Snackbar.Add(string.Format(L.T("tickets.attachments_offline"),
                _pendingAttachments.Count), Severity.Warning);
        }
        Snackbar.Add(L.T("offline.queued"), Severity.Info);
        Navigation.NavigateTo("tickets");
    }

    private void OnFilesPicked(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(maximumFileCount: 20))
        {
            if (file.Size > MaxAttachmentBytes)
            {
                Snackbar.Add(string.Format(L.T("tickets.attachments_too_large"), file.Name), Severity.Warning);
                continue;
            }
            _pendingAttachments.Add(file);
        }
        StateHasChanged();
    }

    private void RemovePendingAttachment(int index)
    {
        if (index < 0 || index >= _pendingAttachments.Count) return;
        _pendingAttachments.RemoveAt(index);
        StateHasChanged();
    }

    // Small humanizer for the file-size hint next to each picked file.
    // Kept inline because no existing helper does exactly this and it's
    // a 6-line tail formatter — abstracting it would obscure intent.
    internal static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024):0.#} MB";
    }

    // Couple the priority dropdown to the selected type: only offer the
    // priorities the type actually configures (union as fallback) and drop
    // a selection the new type doesn't know.
    private void OnTypeChanged(TicketType? type)
    {
        _selectedType = type;
        _priorities = TypePriorityCoupling.PrioritiesForType(type, _allPriorities);
        _selectedPriority = TypePriorityCoupling.EnsureSelected(_priorities, _selectedPriority);
    }

    private void OnTemplateSelected(TicketTemplate? template)
    {
        if (template == null)
        {
            // Selection cleared — drop the stashed checklist so we don't
            // apply items from a template the user backed out of.
            _templateChecklist = [];
            StateHasChanged();
            return;
        }
        _subject = template.Subject;
        _issue = template.Issue ?? string.Empty;
        // Apply Type + Priority from the template if they're set AND match a
        // loaded entry; otherwise leave the current selection so we don't blank
        // out a valid pre-pick.
        if (!string.IsNullOrEmpty(template.TypeId))
        {
            var match = _ticketTypes.FirstOrDefault(t => t.Id == template.TypeId);
            if (match != null) OnTypeChanged(match); // re-filters priorities too
        }
        if (!string.IsNullOrEmpty(template.PriorityId))
        {
            // Validate against the priorities of the type just applied,
            // not the cross-type union.
            var match = _priorities.FirstOrDefault(p => p.Id == template.PriorityId);
            if (match != null) _selectedPriority = match;
        }
        _templateChecklist = new List<string>(template.Checklist);
        StateHasChanged();
    }

    // Pure helper: keep the filter logic out of the async LoadDataAsync
    // so it can be unit-tested without bUnit. `visibleIds == null` means
    // "profile lookup failed — trust the raw list, server will gate";
    // an empty `visibleIds` means "profile loaded but resolved zero
    // groups" and we surface the warning.
    internal static List<Group> FilterGroupsByVisibility(List<Group> raw, List<string>? visibleIds)
    {
        if (visibleIds == null) return raw;
        if (visibleIds.Count == 0) return new List<Group>();
        var allowed = new HashSet<string>(visibleIds, StringComparer.Ordinal);
        return raw.Where(g => g.Id != null && allowed.Contains(g.Id)).ToList();
    }
}
