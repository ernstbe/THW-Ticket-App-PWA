@page "/tickets/add"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.LocalizationService L
@inject THWTicketApp.Web.Services.LocalStorageService LocalStorage
@implements IDisposable

<PageTitle>@L.T("tickets.create_title") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("tickets.create_title")</MudText>

@if (_isLoading && _ticketTypes.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-6">
        <MudSkeleton Width="100%" Height="56px" Class="mb-4" />
        <MudSkeleton Width="100%" Height="120px" Class="mb-4" />
        <MudGrid>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
            <MudItem xs="12" sm="6"><MudSkeleton Width="100%" Height="56px" Class="mb-4" /></MudItem>
        </MudGrid>
    </MudPaper>
}
else
{

<MudPaper Elevation="2" Class="pa-6">
    @if (_templates.Count > 0)
    {
        <MudSelect T="TemplateItem" Label="@L.T("tickets.use_template")" Variant="Variant.Outlined"
                   Clearable="true" Class="mb-4"
                   ToStringFunc="@(t => t?.Name ?? "")"
                   ValueChanged="OnTemplateSelected">
            @foreach (var tpl in _templates)
            {
                <MudSelectItem Value="tpl">@tpl.Name</MudSelectItem>
            }
        </MudSelect>
    }

    @if (_draftRestoredBanner)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _draftRestoredBanner = false)">
            <div class="d-flex align-center justify-space-between" style="width:100%;">
                <MudText>@L.T("tickets.draft_restored")</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="DiscardDraftAsync">
                    @L.T("tickets.draft_discard")
                </MudButton>
            </div>
        </MudAlert>
    }

    <MudForm @ref="_form">
        <MudTextField Value="@_subject" ValueChanged="@OnSubjectChanged" T="string"
                      Label="@L.T("detail.subject")" Variant="Variant.Outlined"
                      Required="true" RequiredError="@L.T("tickets.subject_required")"
                      Counter="200" MaxLength="200" Immediate="true" Class="mb-4" />

        <MudTextField Value="@_issue" ValueChanged="@OnIssueChanged" T="string"
                      Label="@L.T("detail.description")" Variant="Variant.Outlined"
                      Lines="5" Required="true" RequiredError="@L.T("tickets.description_required")"
                      Class="mb-4" />

        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudSelect T="TicketType" @bind-Value="_selectedType" Label="@L.T("detail.type")" Variant="Variant.Outlined"
                           ToStringFunc="@(t => t?.TranslatedName ?? "")" Class="mb-4">
                    @foreach (var type in _ticketTypes)
                    {
                        <MudSelectItem Value="type">@type.TranslatedName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="Priority" @bind-Value="_selectedPriority" Label="@L.T("detail.priority")" Variant="Variant.Outlined"
                           ToStringFunc="@(p => p?.TranslatedName ?? "")" Class="mb-4">
                    @foreach (var priority in _priorities)
                    {
                        <MudSelectItem Value="priority">@priority.TranslatedName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="Group" @bind-Value="_selectedGroup" Label="@L.T("detail.group")" Variant="Variant.Outlined"
                           Required="true" RequiredError="@L.T("tickets.group_required")"
                           ToStringFunc="@(g => g?.Name ?? "")" Class="mb-4">
                    @foreach (var group in _groups)
                    {
                        <MudSelectItem Value="group">@group.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="User" @bind-Value="_selectedAssignee" Label="@L.T("detail.assignee")" Variant="Variant.Outlined"
                           Clearable="true"
                           ToStringFunc="@(u => u?.Fullname ?? "")" Class="mb-4">
                    @foreach (var user in _users)
                    {
                        <MudSelectItem Value="user">@user.Fullname</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_dueDate"
                               Label="@L.T("detail.due")" Variant="Variant.Outlined"
                               PickerVariant="PickerVariant.Dialog"
                               Clearable="true" Editable="false" Class="mb-4" />
            </MudItem>
        </MudGrid>

        <div class="d-flex gap-3 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="CreateTicketAsync" Disabled="_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @L.T("tickets.create")
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("tickets"))">
                @L.T("common.cancel")
            </MudButton>
        </div>
    </MudForm>
</MudPaper>

}

@code {
    // localStorage key for the unsubmitted draft. Cleared on successful
    // create, on explicit "Verwerfen", or when the user lands on the page
    // with no stored content.
    internal const string DraftKey = "draft_new_ticket";

    private MudForm _form = null!;
    private bool _isLoading;
    private string _subject = string.Empty;
    private string _issue = string.Empty;
    private bool _draftRestoredBanner;
    private System.Threading.Timer? _saveDebounce;
    private TicketType? _selectedType;
    private Priority? _selectedPriority;
    private Group? _selectedGroup;
    private User? _selectedAssignee;
    private DateTime? _dueDate;
    private List<TicketType> _ticketTypes = [];
    private List<Priority> _priorities = [];
    private List<Group> _groups = [];
    private List<User> _users = [];
    private List<TemplateItem> _templates = [];

    protected override async Task OnInitializedAsync()
    {
        await TryRestoreDraftAsync();
        await LoadDataAsync();
    }

    private async Task TryRestoreDraftAsync()
    {
        var raw = await LocalStorage.GetItemAsync(DraftKey);
        if (string.IsNullOrEmpty(raw)) return;
        try
        {
            var draft = JsonSerializer.Deserialize<DraftDto>(raw);
            if (draft == null) return;
            if (string.IsNullOrWhiteSpace(draft.Subject) && string.IsNullOrWhiteSpace(draft.Issue)) return;
            _subject = draft.Subject ?? string.Empty;
            _issue = draft.Issue ?? string.Empty;
            _draftRestoredBanner = true;
        }
        catch { /* corrupted draft — ignore, user just types again */ }
    }

    private void OnSubjectChanged(string value)
    {
        _subject = value;
        ScheduleDraftSave();
    }

    private void OnIssueChanged(string value)
    {
        _issue = value;
        ScheduleDraftSave();
    }

    private void ScheduleDraftSave()
    {
        // Debounce: persist 500ms after the last keystroke so we don't
        // hammer localStorage on every character.
        _saveDebounce?.Dispose();
        _saveDebounce = new System.Threading.Timer(async _ =>
        {
            try
            {
                if (string.IsNullOrWhiteSpace(_subject) && string.IsNullOrWhiteSpace(_issue))
                {
                    await LocalStorage.RemoveItemAsync(DraftKey);
                }
                else
                {
                    var json = JsonSerializer.Serialize(new DraftDto { Subject = _subject, Issue = _issue });
                    await LocalStorage.SetItemAsync(DraftKey, json);
                }
            }
            catch { /* offline / quota / serialization — non-fatal */ }
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task DiscardDraftAsync()
    {
        _subject = string.Empty;
        _issue = string.Empty;
        _draftRestoredBanner = false;
        _saveDebounce?.Dispose();
        await LocalStorage.RemoveItemAsync(DraftKey);
    }

    public void Dispose()
    {
        _saveDebounce?.Dispose();
    }

    private sealed class DraftDto
    {
        public string? Subject { get; set; }
        public string? Issue { get; set; }
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            // Core data: types and groups are essential for ticket creation.
            var typesTask = ApiService.GetTicketTypesAsync();
            var groupsTask = ApiService.GetGroupsAsync();
            await Task.WhenAll(typesTask, groupsTask);

            // Types + Priorities
            var types = JsonSerializer.Deserialize<TicketType[]>(typesTask.Result, options);
            if (types != null)
            {
                _ticketTypes = types.ToList();
                _priorities = types.SelectMany(t => t.Priorities)
                    .DistinctBy(p => p.Id).ToList();
                foreach (var p in _priorities)
                    p.Name = TrudeskTranslationHelper.TranslatePriority(p.Name);
                if (_ticketTypes.Count > 0) _selectedType = _ticketTypes[0];
            }

            // Groups
            var groupResponse = JsonSerializer.Deserialize<GetGroupResponse>(groupsTask.Result, options);
            if (groupResponse?.Groups != null)
            {
                _groups = groupResponse.Groups;
                if (_groups.Count > 0) _selectedGroup = _groups[0];
            }

            // Optional data: assignees (requires Agent/Admin role) and templates
            // (v2 endpoint, fails with v1 accesstoken). Fetched separately so a
            // failure doesn't break the whole form — the dropdowns just stay empty.
            try
            {
                var usersJson = await ApiService.GetAssigneesAsync();
                var userResponse = JsonSerializer.Deserialize<GetUserResponse>(usersJson, options);
                if (userResponse?.Users != null)
                    _users = userResponse.Users;
            }
            catch { /* Assignees unavailable for this role — hide dropdown */ }

            try
            {
                var templatesJson = await ApiService.GetTicketTemplatesAsync();
                _templates = ParseTemplates(templatesJson);
            }
            catch { /* Templates endpoint failed (v2 auth mismatch) — skip */ }
        }
        catch { Snackbar.Add(L.T("tickets.form_load_error"), Severity.Error); }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateTicketAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            var success = await ApiService.CreateTicketAsync(
                _subject, _issue,
                _selectedType?.Id, _selectedPriority?.Id,
                _selectedGroup?.Id, _selectedAssignee?.Id,
                _dueDate);

            if (success)
            {
                // Successful submit — drop the draft so the next /tickets/add
                // visit starts fresh.
                _saveDebounce?.Dispose();
                await LocalStorage.RemoveItemAsync(DraftKey);
                Snackbar.Add(L.T("tickets.created"), Severity.Success);
                Navigation.NavigateTo("tickets");
            }
            else
            {
                Snackbar.Add($"{L.T("common.error")}: {ApiService.LastError ?? L.T("tickets.server_rejected")}", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add(L.T("common.network_error"), Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void OnTemplateSelected(TemplateItem? template)
    {
        if (template == null) return;
        _subject = template.Subject;
        _issue = template.Issue ?? string.Empty;
        // Apply Type + Priority from the template if they're set AND match a
        // loaded entry; otherwise leave the current selection so we don't blank
        // out a valid pre-pick.
        if (!string.IsNullOrEmpty(template.TypeId))
        {
            var match = _ticketTypes.FirstOrDefault(t => t.Id == template.TypeId);
            if (match != null) _selectedType = match;
        }
        if (!string.IsNullOrEmpty(template.PriorityId))
        {
            var match = _priorities.FirstOrDefault(p => p.Id == template.PriorityId);
            if (match != null) _selectedPriority = match;
        }
        StateHasChanged();
    }

    internal static List<TemplateItem> ParseTemplates(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("ticketTemplates", out var arr) || arr.ValueKind != JsonValueKind.Array)
                return new();
            var list = new List<TemplateItem>();
            foreach (var el in arr.EnumerateArray())
            {
                list.Add(new TemplateItem
                {
                    Name = el.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "",
                    Subject = el.TryGetProperty("subject", out var s) ? s.GetString() ?? "" : "",
                    Issue = el.TryGetProperty("issue", out var i) ? i.GetString() : null,
                    TypeId = ExtractRefId(el, "ticketType"),
                    PriorityId = ExtractRefId(el, "priority")
                });
            }
            return list;
        }
        catch { return new(); }
    }

    // trudesk's getAll populates refs as objects ({_id, name}) but raw create
    // payloads may store them as plain ObjectId strings. Tolerate both.
    private static string? ExtractRefId(JsonElement parent, string property)
    {
        if (!parent.TryGetProperty(property, out var el)) return null;
        if (el.ValueKind == JsonValueKind.String) return el.GetString();
        if (el.ValueKind == JsonValueKind.Object && el.TryGetProperty("_id", out var idEl))
            return idEl.GetString();
        return null;
    }

    internal sealed class TemplateItem
    {
        public string Name { get; set; } = string.Empty;
        public string Subject { get; set; } = string.Empty;
        public string? Issue { get; set; }
        public string? TypeId { get; set; }
        public string? PriorityId { get; set; }
    }
}
