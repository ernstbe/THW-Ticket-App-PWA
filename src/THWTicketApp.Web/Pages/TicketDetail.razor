    private static Color StatusChipColor(Status? s)
    {
        if (s == null) return Color.Default;
        if (s.IsResolved) return Color.Success;
        return s.Uid switch
        {
            1 => Color.Info,      // Open
            2 => Color.Warning,   // Pending
            _ => Color.Default
        };
    }

    private static Color PriorityChipColor(Priority? p)
    {
        if (p == null) return Color.Default;
        // Priority.Overdue maps to high — colour by name fallback.
        var n = (p.Name ?? "").ToLowerInvariant();
        if (n.Contains("hoch") || n.Contains("high") || n.Contains("urgent")) return Color.Error;
        if (n.Contains("normal")) return Color.Info;
        return Color.Default;
    }

