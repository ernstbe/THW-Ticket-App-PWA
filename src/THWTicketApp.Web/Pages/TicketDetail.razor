    private async Task LoadSubscriptionStateAsync()
    {
        var subJson = await LocalStorage.GetItemAsync("subscribed_tickets") ?? "[]";
        var subs = System.Text.Json.JsonSerializer.Deserialize<List<int>>(subJson) ?? [];
        _isSubscribed = subs.Contains(TicketUid);
    }

    private async Task ToggleSubscriptionAsync()
    {
        if (_ticket == null) return;
        try
        {
            var success = await ApiService.SubscribeToTicketAsync(_ticket.Uid.ToString(), !_isSubscribed);
            if (success)
            {
                _isSubscribed = !_isSubscribed;
                // Track locally
                var subJson = await LocalStorage.GetItemAsync("subscribed_tickets") ?? "[]";
                var subs = System.Text.Json.JsonSerializer.Deserialize<List<int>>(subJson) ?? [];
                if (_isSubscribed) { if (!subs.Contains(TicketUid)) subs.Add(TicketUid); }
                else subs.Remove(TicketUid);
                await LocalStorage.SetItemAsync("subscribed_tickets", System.Text.Json.JsonSerializer.Serialize(subs));
                Snackbar.Add(_isSubscribed ? L.T("detail.subscribed") : L.T("detail.unsubscribed"), Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
    }

