    private void OnRealtimeChange(string ticketId)
    {
        if (string.IsNullOrEmpty(ticketId) || _ticket?.Id != ticketId) return;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts = new CancellationTokenSource();
        var token = _refreshDebounceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                if (token.IsCancellationRequested) return;
                await LoadTicketAsync();
            }
            catch (TaskCanceledException) { }
        });
    }

    // ─── Data loading ────────────────────────────────────────────────────

    private async Task LoadTicketAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var json = await ApiService.GetTicketAsync(TicketUid.ToString());
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            using var doc = JsonDocument.Parse(json);
            _ticket = doc.RootElement.TryGetProperty("ticket", out var ticketEl)
                ? JsonSerializer.Deserialize<Ticket>(ticketEl.GetRawText(), options)
                : JsonSerializer.Deserialize<Ticket>(json, options);

            if (_ticket != null)
            {
                TrudeskTranslationHelper.TranslateTicket(_ticket);
                _editSubject = _ticket.Subject ?? string.Empty;
                _editIssue = _ticket.Issue ?? string.Empty;
                _ = RecentTickets.RecordAsync(
                    _ticket.Uid.ToString(),
                    _ticket.Subject ?? string.Empty,
                    _ticket.Status?.Uid);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ErrorHelper.Categorize(ex).Message}", Severity.Error);
        }
        finally { _isLoading = false; StateHasChanged(); }
    }

