    private async Task ShowQrCodeAsync()
    {
        // Generates fully client-side via QRCoder (no server round-trip,
        // no JS interop). The QR encodes the absolute /tickets/<uid> URL
        // so a phone scanning the screen lands on the same ticket.
        var parameters = new DialogParameters<TicketQrDialog>
        {
            { x => x.Uid, TicketUid }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        await DialogService.ShowAsync<TicketQrDialog>(L.T("detail.show_qr"), parameters, options);
    }

    private IJSObjectReference? _printQrModule;

    private async Task PrintQrCodeAsync()
    {
        // Renders the QR + ticket number into a popup window and triggers
        // print() — bypasses the dialog so it's one click from the menu.
        var url = $"{Navigation.BaseUri.TrimEnd('/')}/tickets/{TicketUid}";
        string svg;
        using (var generator = new QRCodeGenerator())
        using (var data = generator.CreateQrCode(url, QRCodeGenerator.ECCLevel.Q))
        {
            svg = new SvgQRCode(data).GetGraphic(8);
        }

        try
        {
            _printQrModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/print-qr.js");
            var ok = await _printQrModule.InvokeAsync<bool>("printQr",
                svg, $"#{TicketUid}", url);
            if (!ok) Snackbar.Add(L.T("common.popup_blocked"), Severity.Warning);
        }
        catch
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }

    // ─── Favorites / Subscription ───────────────────────────────────────

    private async Task LoadFavoriteStateAsync()
    {
        var favJson = await LocalStorage.GetItemAsync("favorite_tickets") ?? "[]";
        var favs = JsonSerializer.Deserialize<List<int>>(favJson) ?? [];
        _isFavorite = favs.Contains(TicketUid);
    }

    private async Task ToggleFavoriteAsync()
    {
        var favJson = await LocalStorage.GetItemAsync("favorite_tickets") ?? "[]";
        var favs = JsonSerializer.Deserialize<List<int>>(favJson) ?? [];
        if (_isFavorite) favs.Remove(TicketUid); else favs.Add(TicketUid);
        _isFavorite = !_isFavorite;
        await LocalStorage.SetItemAsync("favorite_tickets", JsonSerializer.Serialize(favs));
    }

    private async Task LoadSubscriptionStateAsync()
    {
        var subJson = await LocalStorage.GetItemAsync("subscribed_tickets") ?? "[]";
        var subs = JsonSerializer.Deserialize<List<int>>(subJson) ?? [];
        _isSubscribed = subs.Contains(TicketUid);
    }

    private async Task ToggleSubscriptionAsync()
    {
        if (_ticket == null) return;
        try
        {
            var success = await ApiService.SubscribeToTicketAsync(_ticket.Uid.ToString(), !_isSubscribed);
            if (success)
            {
                _isSubscribed = !_isSubscribed;
                var subJson = await LocalStorage.GetItemAsync("subscribed_tickets") ?? "[]";
                var subs = JsonSerializer.Deserialize<List<int>>(subJson) ?? [];
                if (_isSubscribed) { if (!subs.Contains(TicketUid)) subs.Add(TicketUid); }
                else subs.Remove(TicketUid);
                await LocalStorage.SetItemAsync("subscribed_tickets", JsonSerializer.Serialize(subs));
                Snackbar.Add(_isSubscribed ? L.T("detail.subscribed") : L.T("detail.unsubscribed"), Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
    }

    // ─── Linked tickets (local-only) ────────────────────────────────────

    private async Task LoadLinkedTicketsAsync()
    {
        try
        {
            var json = await LocalStorage.GetItemAsync($"linked_tickets_{TicketUid}");
            if (!string.IsNullOrEmpty(json))
                _linkedTickets = JsonSerializer.Deserialize<List<LinkedTicketItem>>(json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
        }
        catch { }
    }

    private async Task AddLinkedTicketAsync()
    {
        if (_linkTicketUid <= 0 || _linkTicketUid == TicketUid) return;
        if (_linkedTickets.Any(l => l.Uid == _linkTicketUid)) return;
        string subject = $"Ticket #{_linkTicketUid}";
        try
        {
            var json = await ApiService.GetTicketAsync(_linkTicketUid.ToString());
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("ticket", out var tEl))
            {
                var t = JsonSerializer.Deserialize<Ticket>(tEl.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (t?.Subject != null) subject = t.Subject;
            }
        }
        catch { }
        _linkedTickets.Add(new LinkedTicketItem { Uid = _linkTicketUid, Subject = subject, LinkType = _linkType });
        await SaveLinkedTicketsAsync();
        _linkTicketUid = 0;
    }

    private async Task RemoveLinkedTicketAsync(LinkedTicketItem link)
    {
        _linkedTickets.Remove(link);
        await SaveLinkedTicketsAsync();
    }

    private async Task SaveLinkedTicketsAsync()
        => await LocalStorage.SetItemAsync($"linked_tickets_{TicketUid}", JsonSerializer.Serialize(_linkedTickets));

    // ─── Quick replies ──────────────────────────────────────────────────

    private static readonly List<string> DefaultQuickReplies =
    [
        "Vielen Dank für Ihre Meldung. Wir kümmern uns darum.",
        "Das Problem wurde behoben. Bitte prüfen Sie, ob alles funktioniert.",
        "Könnten Sie bitte weitere Informationen bereitstellen?",
        "Die Bearbeitung ist in Arbeit. Wir melden uns, sobald es Neuigkeiten gibt.",
        "Das Ticket wird an die zuständige Abteilung weitergeleitet."
    ];

    private async Task LoadQuickRepliesAsync()
    {
        try
        {
            var json = await LocalStorage.GetItemAsync("quick_reply_templates");
            _quickReplyTemplates = !string.IsNullOrEmpty(json)
                ? JsonSerializer.Deserialize<List<string>>(json) ?? new(DefaultQuickReplies)
                : new(DefaultQuickReplies);
        }
        catch { _quickReplyTemplates = new(DefaultQuickReplies); }
    }

    private void InsertQuickReply(string template) => _newComment = template;
    private void InsertMention(User user) => _newComment += $" @{user.Fullname} ";
    internal static string TruncateTemplate(string t) => t.Length > 50 ? t[..47] + "..." : t;
    private void OpenQuickReplyEditor() => _showQuickReplyEditor = true;
    private void AddEmptyQuickReply() => _quickReplyTemplates.Add(string.Empty);
    private void RemoveQuickReply(int idx) { if (idx < _quickReplyTemplates.Count) _quickReplyTemplates.RemoveAt(idx); }

    private async Task SaveQuickRepliesAsync()
    {
        _quickReplyTemplates.RemoveAll(string.IsNullOrWhiteSpace);
        await LocalStorage.SetItemAsync("quick_reply_templates", JsonSerializer.Serialize(_quickReplyTemplates));
        _showQuickReplyEditor = false;
        Snackbar.Add(L.T("detail.templates_saved"), Severity.Success);
    }

    // ─── Disposal ───────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        Realtime.AnyTicketChanged -= OnRealtimeChange;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts?.Dispose();
        if (_dropzoneModule != null)
        {
            try { await _dropzoneModule.InvokeVoidAsync("unregister", "attachment-dropzone"); } catch { }
            try { await _dropzoneModule.DisposeAsync(); } catch { }
        }
        if (_printQrModule != null)
        {
            try { await _printQrModule.DisposeAsync(); } catch { }
        }
    }

    // ─── Local DTOs ─────────────────────────────────────────────────────

    private class LinkedTicketItem
    {
        public int Uid { get; set; }
        public string Subject { get; set; } = string.Empty;
        public string LinkType { get; set; } = string.Empty;
    }
}
