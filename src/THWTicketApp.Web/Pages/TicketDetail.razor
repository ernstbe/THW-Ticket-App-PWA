            @* Linked tickets — ausgeblendet auf Nutzerwunsch (war localStorage-only,
               nicht serverseitig persistiert). Code bleibt für eine spätere
               serverseitige Reimplementierung erhalten. *@
            @if (false)
            {
                <MudPaper Elevation="1" Class="pa-4 mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.linked")</MudText>
                    @if (_linkedTickets.Count > 0)
                    {
                        <div class="d-flex flex-column gap-1 mb-2">
                            @foreach (var link in _linkedTickets)
                            {
                                var l = link;
                                <div class="d-flex align-center gap-2">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@l.LinkType</MudChip>
                                    <MudLink Href="@($"/tickets/{l.Uid}")" Typo="Typo.body2" Style="flex:1; min-width:0;">
                                        #@l.Uid – @l.Subject
                                    </MudLink>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                   OnClick="@(() => RemoveLinkedTicketAsync(l))" />
                                </div>
