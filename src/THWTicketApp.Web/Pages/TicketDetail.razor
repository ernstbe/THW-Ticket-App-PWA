    // Time tracking
    private void StartTimer()
    {
        _timerStart = DateTime.Now;
        _timerRunning = true;
        _timerElapsed = TimeSpan.Zero;
        _timer = new System.Threading.Timer(_ =>
        {
            _timerElapsed = DateTime.Now - _timerStart;
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private async Task StopTimer()
    {
        _timer?.Dispose();
        _timer = null;
        _timerRunning = false;
        var duration = DateTime.Now - _timerStart;

        if (duration.TotalMinutes >= 0.5)
        {
            var entry = new TimeEntryItem
            {
                Start = _timerStart,
                DurationMinutes = (int)Math.Ceiling(duration.TotalMinutes),
                Description = string.IsNullOrWhiteSpace(_timeEntryDescription) ? null : _timeEntryDescription
            };
            _timeEntries.Add(entry);
            _totalTimeMinutes = _timeEntries.Sum(e => e.DurationMinutes);
            _timeEntryDescription = string.Empty;
            await SaveTimeEntriesAsync();
        }

        _timerElapsed = TimeSpan.Zero;
    }

    private async Task LoadTimeEntriesAsync()
    {
        try
        {
            var json = await LocalStorage.GetItemAsync($"time_entries_{TicketUid}");
            if (!string.IsNullOrEmpty(json))
            {
                _timeEntries = System.Text.Json.JsonSerializer.Deserialize<List<TimeEntryItem>>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
                _totalTimeMinutes = _timeEntries.Sum(e => e.DurationMinutes);
            }
        }
        catch { }
    }

    private async Task SaveTimeEntriesAsync()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_timeEntries);
        await LocalStorage.SetItemAsync($"time_entries_{TicketUid}", json);
    }

    internal static string FormatElapsed(TimeSpan ts) =>
        $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}";

    internal static string FormatMinutes(int minutes)
    {
        if (minutes >= 60) return $"{minutes / 60}h {minutes % 60}m";
        return $"{minutes}m";
    }

    public void Dispose()
    {
        Realtime.AnyTicketChanged -= OnRealtimeChange;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts?.Dispose();
        _timer?.Dispose();
    }

    private class TimeEntryItem
    {
        public DateTime Start { get; set; }
        public int DurationMinutes { get; set; }
        public string? Description { get; set; }
    }

    private class LinkedTicketItem
    {
        public int Uid { get; set; }
        public string Subject { get; set; } = string.Empty;
        public string LinkType { get; set; } = string.Empty;
    }
