    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        if (_ticket == null) return;
        _isUploading = true;
        StateHasChanged();
        try
        {
            var file = e.File;
            // Match the server-side 25 MB pre-resize ceiling so we fail-fast
            // on the client instead of wasting bandwidth on an upload the
            // backend will reject. The sync-queue path below uses
            // SyncService.MaxAttachmentBytes (5 MB) — smaller because the
            // file gets base64'd into IndexedDB.
            if (!AppState.IsOnline)
            {
                using var memStream = new MemoryStream();
                await file.OpenReadStream(maxAllowedSize: THWTicketApp.Web.Services.SyncService.MaxAttachmentBytes)
                    .CopyToAsync(memStream);
                await SyncService.EnqueueUploadAttachmentAsync(
                    _ticket.Id, _ticket.Uid, file.Name, memStream.ToArray(),
                    string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType,
                    _ticket.Updated);
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
            if (await ApiService.UploadAttachmentAsync(_ticket.Id, stream, file.Name))
            {
                Snackbar.Add(L.T("attachments.uploaded"), Severity.Success);
                await LoadTicketAsync();
            }
            else Snackbar.Add(L.T("common.error"), Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isUploading = false; StateHasChanged(); }
    }

