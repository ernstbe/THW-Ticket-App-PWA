    private async Task OnDueDateChangedAsync(DateTime? newDate)
    {
        if (_ticket == null) return;
        // Treat "no change" as a no-op so a re-render that pushes the same
        // value through the picker doesn't ping the API every time.
        var current = _ticket.DueDate == DateTime.MinValue ? (DateTime?)null : _ticket.DueDate.Date;
        if (current == newDate?.Date) return;

        _dueDateLocal = newDate;
        _ticket.DueDate = newDate ?? DateTime.MinValue;
        var ticketId = _ticket.Id;
        var ticketUid = _ticket.Uid;
        var updatedAt = _ticket.Updated;
        try
        {
            if (!AppState.IsOnline)
            {
                // newDate == null is an explicit clear here (the no-op guard
                // above already returned for "unchanged") — flag it so the
                // sync sends the same explicit null as the online path.
                await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, null, null, null, null, null, newDate, updatedAt, dueDateCleared: newDate == null);
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }
            if (await ApiService.EditTicketAsync(_ticket))
            {
                Snackbar.Add(L.T("detail.ticket_updated"), Severity.Success);
                await LoadTicketAsync();
            }
            else Snackbar.Add(L.T("detail.update_failed"), Severity.Error);
        }
        catch (HttpRequestException)
        {
            await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, null, null, null, null, null, newDate, updatedAt, dueDateCleared: newDate == null);
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
    }

