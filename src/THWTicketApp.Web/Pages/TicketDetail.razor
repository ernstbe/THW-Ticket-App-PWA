@page "/tickets/{TicketUid:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@using Markdig
@using Microsoft.AspNetCore.Components.Forms
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage
@inject LocalizationService L
@inject THWTicketApp.Web.Services.RealtimeService Realtime
@inject IJSRuntime JsRuntime
@inject THWTicketApp.Web.Services.RecentTicketsService RecentTickets
@implements IAsyncDisposable

<PageTitle>@(_ticket?.Subject ?? "Ticket") - THW Ticket App</PageTitle>

@if (_isLoading && _ticket == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_ticket == null)
{
    <MudAlert Severity="Severity.Error">@L.T("detail.not_found")</MudAlert>
}
else
{
    @* ─── Header ───────────────────────────────────────────────────────── *@
    <div class="d-flex align-center gap-2 mb-2 pwa-no-print">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("tickets"))"
                       aria-label="@L.T("common.back")" />
        <MudText Typo="Typo.caption" Color="Color.Secondary">#@_ticket.Uid</MudText>
        @if (_editingTitle)
        {
            <MudTextField @bind-Value="_editSubject" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Immediate="true" Style="flex:1;"
                          OnKeyDown="@(async (e) => { if (e.Key == "Enter") await SaveTitleAsync(); else if (e.Key == "Escape") CancelTitleEdit(); })" />
            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                           OnClick="SaveTitleAsync" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="CancelTitleEdit" />
        }
        else
        {
            <MudText Typo="Typo.h5" Style="flex:1; cursor:text;" @onclick="StartTitleEdit"
                     title="@L.T("detail.click_to_edit")">@_ticket.Subject</MudText>
        }
        <MudIconButton Icon="@(_isFavorite ? Icons.Material.Filled.Star : Icons.Material.Filled.StarOutline)"
                       Color="@(_isFavorite ? Color.Warning : Color.Default)"
                       OnClick="ToggleFavoriteAsync"
                       aria-label="@L.T("detail.favorite")" />
        <MudTooltip Text="@(_isSubscribed ? L.T("detail.unsubscribe") : L.T("detail.subscribe"))">
            <MudIconButton Icon="@(_isSubscribed ? Icons.Material.Filled.NotificationsActive : Icons.Material.Filled.NotificationsNone)"
                           Color="@(_isSubscribed ? Color.Info : Color.Default)"
                           OnClick="ToggleSubscriptionAsync" />
        </MudTooltip>
        <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Print" OnClick="PrintAsync">@L.T("detail.print")</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="DeleteTicketAsync">
                <MudText Color="Color.Error">@L.T("detail.delete_ticket")</MudText>
            </MudMenuItem>
        </MudMenu>
    </div>

    @* ─── Chips bar — inline status/priority/group/assignee changes ───── *@
    <div class="d-flex align-center gap-2 mb-4 pwa-no-print flex-wrap">
        <ChipWithMenu T="Status"
                      Label="@_ticket.Status?.TranslatedName"
                      Icon="@Icons.Material.Filled.Circle"
                      Color="@StatusChipColor(_ticket.Status)"
                      Items="_statuses"
                      ItemTitle="@(s => s.TranslatedName ?? "")"
                      OnSelected="QuickChangeStatusAsync" />
        <ChipWithMenu T="Priority"
                      Label="@_ticket.Priority?.TranslatedName"
                      Icon="@Icons.Material.Filled.Flag"
                      Color="@PriorityChipColor(_ticket.Priority)"
                      Items="_priorities"
                      ItemTitle="@(p => p.TranslatedName ?? "")"
                      OnSelected="QuickChangePriorityAsync" />
        <ChipWithMenu T="Group"
                      Label="@_ticket.Group?.Name"
                      EmptyLabel="@L.T("detail.no_group")"
                      Icon="@Icons.Material.Filled.Group"
                      Items="_groups"
                      ItemTitle="@(g => g.Name ?? "")"
                      OnSelected="QuickChangeGroupAsync" />
        <ChipWithMenu T="User"
                      Label="@_ticket.Assignee?.Fullname"
                      EmptyLabel="@L.T("detail.unassigned")"
                      Icon="@Icons.Material.Filled.AssignmentInd"
                      Items="_users"
                      ItemTitle="@(u => u.Fullname ?? "")"
                      OnSelected="QuickAssignAsync"
                      OnClear="ClearAssigneeAsync"
                      ClearLabel="@L.T("detail.remove_assign")"
                      EmptyMenuLabel="@L.T("detail.no_assignees_available")" />
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
    }

    @* ─── Print-only summary (revealed by @media print in app.css) ───── *@
    <div class="pwa-print-only">
        <h1>THW Ticket #@_ticket.Uid</h1>
        <h2>@_ticket.Subject</h2>
        <table>
            <tr><th>Status</th><td>@(_ticket.Status?.TranslatedName ?? "-")</td></tr>
            <tr><th>Priorität</th><td>@(_ticket.Priority?.TranslatedName ?? "-")</td></tr>
            <tr><th>Ersteller</th><td>@(_ticket.Owner?.Fullname ?? "-")</td></tr>
            <tr><th>Zuständig</th><td>@(_ticket.Assignee?.Fullname ?? "Nicht zugewiesen")</td></tr>
            <tr><th>Gruppe</th><td>@(_ticket.Group?.Name ?? "-")</td></tr>
            <tr><th>Typ</th><td>@(_ticket.Type?.TranslatedName ?? "-")</td></tr>
            <tr><th>Erstellt</th><td>@_ticket.Date.ToString("dd.MM.yyyy HH:mm")</td></tr>
            <tr><th>Aktualisiert</th><td>@_ticket.Updated.ToString("dd.MM.yyyy HH:mm")</td></tr>
            @if (_ticket.DueDate != DateTime.MinValue)
            {
                <tr><th>Fällig</th><td>@_ticket.DueDate.ToString("dd.MM.yyyy")</td></tr>
            }
        </table>
        <h3>Beschreibung</h3>
        <div>
            @if (!string.IsNullOrEmpty(_ticket.Issue))
            {
                @((MarkupString)Markdown.ToHtml(_ticket.Issue, _mdPipeline))
            }
            else { <em>Keine Beschreibung.</em> }
        </div>
        @if (_ticket.Comments?.Count > 0)
        {
            <h3>Kommentare (@_ticket.Comments.Count)</h3>
            @foreach (var c in _ticket.Comments.OrderBy(c => c.Date))
            {
                <div style="margin-bottom:1em;">
                    <strong>@(c.Owner?.Fullname ?? "?")</strong>
                    <span>— @c.Date.ToString("dd.MM.yyyy HH:mm")</span>
                    <div>@((MarkupString)Markdown.ToHtml(c.Text ?? string.Empty, _mdPipeline))</div>
                </div>
            }
        }
        @if (_ticket.Notes?.Count > 0)
        {
            <h3>Notizen (@_ticket.Notes.Count)</h3>
            @foreach (var n in _ticket.Notes.OrderBy(n => n.Date))
            {
                <div style="margin-bottom:1em;">
                    <strong>@(n.Owner?.Fullname ?? "?")</strong>
                    <span>— @n.Date.ToString("dd.MM.yyyy HH:mm")</span>
                    <div>@((MarkupString)Markdown.ToHtml(n.Content ?? string.Empty, _mdPipeline))</div>
                </div>
            }
        }
        <p style="margin-top:2em; font-size:10px; color:#666;">
            Gedruckt am @DateTime.Now.ToString("dd.MM.yyyy HH:mm") — THW Ticket App
        </p>
    </div>

    @* ─── Main layout: left = description+feed+composer, right = sidebar ─ *@
    <MudGrid Class="pwa-no-print">
        <MudItem xs="12" md="8">
            @* Description (click to edit) *@
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle2">@L.T("detail.description")</MudText>
                    @if (!_editingDescription)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="StartDescriptionEdit"
                                       aria-label="@L.T("common.edit")" />
                    }
                </div>
                @if (_editingDescription)
                {
                    <MudTextField @bind-Value="_editIssue" Variant="Variant.Outlined" Lines="6"
                                  Immediate="true" Class="mb-2" />
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="SaveDescriptionAsync" Disabled="_isLoading">
                            @L.T("common.save")
                        </MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                   OnClick="CancelDescriptionEdit">
                            @L.T("common.cancel")
                        </MudButton>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(_ticket.Issue))
                    {
                        @((MarkupString)Markdown.ToHtml(_ticket.Issue, _mdPipeline))
                    }
                    else
                    {
                        <MudText Color="Color.Secondary"><em>@L.T("detail.no_description")</em></MudText>
                    }
                }
            </MudPaper>

            @* Activity feed *@
            <MudText Typo="Typo.h6" Class="mb-3">@L.T("detail.activity")</MudText>
            <TicketActivityFeed Ticket="_ticket" />

            @* Composer — bottom of the left column, sticky-ish *@
            <MudPaper Elevation="2" Class="pa-3 mt-6" Style="position: sticky; bottom: 0;">
                <MudTabs Elevation="0" Rounded="false" Border="false"
                         ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_composerTab">
                    <MudTabPanel Text="@L.T("detail.composer_comment")" Icon="@Icons.Material.Filled.Comment">
                        @* Quick replies + mentions *@
                        <div class="d-flex gap-2 mb-2 flex-wrap">
                            <MudMenu Label="@L.T("comments.quickreply")" Variant="Variant.Outlined" Size="Size.Small"
                                     StartIcon="@Icons.Material.Filled.Reply" Dense="true">
                                @foreach (var template in _quickReplyTemplates)
                                {
                                    <MudMenuItem OnClick="@(() => InsertQuickReply(template))">@TruncateTemplate(template)</MudMenuItem>
                                }
                                <MudDivider />
                                <MudMenuItem OnClick="OpenQuickReplyEditor">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-1" />
                                    @L.T("detail.edit_templates")
                                </MudMenuItem>
                            </MudMenu>
                            @if (_users.Any())
                            {
                                <MudMenu Label="@L.T("comments.mention")" Variant="Variant.Outlined" Size="Size.Small"
                                         StartIcon="@Icons.Material.Filled.AlternateEmail" Dense="true">
                                    @foreach (var user in _users)
                                    {
                                        <MudMenuItem OnClick="@(() => InsertMention(user))">@user.Fullname</MudMenuItem>
                                    }
                                </MudMenu>
                            }
                            <MudToggleIconButton Toggled="@_commentPreview"
                                                 ToggledChanged="@((bool v) => _commentPreview = v)"
                                                 Icon="@Icons.Material.Filled.Edit"
                                                 ToggledIcon="@Icons.Material.Filled.Visibility"
                                                 Size="Size.Small"
                                                 title="@L.T("comments.preview_toggle")" />
                        </div>
                        @if (_showQuickReplyEditor)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background: var(--mud-palette-background-gray);">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.quickreply_templates")</MudText>
                                @for (int i = 0; i < _quickReplyTemplates.Count; i++)
                                {
                                    var idx = i;
                                    <div class="d-flex gap-2 mb-1 align-center">
                                        <MudTextField @bind-Value="_quickReplyTemplates[idx]" Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" Style="flex: 1;" T="string" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error" OnClick="@(() => RemoveQuickReply(idx))" />
                                    </div>
                                }
                                <div class="d-flex gap-2 mt-2">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="AddEmptyQuickReply"
                                               StartIcon="@Icons.Material.Filled.Add">@L.T("detail.new_template")</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                               OnClick="SaveQuickRepliesAsync">@L.T("common.save")</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Text"
                                               OnClick="@(() => _showQuickReplyEditor = false)">@L.T("common.close")</MudButton>
                                </div>
                            </MudPaper>
                        }
                        @if (_commentPreview)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mb-3"
                                      Style="background: var(--mud-palette-background-gray); min-height: 80px;">
                                @if (string.IsNullOrWhiteSpace(_newComment))
                                {
                                    <MudText Color="Color.Secondary"><em>@L.T("comments.preview_empty")</em></MudText>
                                }
                                else
                                {
                                    @((MarkupString)Markdown.ToHtml(_newComment, _mdPipeline))
                                }
                            </MudPaper>
                        }
                        else
                        {
                            <MudTextField @bind-Value="_newComment" Placeholder="@L.T("comments.new")"
                                          Variant="Variant.Outlined" Lines="3" Class="mb-2" />
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="false"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   OnClick="AddCommentAsync"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newComment) || _isLoading)">
                            @L.T("comments.send")
                        </MudButton>
                    </MudTabPanel>
                    <MudTabPanel Text="@L.T("detail.composer_note")" Icon="@Icons.Material.Filled.Note">
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            @L.T("detail.note_visible_internal")
                        </MudAlert>
                        <MudTextField @bind-Value="_newNote" Placeholder="@L.T("notes.new")"
                                      Variant="Variant.Outlined" Lines="3" Class="mb-2" />
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.NoteAdd"
                                   OnClick="AddNoteAsync"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newNote) || _isLoading)">
                            @L.T("notes.add")
                        </MudButton>
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        </MudItem>

        @* ─── Sidebar ────────────────────────────────────────────────── *@
        <MudItem xs="12" md="4">
            @* Meta *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.details")</MudText>
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex align-center gap-2">
                        <UserAvatar Name="@_ticket.Owner?.Fullname" Size="Size.Small" />
                        <div style="flex:1;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.creator")</MudText>
                            <MudText Typo="Typo.body2">@(_ticket.Owner?.Fullname ?? L.T("common.unknown"))</MudText>
                        </div>
                    </div>
                    <MudDivider Class="my-2" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.type")</MudText>
                        <MudText Typo="Typo.body2">@(_ticket.Type?.TranslatedName ?? "-")</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.created")</MudText>
                        <MudText Typo="Typo.body2">@_ticket.Date.ToString("dd.MM.yyyy HH:mm")</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.updated")</MudText>
                        <MudText Typo="Typo.body2">@_ticket.Updated.ToString("dd.MM.yyyy HH:mm")</MudText>
                    </div>
                    @if (_ticket.DueDate != DateTime.MinValue)
                    {
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.due")</MudText>
                            <MudText Typo="Typo.body2" Color="@(_ticket.DueDate < DateTime.Now ? Color.Error : Color.Default)">
                                @_ticket.DueDate.ToString("dd.MM.yyyy HH:mm")
                            </MudText>
                        </div>
                    }
                </div>
            </MudPaper>

            @* Tags *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.tags")</MudText>
                <div class="d-flex flex-wrap gap-1 align-center">
                    @if (_ticket.Tags?.Count > 0)
                    {
                        @foreach (var tag in _ticket.Tags)
                        {
                            var tagId = tag.Id;
                            <MudChip T="string" Size="Size.Small" OnClose="@(_ => RemoveTagAsync(tagId!))"
                                     Disabled="_isLoading">@tag.Name</MudChip>
                        }
                    }
                    @if (_availableTags.Any(t => !(_ticket.Tags?.Any(tt => tt.Id == t.Id) ?? false)))
                    {
                        <MudMenu Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                 Dense="true" aria-label="@L.T("detail.add_tag")">
                            @foreach (var tag in _availableTags.Where(t => !(_ticket.Tags?.Any(tt => tt.Id == t.Id) ?? false)))
                            {
                                <MudMenuItem OnClick="@(() => AddTagAsync(tag.Id!, tag.Name!))">@tag.Name</MudMenuItem>
                            }
                        </MudMenu>
                    }
                    @if ((_ticket.Tags?.Count ?? 0) == 0 && !_availableTags.Any())
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                    }
                </div>
            </MudPaper>

            @* Checklist *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    @L.T("checklist.title")
                    @if (_ticket.Checklist?.Count > 0)
                    {
                        <span style="font-weight:normal; opacity:0.7;">
                            (@(_ticket.Checklist.Count(c => c.Completed))/@_ticket.Checklist.Count)
                        </span>
                    }
                </MudText>
                @if (_ticket.Checklist?.Count > 0)
                {
                    <div class="d-flex flex-column gap-1 mb-2">
                        @foreach (var item in _ticket.Checklist)
                        {
                            var itemRef = item;
                            <div class="d-flex align-center gap-2">
                                <MudCheckBox T="bool" Value="@itemRef.Completed" Dense="true"
                                             ValueChanged="@(v => ToggleChecklistItemAsync(itemRef.Id!, v))"
                                             Disabled="_isLoading" />
                                <MudText Typo="Typo.body2"
                                         Style="@(itemRef.Completed ? "text-decoration: line-through; opacity: 0.6; flex:1;" : "flex:1;")">
                                    @itemRef.Title
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="@(() => DeleteChecklistItemAsync(itemRef.Id!))"
                                               Disabled="_isLoading"
                                               aria-label="@L.T("common.delete")" />
                            </div>
                        }
                    </div>
                }
                <div class="d-flex gap-1">
                    <MudTextField @bind-Value="_newChecklistTitle" Placeholder="@L.T("checklist.new_item")"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1"
                                  OnKeyDown="@(async (e) => { if (e.Key == "Enter") await AddChecklistItemAsync(); })" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                   OnClick="AddChecklistItemAsync"
                                   Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_newChecklistTitle))" />
                </div>
            </MudPaper>

            @* Attachments *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    @L.T("attachments.title")
                    @if (_ticket.Attachments?.Count > 0)
                    {
                        <span style="font-weight:normal; opacity:0.7;">(@_ticket.Attachments.Count)</span>
                    }
                </MudText>
                <div id="attachment-dropzone" class="pwa-dropzone pa-2">
                    @if (_ticket.Attachments != null && _ticket.Attachments.Count > 0)
                    {
                        <div class="d-flex flex-column gap-1 mb-2">
                            @foreach (var att in _ticket.Attachments)
                            {
                                var a = att;
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                                    <MudLink Typo="Typo.body2" Style="flex:1; min-width:0; word-break:break-all;"
                                             OnClick="@(() => DownloadAttachment(a))">@a.Name</MudLink>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@a.SizeFormatted</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="() => DeleteAttachmentAsync(a)" />
                                </div>
                            }
                        </div>
                    }
                    <div class="d-flex gap-2 align-center">
                        <InputFile id="attachment-upload" OnChange="OnFileSelectedAsync" hidden
                                   accept=".pdf,.png,.jpg,.jpeg,.gif,.doc,.docx,.xls,.xlsx,.txt,.zip" />
                        <MudButton HtmlTag="label" Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CloudUpload" for="attachment-upload"
                                   Disabled="_isUploading">
                            @(_isUploading ? L.T("attachments.uploading") : L.T("attachments.upload"))
                        </MudButton>
                        @if (_isUploading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @L.T("attachments.drop_hint")
                        </MudText>
                    </div>
                </div>
            </MudPaper>

            @* Linked tickets *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.linked")</MudText>
                @if (_linkedTickets.Count > 0)
                {
                    <div class="d-flex flex-column gap-1 mb-2">
                        @foreach (var link in _linkedTickets)
                        {
                            var l = link;
                            <div class="d-flex align-center gap-2">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@l.LinkType</MudChip>
                                <MudLink Href="@($"/tickets/{l.Uid}")" Typo="Typo.body2" Style="flex:1; min-width:0;">
                                    #@l.Uid – @l.Subject
                                </MudLink>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="@(() => RemoveLinkedTicketAsync(l))" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-2">@L.T("detail.no_links")</MudText>
                }
                <div class="d-flex gap-1 align-center">
                    <MudNumericField @bind-Value="_linkTicketUid" Placeholder="#" Variant="Variant.Outlined"
                                     Margin="Margin.Dense" Style="max-width: 80px;" T="int" />
                    <MudSelect @bind-Value="_linkType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Dense="true" T="string" Style="flex:1;">
                        <MudSelectItem Value="@(L.T("detail.link_related"))">@L.T("detail.link_related")</MudSelectItem>
                        <MudSelectItem Value="@(L.T("detail.link_blocks"))">@L.T("detail.link_blocks")</MudSelectItem>
                        <MudSelectItem Value="@(L.T("detail.link_blocked_by"))">@L.T("detail.link_blocked_by")</MudSelectItem>
                        <MudSelectItem Value="@(L.T("detail.link_duplicate"))">@L.T("detail.link_duplicate")</MudSelectItem>
                    </MudSelect>
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                   OnClick="AddLinkedTicketAsync" />
                </div>
            </MudPaper>

            @* Time tracking *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    @L.T("time.title")
                    <span style="font-weight:normal; opacity:0.7;">(@FormatMinutes(_totalTimeMinutes))</span>
                </MudText>
                <div class="d-flex align-center gap-2 mb-2">
                    <MudText Typo="Typo.h6" Style="font-family:monospace; flex:1;"
                             Color="@(_timerRunning ? Color.Primary : Color.Default)">
                        @FormatElapsed(_timerElapsed)
                    </MudText>
                    @if (!_timerRunning)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success"
                                       OnClick="StartTimer" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Stop" Color="Color.Error"
                                       OnClick="StopTimer" />
                    }
                </div>
                @if (_timerRunning)
                {
                    <MudTextField @bind-Value="_timeEntryDescription" Placeholder="@L.T("time.description")"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                }
                @if (_timeEntries.Count > 0)
                {
                    <MudExpansionPanels Elevation="0" Class="mt-2" Dense="true">
                        <MudExpansionPanel Text="@($"{_timeEntries.Count} {L.T("time.entries_short")}")">
                            <div class="d-flex flex-column gap-1">
                                @foreach (var entry in _timeEntries.OrderByDescending(e => e.Start))
                                {
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.caption">@entry.Start.ToString("dd.MM HH:mm")</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatMinutes(entry.DurationMinutes)</MudText>
                                        @if (!string.IsNullOrEmpty(entry.Description))
                                        {
                                            <MudText Typo="Typo.caption" Style="flex:1;">@entry.Description</MudText>
                                        }
                                    </div>
                                }
                            </div>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

