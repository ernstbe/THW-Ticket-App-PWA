    private bool _isUploading;
    private IJSObjectReference? _dropzoneModule;

    // Quick replies
    private List<string> _quickReplyTemplates = new();
    private bool _showQuickReplyEditor;

    // Linked tickets (local)
    private List<LinkedTicketItem> _linkedTickets = [];
    private int _linkTicketUid;
    private string _linkType = "";

    private CancellationTokenSource? _refreshDebounceCts;

    // ─── Lifecycle ───────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _linkType = L.T("detail.link_related");
        await LoadTicketAsync();
        _ = LoadReferenceDataAsync();
        await LoadFavoriteStateAsync();
        await LoadLinkedTicketsAsync();
        await LoadQuickRepliesAsync();
        await LoadSubscriptionStateAsync();
        Realtime.AnyTicketChanged += OnRealtimeChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _ticket == null) return;
        try
        {
            _dropzoneModule = await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/dropzone-interop.js");
            await _dropzoneModule.InvokeVoidAsync("register",
                "attachment-dropzone", "attachment-upload");
        }
        catch { /* drag-drop is optional — button still works */ }
    }

    private void OnRealtimeChange(string ticketId)
    {
        if (string.IsNullOrEmpty(ticketId) || _ticket?.Id != ticketId) return;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts = new CancellationTokenSource();
        var token = _refreshDebounceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                if (token.IsCancellationRequested) return;
                await LoadTicketAsync();
            }
            catch (TaskCanceledException) { }
        });
    }

    // ─── Data loading ────────────────────────────────────────────────────

    private async Task LoadTicketAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var json = await ApiService.GetTicketAsync(TicketUid.ToString());
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            using var doc = JsonDocument.Parse(json);
            _ticket = doc.RootElement.TryGetProperty("ticket", out var ticketEl)
                ? JsonSerializer.Deserialize<Ticket>(ticketEl.GetRawText(), options)
                : JsonSerializer.Deserialize<Ticket>(json, options);

            if (_ticket != null)
            {
                TrudeskTranslationHelper.TranslateTicket(_ticket);
                _editSubject = _ticket.Subject ?? string.Empty;
                _editIssue = _ticket.Issue ?? string.Empty;
                _dueDateLocal = _ticket.DueDate == DateTime.MinValue ? null : _ticket.DueDate;
                _ = RecentTickets.RecordAsync(
                    _ticket.Uid.ToString(),
                    _ticket.Subject ?? string.Empty,
                    _ticket.Status?.Uid);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ErrorHelper.Categorize(ex).Message}", Severity.Error);
        }
        finally { _isLoading = false; StateHasChanged(); }
    }

    private async Task LoadReferenceDataAsync()
    {
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var statusTask = ApiService.GetStatusesAsync();
            var prioTask = ApiService.GetPrioritiesAsync();
            var tagsTask = ApiService.GetTagsAsync();
            var groupsTask = ApiService.GetGroupsAsync();
            await Task.WhenAll(statusTask, prioTask, tagsTask, groupsTask);

            _statuses = JsonHelper.DeserializeWrappedArray<Status>(statusTask.Result, "status", options).ToList();
            foreach (var s in _statuses) s.Name = TrudeskTranslationHelper.TranslateStatus(s.Name);

            using var prioDoc = JsonDocument.Parse(prioTask.Result);
            _priorities = prioDoc.RootElement.TryGetProperty("priorities", out var prioEl)
                ? JsonSerializer.Deserialize<List<Priority>>(prioEl.GetRawText(), options) ?? []
                : JsonSerializer.Deserialize<List<Priority>>(prioTask.Result, options) ?? [];
            foreach (var p in _priorities) p.Name = TrudeskTranslationHelper.TranslatePriority(p.Name);

            _availableTags = JsonHelper.DeserializeWrappedArray<Tag>(tagsTask.Result, "tags", options).ToList();

            var groupResp = JsonSerializer.Deserialize<GetGroupResponse>(groupsTask.Result, options);
            _groups = groupResp?.Groups ?? [];

            try
            {
                var usersJson = await ApiService.GetAssigneesAsync();
                var userResponse = JsonSerializer.Deserialize<GetUserResponse>(usersJson, options);
                _users = userResponse?.Users ?? [];
            }
            catch { _users = []; }

            StateHasChanged();
        }
        catch { /* sidebar functionality degrades but core view works */ }
    }

