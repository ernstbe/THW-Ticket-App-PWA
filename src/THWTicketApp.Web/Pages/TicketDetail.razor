@page "/tickets/{TicketUid:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@using Markdig
@using Microsoft.AspNetCore.Components.Forms
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage
@inject LocalizationService L
@inject THWTicketApp.Web.Services.RealtimeService Realtime
@implements IDisposable

<PageTitle>@(_ticket?.Subject ?? "Ticket") - THW Ticket App</PageTitle>

@if (_isLoading && _ticket == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_ticket == null)
{
    <MudAlert Severity="Severity.Error">@L.T("detail.not_found")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div class="d-flex align-center gap-3">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("tickets"))"
                           aria-label="@L.T("common.back")" />
            <MudText Typo="Typo.h5">#@_ticket.Uid – @_ticket.Subject</MudText>
            <MudIconButton Icon="@(_isFavorite ? Icons.Material.Filled.Star : Icons.Material.Filled.StarOutline)"
                           Color="@(_isFavorite ? Color.Warning : Color.Default)"
                           OnClick="ToggleFavoriteAsync" />
            <MudTooltip Text="@(_isSubscribed ? L.T("detail.unsubscribe") : L.T("detail.subscribe"))">
                <MudIconButton Icon="@(_isSubscribed ? Icons.Material.Filled.NotificationsActive : Icons.Material.Filled.NotificationsNone)"
                               Color="@(_isSubscribed ? Color.Info : Color.Default)"
                               OnClick="ToggleSubscriptionAsync" />
            </MudTooltip>
        </div>
        <div class="d-flex gap-2">
            <StatusBadge Status="@_ticket.Status" />
            <PriorityBadge Priority="@_ticket.Priority" />
        </div>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
    }

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="pa-4">
        @* Details Tab *@
        <MudTabPanel Text="@L.T("detail.details")" Icon="@Icons.Material.Filled.Info">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">@L.T("detail.description")</MudText>
                    <MudPaper Elevation="0" Class="pa-3 mb-4" Style="background: var(--mud-palette-background-gray);">
                        @if (!string.IsNullOrEmpty(_ticket.Issue))
                        {
                            @((MarkupString)Markdown.ToHtml(_ticket.Issue, _mdPipeline))
                        }
                        else
                        {
                            <MudText Color="Color.Secondary">@L.T("detail.no_description")</MudText>
                        }
                    </MudPaper>

                    @* Edit section *@
                    <MudExpansionPanels Class="mb-4">
                        <MudExpansionPanel Text="@L.T("detail.edit")">
                            <MudTextField @bind-Value="_editSubject" Label="@L.T("detail.subject")" Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_editIssue" Label="@L.T("detail.description")" Variant="Variant.Outlined" Lines="4" Class="mb-3" />
                            <MudGrid>
                                <MudItem xs="6">
                                    <MudSelect T="Status" @bind-Value="_selectedStatus" Label="@L.T("detail.status")" Variant="Variant.Outlined"
                                               ToStringFunc="@(s => s?.TranslatedName ?? "")">
                                        @foreach (var s in _statuses)
                                        {
                                            <MudSelectItem Value="s">@s.TranslatedName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudSelect T="Priority" @bind-Value="_selectedPriority" Label="@L.T("detail.priority")" Variant="Variant.Outlined"
                                               ToStringFunc="@(p => p?.TranslatedName ?? "")">
                                        @foreach (var p in _priorities)
                                        {
                                            <MudSelectItem Value="p">@p.TranslatedName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                                       OnClick="SaveEditAsync" Disabled="_isLoading">@L.T("common.save")</MudButton>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.details")</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                <MudText Typo="Typo.caption">@L.T("detail.creator")</MudText>
                                <MudText>@(_ticket.Owner?.Fullname ?? L.T("common.unknown"))</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.AssignmentInd">
                                <MudText Typo="Typo.caption">@L.T("detail.assignee")</MudText>
                                <MudText>@(_ticket.Assignee?.Fullname ?? L.T("detail.unassigned"))</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Group">
                                <MudText Typo="Typo.caption">@L.T("detail.group")</MudText>
                                <MudText>@(_ticket.Group?.Name ?? "-")</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Category">
                                <MudText Typo="Typo.caption">@L.T("detail.type")</MudText>
                                <MudText>@(_ticket.Type?.TranslatedName ?? "-")</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CalendarToday">
                                <MudText Typo="Typo.caption">@L.T("detail.created")</MudText>
                                <MudText>@_ticket.Date.ToString("dd.MM.yyyy HH:mm")</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Update">
                                <MudText Typo="Typo.caption">@L.T("detail.updated")</MudText>
                                <MudText>@_ticket.Updated.ToString("dd.MM.yyyy HH:mm")</MudText>
                            </MudListItem>
                            @if (_ticket.DueDate != DateTime.MinValue)
                            {
                                <MudListItem T="string" Icon="@Icons.Material.Filled.Event">
                                    <MudText Typo="Typo.caption">@L.T("detail.due")</MudText>
                                    <MudText Color="@(_ticket.DueDate < DateTime.Now ? Color.Error : Color.Default)">
                                        @_ticket.DueDate.ToString("dd.MM.yyyy HH:mm")
                                    </MudText>
                                </MudListItem>
                            }
                        </MudList>

                        @* Assignee picker *@
                        <MudDivider Class="my-3" />
                        <MudSelect T="User" @bind-Value="_selectedAssignee" Label="@L.T("detail.assign_to")" Variant="Variant.Outlined"
                                   ToStringFunc="@(u => u?.Fullname ?? "")" Dense="true" Class="mb-2"
                                   Clearable="true">
                            @foreach (var u in _users)
                            {
                                <MudSelectItem Value="u">@u.Fullname</MudSelectItem>
                            }
                        </MudSelect>
                        <div class="d-flex gap-2">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="AssignAsync" Disabled="_isLoading">@L.T("detail.assign")</MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                       OnClick="ClearAssigneeAsync" Disabled="_isLoading">@L.T("detail.remove_assign")</MudButton>
                        </div>

                        @* Tags *@
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.tags")</MudText>
                        <div class="d-flex flex-wrap gap-1 align-center">
                            @if (_ticket.Tags?.Count > 0)
                            {
                                @foreach (var tag in _ticket.Tags)
                                {
                                    var tagId = tag.Id;
                                    <MudChip T="string" Size="Size.Small" OnClose="@(_ => RemoveTagAsync(tagId!))"
                                             Disabled="_isLoading">@tag.Name</MudChip>
                                }
                            }
                            @if (_availableTags.Any(t => !(_ticket.Tags?.Any(tt => tt.Id == t.Id) ?? false)))
                            {
                                <MudMenu Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                         Dense="true" aria-label="@L.T("detail.add_tag")">
                                    @foreach (var tag in _availableTags.Where(t => !(_ticket.Tags?.Any(tt => tt.Id == t.Id) ?? false)))
                                    {
                                        <MudMenuItem OnClick="@(() => AddTagAsync(tag.Id!, tag.Name!))">@tag.Name</MudMenuItem>
                                    }
                                </MudMenu>
                            }
                        </div>

                        @* Linked Tickets *@
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.linked")</MudText>
                        @if (_linkedTickets.Count > 0)
                        {
                            @foreach (var link in _linkedTickets)
                            {
                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@link.LinkType</MudChip>
                                    <MudLink Href="@($"/tickets/{link.Uid}")" Typo="Typo.body2">
                                        #@link.Uid – @link.Subject
                                    </MudLink>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                   OnClick="@(() => RemoveLinkedTicketAsync(link))" />
                                </div>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.no_links")</MudText>
                        }
                        <div class="d-flex gap-2 mt-2">
                            <MudNumericField @bind-Value="_linkTicketUid" Label="@L.T("detail.link_ticket_num")" Variant="Variant.Outlined"
                                             Margin="Margin.Dense" Style="max-width: 100px;" T="int" />
                            <MudSelect @bind-Value="_linkType" Label="@L.T("detail.type")" Variant="Variant.Outlined" Dense="true"
                                       Style="max-width: 130px;" T="string">
                                <MudSelectItem Value="@(L.T("detail.link_related"))">@L.T("detail.link_related")</MudSelectItem>
                                <MudSelectItem Value="@(L.T("detail.link_blocks"))">@L.T("detail.link_blocks")</MudSelectItem>
                                <MudSelectItem Value="@(L.T("detail.link_blocked_by"))">@L.T("detail.link_blocked_by")</MudSelectItem>
                                <MudSelectItem Value="@(L.T("detail.link_duplicate"))">@L.T("detail.link_duplicate")</MudSelectItem>
                            </MudSelect>
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                           OnClick="AddLinkedTicketAsync" />
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Comments Tab *@
        <MudTabPanel Text="@($"{L.T("comments.title")} ({_ticket.Comments?.Count ?? 0})")" Icon="@Icons.Material.Filled.Comment">
            @if (_ticket.Comments != null)
            {
                @foreach (var comment in _ticket.Comments.OrderByDescending(c => c.Date))
                {
                    <MudPaper Elevation="1" Class="pa-3 mb-3">
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.subtitle2">@(comment.Owner?.Fullname ?? L.T("common.unknown"))</MudText>
                            <MudText Typo="Typo.caption">@comment.Date.ToString("dd.MM.yyyy HH:mm")</MudText>
                        </div>
                        @if (!string.IsNullOrEmpty(comment.Text))
                        {
                            @((MarkupString)Markdown.ToHtml(comment.Text, _mdPipeline))
                        }
                    </MudPaper>
                }
            }

            <MudDivider Class="my-4" />

            @* Quick Reply Templates *@
            <div class="d-flex gap-2 mb-2">
                <MudMenu Label="@L.T("comments.quickreply")" Variant="Variant.Outlined" Size="Size.Small"
                         StartIcon="@Icons.Material.Filled.Reply" Dense="true">
                    @foreach (var template in _quickReplyTemplates)
                    {
                        <MudMenuItem OnClick="@(() => InsertQuickReply(template))">@TruncateTemplate(template)</MudMenuItem>
                    }
                    <MudDivider />
                    <MudMenuItem OnClick="OpenQuickReplyEditor">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-1" />
                        @L.T("detail.edit_templates")
                    </MudMenuItem>
                </MudMenu>
                <MudMenu Label="@L.T("comments.mention")" Variant="Variant.Outlined" Size="Size.Small"
                         StartIcon="@Icons.Material.Filled.AlternateEmail" Dense="true">
                    @foreach (var user in _users)
                    {
                        <MudMenuItem OnClick="@(() => InsertMention(user))">@user.Fullname</MudMenuItem>
                    }
                </MudMenu>
            </div>

            @* Quick Reply Editor Dialog *@
            @if (_showQuickReplyEditor)
            {
                <MudPaper Elevation="2" Class="pa-3 mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.quickreply_templates")</MudText>
                    @for (int i = 0; i < _quickReplyTemplates.Count; i++)
                    {
                        var idx = i;
                        <div class="d-flex gap-2 mb-1 align-center">
                            <MudTextField @bind-Value="_quickReplyTemplates[idx]" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" Style="flex: 1;" T="string" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => RemoveQuickReply(idx))" />
                        </div>
                    }
                    <div class="d-flex gap-2 mt-2">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="AddEmptyQuickReply"
                                   StartIcon="@Icons.Material.Filled.Add">@L.T("detail.new_template")</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="SaveQuickRepliesAsync">@L.T("common.save")</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick="@(() => _showQuickReplyEditor = false)">@L.T("common.close")</MudButton>
                    </div>
                </MudPaper>
            }

            <MudTextField @bind-Value="_newComment" Label="@L.T("comments.new")" Variant="Variant.Outlined"
                          Lines="3" Class="mb-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddCommentAsync"
                       Disabled="@(string.IsNullOrWhiteSpace(_newComment) || _isLoading)">
                @L.T("comments.send")
            </MudButton>
        </MudTabPanel>

        @* Notes Tab *@
        <MudTabPanel Text="@($"{L.T("notes.title")} ({_ticket.Notes?.Count ?? 0})")" Icon="@Icons.Material.Filled.Note">
            @if (_ticket.Notes != null)
            {
                @foreach (var note in _ticket.Notes.OrderByDescending(n => n.Date))
                {
                    <MudPaper Elevation="1" Class="pa-3 mb-3">
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.subtitle2">@(note.Owner?.Fullname ?? L.T("common.unknown"))</MudText>
                            <MudText Typo="Typo.caption">@note.Date.ToString("dd.MM.yyyy HH:mm")</MudText>
                        </div>
                        @if (!string.IsNullOrEmpty(note.Content))
                        {
                            @((MarkupString)Markdown.ToHtml(note.Content, _mdPipeline))
                        }
                    </MudPaper>
                }
            }

            <MudDivider Class="my-4" />
            <MudTextField @bind-Value="_newNote" Label="@L.T("notes.new")" Variant="Variant.Outlined"
                          Lines="3" Class="mb-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddNoteAsync"
                       Disabled="@(string.IsNullOrWhiteSpace(_newNote) || _isLoading)">
                @L.T("notes.add")
            </MudButton>
        </MudTabPanel>

        @* Attachments Tab *@
        <MudTabPanel Text="@($"{L.T("attachments.title")} ({_ticket.Attachments?.Count ?? 0})")" Icon="@Icons.Material.Filled.AttachFile">
            @if (_ticket.Attachments != null && _ticket.Attachments.Count > 0)
            {
                <MudTable Items="_ticket.Attachments" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>@L.T("attachments.name")</MudTh>
                        <MudTh>@L.T("attachments.type")</MudTh>
                        <MudTh>@L.T("attachments.size")</MudTh>
                        <MudTh>@L.T("attachments.date")</MudTh>
                        <MudTh>@L.T("attachments.actions")</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>@context.MimeType</MudTd>
                        <MudTd>@context.SizeFormatted</MudTd>
                        <MudTd>@(context.UploadDate?.ToString("dd.MM.yyyy") ?? "-")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                           OnClick="() => DownloadAttachment(context)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="() => DeleteAttachmentAsync(context)" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText Color="Color.Secondary">@L.T("attachments.none")</MudText>
            }

            <MudDivider Class="my-4" />
            <div class="d-flex gap-2 align-center">
                <InputFile id="attachment-upload" OnChange="OnFileSelectedAsync" hidden
                           accept=".pdf,.png,.jpg,.jpeg,.gif,.doc,.docx,.xls,.xlsx,.txt,.zip" />
                <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudUpload" for="attachment-upload"
                           Disabled="_isUploading">
                    @(_isUploading ? L.T("attachments.uploading") : L.T("attachments.upload"))
                </MudButton>
                @if (_isUploading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
            </div>
        </MudTabPanel>

        @* Time Tracking Tab *@
        <MudTabPanel Text="@L.T("time.title")" Icon="@Icons.Material.Filled.Timer">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.h6" Class="mb-3">@L.T("time.timer")</MudText>
                        <MudText Typo="Typo.h3" Class="mb-3" Style="font-family: monospace; font-weight: 600;"
                                 Color="@(_timerRunning ? Color.Primary : Color.Default)">
                            @FormatElapsed(_timerElapsed)
                        </MudText>
                        <div class="d-flex gap-2 mb-4">
                            @if (!_timerRunning)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="StartTimer">
                                    @L.T("time.start")
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Stop" OnClick="StopTimer">
                                    @L.T("time.stop")
                                </MudButton>
                            }
                        </div>
                        <MudTextField @bind-Value="_timeEntryDescription" Label="@L.T("time.description")"
                                      Variant="Variant.Outlined" />
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.h6" Class="mb-3">@L.T("time.total"): @FormatMinutes(_totalTimeMinutes)</MudText>
                        @if (_timeEntries.Count > 0)
                        {
                            <MudSimpleTable Dense="true">
                                <thead>
                                    <tr>
                                        <th>@L.T("time.col_start")</th>
                                        <th>@L.T("time.col_duration")</th>
                                        <th>@L.T("time.col_description")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in _timeEntries.OrderByDescending(e => e.Start))
                                    {
                                        <tr>
                                            <td>@entry.Start.ToString("dd.MM HH:mm")</td>
                                            <td>@FormatMinutes(entry.DurationMinutes)</td>
                                            <td>@(entry.Description ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudText Color="Color.Secondary">@L.T("time.no_entries")</MudText>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* History Tab *@
        <MudTabPanel Text="@($"{L.T("history.title")} ({_ticket.History?.Count ?? 0})")" Icon="@Icons.Material.Filled.History">
            @if (_ticket.History != null)
            {
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var item in _ticket.History.OrderByDescending(h => h.Date))
                    {
                        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                            <ItemContent>
                                <MudText Typo="Typo.subtitle2">@item.TranslatedAction</MudText>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <MudText Typo="Typo.body2">@item.Description</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @item.Date.ToString("dd.MM.yyyy HH:mm") – @(item.Owner?.Fullname ?? "System")
                                </MudText>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
        </MudTabPanel>
    </MudTabs>

    @* Delete button *@
    <div class="d-flex justify-end mt-4">
        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="DeleteTicketAsync">
            @L.T("detail.delete_ticket")
        </MudButton>
    </div>
}

@code {
    [Parameter] public int TicketUid { get; set; }

    private Ticket? _ticket;
    private bool _isLoading;
    private string _newComment = string.Empty;
    private string _newNote = string.Empty;
    private string _editSubject = string.Empty;
    private string _editIssue = string.Empty;
    private Status? _selectedStatus;
    private Priority? _selectedPriority;
    private User? _selectedAssignee;
    private List<Status> _statuses = [];
    private List<Priority> _priorities = [];
    private List<User> _users = [];
    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    // Tags
    private List<Tag> _availableTags = [];

    // Subscription
    private bool _isSubscribed;

    // Attachment upload
    private bool _isUploading;

    // Quick reply templates
    private List<string> _quickReplyTemplates = new();
    private bool _showQuickReplyEditor;

    // Favorites & Linked Tickets
    private bool _isFavorite;
    private List<LinkedTicketItem> _linkedTickets = [];
    private int _linkTicketUid;
    private string _linkType = "";

    // Time tracking
    private bool _timerRunning;
    private DateTime _timerStart;
    private TimeSpan _timerElapsed;
    private string _timeEntryDescription = string.Empty;
    private List<TimeEntryItem> _timeEntries = [];
    private int _totalTimeMinutes;
    private System.Threading.Timer? _timer;

    private CancellationTokenSource? _refreshDebounceCts;

    protected override async Task OnInitializedAsync()
    {
        _linkType = L.T("detail.link_related");
        await LoadTicketAsync();
        _ = LoadReferenceDataAsync();
        await LoadFavoriteStateAsync();
        await LoadLinkedTicketsAsync();
        await LoadTimeEntriesAsync();
        await LoadQuickRepliesAsync();
        await LoadSubscriptionStateAsync();
        Realtime.AnyTicketChanged += OnRealtimeChange;
    }

    private void OnRealtimeChange(string ticketId)
    {
        if (string.IsNullOrEmpty(ticketId) || _ticket?.Id != ticketId) return;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts = new CancellationTokenSource();
        var token = _refreshDebounceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                if (token.IsCancellationRequested) return;
                await LoadTicketAsync();
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task LoadTicketAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var json = await ApiService.GetTicketAsync(TicketUid.ToString());
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("ticket", out var ticketEl))
                _ticket = JsonSerializer.Deserialize<Ticket>(ticketEl.GetRawText(), options);
            else
                _ticket = JsonSerializer.Deserialize<Ticket>(json, options);

            if (_ticket != null)
            {
                TrudeskTranslationHelper.TranslateTicket(_ticket);
                _editSubject = _ticket.Subject ?? string.Empty;
                _editIssue = _ticket.Issue ?? string.Empty;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ErrorHelper.Categorize(ex).Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadReferenceDataAsync()
    {
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var statusTask = ApiService.GetStatusesAsync();
            var prioTask = ApiService.GetPrioritiesAsync();
            var usersTask = ApiService.GetAssigneesAsync();
            var tagsTask = ApiService.GetTagsAsync();
            await Task.WhenAll(statusTask, prioTask, usersTask, tagsTask);

            _statuses = JsonHelper.DeserializeWrappedArray<Status>(statusTask.Result, "status", options).ToList();
            foreach (var s in _statuses) s.Name = TrudeskTranslationHelper.TranslateStatus(s.Name);

            using var prioDoc = JsonDocument.Parse(prioTask.Result);
            if (prioDoc.RootElement.TryGetProperty("priorities", out var prioEl))
                _priorities = JsonSerializer.Deserialize<List<Priority>>(prioEl.GetRawText(), options) ?? [];
            else
                _priorities = JsonSerializer.Deserialize<List<Priority>>(prioTask.Result, options) ?? [];
            foreach (var p in _priorities) p.Name = TrudeskTranslationHelper.TranslatePriority(p.Name);

            var userResponse = JsonSerializer.Deserialize<GetUserResponse>(usersTask.Result, options);
            _users = userResponse?.Users ?? [];

            _availableTags = JsonHelper.DeserializeWrappedArray<Tag>(tagsTask.Result, "tags", options).ToList();

            if (_ticket != null)
            {
                _selectedStatus = _statuses.FirstOrDefault(s => s.Id == _ticket.Status?.Id);
                _selectedPriority = _priorities.FirstOrDefault(p => p.Id == _ticket.Priority?.Id);
            }
            StateHasChanged();
        }
        catch { }
    }

