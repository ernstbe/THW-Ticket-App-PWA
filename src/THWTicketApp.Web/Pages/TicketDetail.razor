    private async Task OnDueDateChangedAsync(DateTime? newDate)
    {
        if (_ticket == null) return;
        // Treat "no change" as a no-op so a re-render that pushes the same
        // value through the picker doesn't ping the API every time.
        var current = _ticket.DueDate == DateTime.MinValue ? (DateTime?)null : _ticket.DueDate.Date;
        if (current == newDate?.Date) return;

        _dueDateLocal = newDate;
        _ticket.DueDate = newDate ?? DateTime.MinValue;
        try
