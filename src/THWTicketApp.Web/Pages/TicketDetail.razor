    // Linked Tickets
    private async Task LoadLinkedTicketsAsync()
    {
        try
        {
            var json = await LocalStorage.GetItemAsync($"linked_tickets_{TicketUid}");
            if (!string.IsNullOrEmpty(json))
                _linkedTickets = System.Text.Json.JsonSerializer.Deserialize<List<LinkedTicketItem>>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
        }
        catch { }
    }

    private async Task AddLinkedTicketAsync()
    {
        if (_linkTicketUid <= 0 || _linkTicketUid == TicketUid) return;

        if (_linkedTickets.Any(l => l.Uid == _linkTicketUid)) return;

        // Try to fetch the linked ticket's subject
        string subject = $"Ticket #{_linkTicketUid}";
        try
        {
            var json = await ApiService.GetTicketAsync(_linkTicketUid.ToString());
            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("ticket", out var tEl))
            {
                var t = System.Text.Json.JsonSerializer.Deserialize<Ticket>(tEl.GetRawText(), options);
                if (t?.Subject != null) subject = t.Subject;
            }
        }
        catch { }

        _linkedTickets.Add(new LinkedTicketItem { Uid = _linkTicketUid, Subject = subject, LinkType = _linkType });
        await SaveLinkedTicketsAsync();
        _linkTicketUid = 0;
    }

    private async Task RemoveLinkedTicketAsync(LinkedTicketItem link)
    {
        _linkedTickets.Remove(link);
        await SaveLinkedTicketsAsync();
    }

    private async Task SaveLinkedTicketsAsync()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_linkedTickets);
        await LocalStorage.SetItemAsync($"linked_tickets_{TicketUid}", json);
    }

    // Subscription
    private async Task LoadSubscriptionStateAsync()
    {
        var subJson = await LocalStorage.GetItemAsync("subscribed_tickets") ?? "[]";
        var subs = System.Text.Json.JsonSerializer.Deserialize<List<int>>(subJson) ?? [];
        _isSubscribed = subs.Contains(TicketUid);
    }

    private async Task ToggleSubscriptionAsync()
    {
        if (_ticket == null) return;
        try
        {
            var success = await ApiService.SubscribeToTicketAsync(_ticket.Id, !_isSubscribed);
            if (success)
            {
                _isSubscribed = !_isSubscribed;
                // Track locally
                var subJson = await LocalStorage.GetItemAsync("subscribed_tickets") ?? "[]";
                var subs = System.Text.Json.JsonSerializer.Deserialize<List<int>>(subJson) ?? [];
                if (_isSubscribed) { if (!subs.Contains(TicketUid)) subs.Add(TicketUid); }
                else subs.Remove(TicketUid);
                await LocalStorage.SetItemAsync("subscribed_tickets", System.Text.Json.JsonSerializer.Serialize(subs));
                Snackbar.Add(_isSubscribed ? L.T("detail.subscribed") : L.T("detail.unsubscribed"), Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
    }

    // Attachment upload
    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        if (_ticket == null) return;
        _isUploading = true;
        StateHasChanged();
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50MB max
            if (await ApiService.UploadAttachmentAsync(_ticket.Id, stream, file.Name))
            {
                Snackbar.Add(L.T("attachments.uploaded"), Severity.Success);
                await LoadTicketAsync();
            }
            else
            {
                Snackbar.Add(L.T("common.error"), Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isUploading = false; StateHasChanged(); }
    }

