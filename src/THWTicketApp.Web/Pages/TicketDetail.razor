@page "/tickets/{TicketUid:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@using Markdig
@using Microsoft.AspNetCore.Components.Forms
@using QRCoder
@using System.Net.Http
@inject ITrueDeskApiService ApiService
@inject ILookupService Lookup
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage
@inject LocalizationService L
@inject THWTicketApp.Web.Services.RealtimeService Realtime
@inject IJSRuntime JsRuntime
@inject THWTicketApp.Web.Services.RecentTicketsService RecentTickets
@inject IDialogService DialogService
@inject ISyncService SyncService
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject THWTicketApp.Web.Services.NavigationHistoryService NavHistory
@implements IAsyncDisposable

<PageTitle>@(_ticket?.Subject ?? "Ticket") - THW Ticket App</PageTitle>

@if (_isLoading && _ticket == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_ticket == null)
{
    <MudAlert Severity="Severity.Error">@L.T("detail.not_found")</MudAlert>
}
else
{
    @* ─── Header ───────────────────────────────────────────────────────── *@
    @* flex-wrap auf mobile, sonst sprengen die sieben Icon-Buttons den
       Viewport und es erscheint eine horizontale Scrollbar. Title hat
       flex:1, behält also Vorrang und schiebt die Aktion-Icons bei Bedarf
       auf eine zweite Zeile. *@
    <div class="d-flex flex-wrap align-center gap-2 mb-2 pwa-no-print">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo(NavHistory.LastListUri))"
                       aria-label="@L.T("common.back")" />
        <MudText Typo="Typo.caption" Color="Color.Secondary">#@_ticket.Uid</MudText>
        @if (_editingTitle)
        {
            <MudTextField @bind-Value="_editSubject" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Immediate="true" Style="flex:1;"
                          OnKeyDown="@(async (e) => { if (e.Key == "Enter") await SaveTitleAsync(); else if (e.Key == "Escape") await CancelTitleEdit(); })" />
            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                           OnClick="SaveTitleAsync" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="CancelTitleEdit" />
        }
        else
        {
            @* On phones the title gets its own row (flex-basis 100%) so it
               isn't squeezed between back-arrow/#uid and the trailing icons.
               See `.pwa-detail-title` in app.css. *@
            <MudText Typo="Typo.h5" Class="pwa-detail-title"
                     Style="flex:1; cursor:text;" @onclick="StartTitleEdit"
                     title="@L.T("detail.click_to_edit")">@_ticket.Subject</MudText>
        }
        <MudIconButton Icon="@(_isFavorite ? Icons.Material.Filled.Star : Icons.Material.Filled.StarOutline)"
                       Color="@(_isFavorite ? Color.Warning : Color.Default)"
                       OnClick="ToggleFavoriteAsync"
                       aria-label="@L.T("detail.favorite")" />
        <MudTooltip Text="@(_isSubscribed ? L.T("detail.unsubscribe") : L.T("detail.subscribe"))">
            <MudIconButton Icon="@(_isSubscribed ? Icons.Material.Filled.NotificationsActive : Icons.Material.Filled.NotificationsNone)"
                           Color="@(_isSubscribed ? Color.Info : Color.Default)"
                           OnClick="ToggleSubscriptionAsync" />
        </MudTooltip>
        <MudTooltip Text="@L.T("detail.show_qr")">
            <MudIconButton Icon="@Icons.Material.Filled.QrCode2" OnClick="ShowQrCodeAsync"
                           aria-label="@L.T("detail.show_qr")" />
        </MudTooltip>
        <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Print" OnClick="PrintAsync">@L.T("detail.print")</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.QrCode" OnClick="PrintQrCodeAsync">@L.T("detail.print_qr")</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="DeleteTicketAsync">
                <MudText Color="Color.Error">@L.T("detail.delete_ticket")</MudText>
            </MudMenuItem>
        </MudMenu>
    </div>

    @* ─── Chips bar — inline status/priority/group/assignee changes ───── *@
    <div class="d-flex align-center gap-2 mb-4 pwa-no-print flex-wrap">
        <ChipWithMenu T="Status"
                      Label="@_ticket.Status?.TranslatedName"
                      Icon="@Icons.Material.Filled.Circle"
                      BackgroundColor="@_ticket.Status?.HtmlColor"
                      Items="@AllowedStatusesForCurrentType()"
                      ItemTitle="@(s => s.TranslatedName ?? "")"
                      OnSelected="QuickChangeStatusAsync" />
        <ChipWithMenu T="Priority"
                      Label="@_ticket.Priority?.TranslatedName"
                      Icon="@Icons.Material.Filled.Flag"
                      BackgroundColor="@_ticket.Priority?.HtmlColor"
                      Items="_priorities"
                      ItemTitle="@(p => p.TranslatedName ?? "")"
                      OnSelected="QuickChangePriorityAsync" />
        @* Type chip — lets the user fix a wrong type chosen at create time. *@
        <ChipWithMenu T="TicketType"
                      Label="@_ticket.Type?.TranslatedName"
                      Icon="@Icons.Material.Filled.Category"
                      Items="_ticketTypes"
                      ItemTitle="@(t => t.TranslatedName ?? "")"
                      OnSelected="QuickChangeTypeAsync" />
        <ChipWithMenu T="Group"
                      Label="@_ticket.Group?.Name"
                      EmptyLabel="@L.T("detail.no_group")"
                      Icon="@Icons.Material.Filled.Group"
                      Items="_groups"
                      ItemTitle="@(g => g.Name ?? "")"
                      OnSelected="QuickChangeGroupAsync" />
        <ChipWithMenu T="User"
                      Label="@_ticket.Assignee?.Fullname"
                      EmptyLabel="@L.T("detail.unassigned")"
                      Icon="@Icons.Material.Filled.AssignmentInd"
                      Items="_users"
                      ItemTitle="@(u => u.Fullname ?? "")"
                      OnSelected="QuickAssignAsync"
                      OnClear="ClearAssigneeAsync"
                      ClearLabel="@L.T("detail.remove_assign")"
                      EmptyMenuLabel="@L.T("detail.no_assignees_available")" />
        @* Due date — chip with the same look as Status/Priority/Group/
           Assignee. Click opens a MudDialog that contains a static
           MudDatePicker, which gives us reliable backdrop-tap-to-close
           on mobile (the previous off-screen MudDatePicker + ActivatorContent
           pattern did not dismiss when tapping outside on phones). *@
        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                 Color="@DueDateChipColor(_dueDateLocal)"
                 Icon="@Icons.Material.Filled.Event"
                 Style="cursor:pointer;"
                 OnClick="@OpenDuePickerAsync">
            @if (_dueDateLocal.HasValue)
            {
                @_dueDateLocal.Value.ToString("dd.MM.yyyy")
            }
            else
            {
                <em style="opacity:0.7;">@L.T("detail.no_due")</em>
            }
        </MudChip>
    </div>

    @* ─── Weitere Zuständige — additional assignees besides the primary ─ *@
    <div class="d-flex align-center gap-2 mb-4 pwa-no-print flex-wrap">
        <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.additional_assignees"):</MudText>
        @foreach (var assignee in _ticket.AdditionalAssignees)
        {
            var local = assignee;
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Icon="@Icons.Material.Filled.Person"
                     OnClose="@(() => RemoveAdditionalAssigneeAsync(local))">
                @local.Fullname
            </MudChip>
        }
        <ChipWithMenu T="User"
                      EmptyLabel="@L.T("detail.additional_assignees_add")"
                      Icon="@Icons.Material.Filled.PersonAdd"
                      Items="@AvailableAdditionalAssignees()"
                      ItemTitle="@(u => u.Fullname ?? "")"
                      OnSelected="AddAdditionalAssigneeAsync"
                      EmptyMenuLabel="@L.T("detail.no_assignees_available")" />
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
    }

    @* ─── Print-only summary (revealed by @media print in app.css) ───── *@
    <div class="pwa-print-only">
        <h1>THW Ticket #@_ticket.Uid</h1>
        <h2>@_ticket.Subject</h2>
        <table>
            <tr><th>Status</th><td>@(_ticket.Status?.TranslatedName ?? "-")</td></tr>
            <tr><th>Priorität</th><td>@(_ticket.Priority?.TranslatedName ?? "-")</td></tr>
            <tr><th>Ersteller</th><td>@(_ticket.Owner?.Fullname ?? "-")</td></tr>
            <tr><th>Zuständig</th><td>@(_ticket.Assignee?.Fullname ?? "Nicht zugewiesen")</td></tr>
            @if (_ticket.AdditionalAssignees.Count > 0)
            {
                <tr><th>Weitere Zuständige</th><td>@string.Join(", ", _ticket.AdditionalAssignees.Select(a => a.Fullname))</td></tr>
            }
            <tr><th>Gruppe</th><td>@(_ticket.Group?.Name ?? "-")</td></tr>
            <tr><th>Typ</th><td>@(_ticket.Type?.TranslatedName ?? "-")</td></tr>
            <tr><th>Erstellt</th><td>@_ticket.Date.ToLocalDisplayString("dd.MM.yyyy HH:mm")</td></tr>
            <tr><th>Aktualisiert</th><td>@_ticket.LastActivityAt.ToLocalDisplayString("dd.MM.yyyy HH:mm")</td></tr>
            @if (_ticket.DueDate != DateTime.MinValue)
            {
                <tr><th>Fällig</th><td>@_ticket.DueDate.ToLocalDisplayString("dd.MM.yyyy")</td></tr>
            }
        </table>
        <h3>Beschreibung</h3>
        <div>
            @if (!string.IsNullOrEmpty(_ticket.Issue))
            {
                @RenderMarkdown(_ticket.Issue)
            }
            else { <em>Keine Beschreibung.</em> }
        </div>
        @if (_ticket.Comments?.Count > 0)
        {
            <h3>Kommentare (@_ticket.Comments.Count)</h3>
            @foreach (var c in _ticket.Comments.OrderBy(c => c.Date))
            {
                <div style="margin-bottom:1em;">
                    <strong>@(c.Owner?.Fullname ?? "?")</strong>
                    <span>— @c.Date.ToLocalDisplayString("dd.MM.yyyy HH:mm")</span>
                    <div>@((MarkupString)SafeHtml.Sanitize(Markdown.ToHtml(c.Text ?? string.Empty, _mdPipeline)))</div>
                </div>
            }
        }
        @if (_ticket.Notes?.Count > 0)
        {
            <h3>Notizen (@_ticket.Notes.Count)</h3>
            @foreach (var n in _ticket.Notes.OrderBy(n => n.Date))
            {
                <div style="margin-bottom:1em;">
                    <strong>@(n.Owner?.Fullname ?? "?")</strong>
                    <span>— @n.Date.ToLocalDisplayString("dd.MM.yyyy HH:mm")</span>
                    <div>@((MarkupString)SafeHtml.Sanitize(Markdown.ToHtml(n.Content ?? string.Empty, _mdPipeline)))</div>
                </div>
            }
        }
        <p style="margin-top:2em; font-size:10px; color:#666;">
            Gedruckt am @DateTime.Now.ToString("dd.MM.yyyy HH:mm") — THW Ticket App
        </p>
    </div>

    @* ─── Main layout: left = description+feed+composer, right = sidebar ─ *@
    <MudGrid Class="pwa-no-print">
        <MudItem xs="12" md="8">
            @* Description (click to edit) *@
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle2">@L.T("detail.description")</MudText>
                    @if (!_editingDescription)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="StartDescriptionEdit"
                                       aria-label="@L.T("common.edit")" />
                    }
                </div>
                @if (_editingDescription)
                {
                    <MarkdownToolbar TextAreaId="description-editor" />
                    <MudTextField @bind-Value="_editIssue" Variant="Variant.Outlined" Lines="6"
                                  Immediate="true" Class="mb-2" InputId="description-editor" />
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="SaveDescriptionAsync" Disabled="_isLoading">
                            @L.T("common.save")
                        </MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                   OnClick="CancelDescriptionEdit">
                            @L.T("common.cancel")
                        </MudButton>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(_ticket.Issue))
                    {
                        @RenderMarkdown(_ticket.Issue)
                    }
                    else
                    {
                        <MudText Color="Color.Secondary"><em>@L.T("detail.no_description")</em></MudText>
                    }
                }
            </MudPaper>

            @* Comments + Notes feed — prominent, with a toggle icon that
               reveals the composer below. History was previously merged in
               here but moved into a collapsed expansion panel at the bottom
               of this column so the conversation stays visible. *@
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.h6">@L.T("detail.activity_comments_notes")</MudText>
                <MudTooltip Text="@L.T(_composerOpen ? "detail.composer_close" : "detail.composer_open")">
                    <MudIconButton Icon="@(_composerOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.AddComment)"
                                   Color="@(_composerOpen ? Color.Default : Color.Primary)"
                                   OnClick="@(() => _composerOpen = !_composerOpen)"
                                   aria-label="@L.T(_composerOpen ? "detail.composer_close" : "detail.composer_open")" />
                </MudTooltip>
            </div>
            <TicketActivityFeed Ticket="_ticket"
                                Kinds="@(new[] { TicketActivityFeed.ActivityKind.Comment, TicketActivityFeed.ActivityKind.Note })" />

            @* Composer — hidden behind the toggle icon above so it doesn't
               crowd the conversation by default. Reported via in-app bug
               from b.ernst (2026-05-19): composer was always-on, too loud. *@
            @if (_composerOpen)
            {
            <MudPaper Elevation="2" Class="pa-3 mt-4">
                <MudTabs Elevation="0" Rounded="false" Border="false"
                         ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_composerTab">
                    <MudTabPanel Text="@L.T("detail.composer_comment")" Icon="@Icons.Material.Filled.Comment">
                        @* Quick replies + mentions *@
                        <div class="d-flex gap-2 mb-2 flex-wrap">
                            <MudMenu Label="@L.T("comments.quickreply")" Variant="Variant.Outlined" Size="Size.Small"
                                     StartIcon="@Icons.Material.Filled.Reply" Dense="true">
                                @foreach (var template in _quickReplyTemplates)
                                {
                                    <MudMenuItem OnClick="@(() => InsertQuickReply(template))">@TruncateTemplate(template)</MudMenuItem>
                                }
                                <MudDivider />
                                <MudMenuItem OnClick="OpenQuickReplyEditor">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-1" />
                                    @L.T("detail.edit_templates")
                                </MudMenuItem>
                            </MudMenu>
                            @if (_users.Any())
                            {
                                <MudMenu Label="@L.T("comments.mention")" Variant="Variant.Outlined" Size="Size.Small"
                                         StartIcon="@Icons.Material.Filled.AlternateEmail" Dense="true">
                                    @foreach (var user in _users)
                                    {
                                        <MudMenuItem OnClick="@(() => InsertMention(user))">@user.Fullname</MudMenuItem>
                                    }
                                </MudMenu>
                            }
                            <MudToggleIconButton Toggled="@_commentPreview"
                                                 ToggledChanged="@((bool v) => _commentPreview = v)"
                                                 Icon="@Icons.Material.Filled.Edit"
                                                 ToggledIcon="@Icons.Material.Filled.Visibility"
                                                 Size="Size.Small"
                                                 title="@L.T("comments.preview_toggle")" />
                        </div>
                        @if (_showQuickReplyEditor)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background: var(--mud-palette-background-gray);">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.quickreply_templates")</MudText>
                                @for (int i = 0; i < _quickReplyTemplates.Count; i++)
                                {
                                    var idx = i;
                                    <div class="d-flex gap-2 mb-1 align-center">
                                        <MudTextField @bind-Value="_quickReplyTemplates[idx]" Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" Style="flex: 1;" T="string" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error" OnClick="@(() => RemoveQuickReply(idx))" />
                                    </div>
                                }
                                <div class="d-flex gap-2 mt-2">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="AddEmptyQuickReply"
                                               StartIcon="@Icons.Material.Filled.Add">@L.T("detail.new_template")</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                               OnClick="SaveQuickRepliesAsync">@L.T("common.save")</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Text"
                                               OnClick="@(() => _showQuickReplyEditor = false)">@L.T("common.close")</MudButton>
                                </div>
                            </MudPaper>
                        }
                        @if (_commentPreview)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mb-3"
                                      Style="background: var(--mud-palette-background-gray); min-height: 80px;">
                                @if (string.IsNullOrWhiteSpace(_newComment))
                                {
                                    <MudText Color="Color.Secondary"><em>@L.T("comments.preview_empty")</em></MudText>
                                }
                                else
                                {
                                    @((MarkupString)SafeHtml.Sanitize(Markdown.ToHtml(_newComment, _mdPipeline)))
                                }
                            </MudPaper>
                        }
                        else
                        {
                            <MarkdownToolbar TextAreaId="comment-editor" />
                            <MudTextField @bind-Value="_newComment" Placeholder="@L.T("comments.new")"
                                          Variant="Variant.Outlined" Lines="3" Class="mb-2"
                                          InputId="comment-editor" />
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="false"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   OnClick="AddCommentAsync"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newComment) || _isLoading)">
                            @L.T("comments.send")
                        </MudButton>
                    </MudTabPanel>
                    <MudTabPanel Text="@L.T("detail.composer_note")" Icon="@Icons.Material.Filled.Note">
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            @L.T("detail.note_visible_internal")
                        </MudAlert>
                        <MarkdownToolbar TextAreaId="note-editor" />
                        <MudTextField @bind-Value="_newNote" Placeholder="@L.T("notes.new")"
                                      Variant="Variant.Outlined" Lines="3" Class="mb-2"
                                      InputId="note-editor" />
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.NoteAdd"
                                   OnClick="AddNoteAsync"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newNote) || _isLoading)">
                            @L.T("notes.add")
                        </MudButton>
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
            }

        </MudItem>

        @* ─── Sidebar — order on user request (2026-05-19):
               Tags → Checklisten (collapsed) → Details (collapsed).
               History moves OUT of this grid to a full-width panel after
               the grid so it truly lands at the end of the ticket. ───── *@
        <MudItem xs="12" md="4">
            @* Tags — collapsible like the other bottom-of-ticket panels.
               The current tag count stays visible in the header so users
               see how many are set without expanding. *@
            <MudExpansionPanels Elevation="1" Class="mb-3">
                <MudExpansionPanel>
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2">@L.T("detail.tags")</MudText>
                            @if ((_ticket.Tags?.Count ?? 0) > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    (@_ticket.Tags!.Count)
                                </MudText>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="d-flex flex-wrap gap-1 align-center">
                            @if (_ticket.Tags?.Count > 0)
                            {
                                @foreach (var tag in _ticket.Tags)
                                {
                                    var tagId = tag.Id;
                                    <MudChip T="string" Size="Size.Small" OnClose="@(_ => RemoveTagAsync(tagId!))"
                                             Disabled="_isLoading">@tag.Name</MudChip>
                                }
                            }
                            @if (_availableTags.Any(t => !(_ticket.Tags?.Any(tt => tt.Id == t.Id) ?? false)))
                            {
                                <MudMenu Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                         Dense="true" aria-label="@L.T("detail.add_tag")">
                                    @foreach (var tag in _availableTags.Where(t => !(_ticket.Tags?.Any(tt => tt.Id == t.Id) ?? false)))
                                    {
                                        <MudMenuItem OnClick="@(() => AddTagAsync(tag.Id!, tag.Name!))">@tag.Name</MudMenuItem>
                                    }
                                </MudMenu>
                            }
                            @if ((_ticket.Tags?.Count ?? 0) == 0 && !_availableTags.Any())
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>

            @* Checklist — collapsed behind the expansion arrow on user
               request. Header keeps the progress count visible so users
               can see "3/5 done" without expanding the panel. *@
            <MudExpansionPanels Elevation="1" Class="mb-3">
                <MudExpansionPanel>
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.CheckBox" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2">@L.T("checklist.title")</MudText>
                            @if (_ticket.Checklist?.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    (@(_ticket.Checklist.Count(c => c.Completed))/@_ticket.Checklist.Count)
                                </MudText>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        @if (_ticket.Checklist?.Count > 0)
                        {
                            <div class="d-flex flex-column gap-1 mb-2">
                                @foreach (var item in _ticket.Checklist)
                                {
                                    var itemRef = item;
                                    <div class="d-flex align-center gap-2">
                                        <MudCheckBox T="bool" Value="@itemRef.Completed" Dense="true"
                                                     ValueChanged="@(v => ToggleChecklistItemAsync(itemRef.Id!, v))"
                                                     Disabled="_isLoading" />
                                        <MudText Typo="Typo.body2"
                                                 Style="@(itemRef.Completed ? "text-decoration: line-through; opacity: 0.6; flex:1;" : "flex:1;")">
                                            @itemRef.Title
                                        </MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                       OnClick="@(() => DeleteChecklistItemAsync(itemRef.Id!))"
                                                       Disabled="_isLoading"
                                                       aria-label="@L.T("common.delete")" />
                                    </div>
                                }
                            </div>
                        }
                        <div class="d-flex gap-1">
                            <MudTextField @bind-Value="_newChecklistTitle" Placeholder="@L.T("checklist.new_item")"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1"
                                          OnKeyDown="@(async (e) => { if (e.Key == "Enter") await AddChecklistItemAsync(); })" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                           OnClick="AddChecklistItemAsync"
                                           Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_newChecklistTitle))" />
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>

            @* Details — collapsed by default; sits directly above the
               full-width History panel that follows after </MudGrid>. *@
            <MudExpansionPanels Elevation="1" Class="mb-3">
                <MudExpansionPanel>
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2">@L.T("detail.details")</MudText>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="d-flex flex-column gap-1">
                            <div class="d-flex align-center gap-2">
                                <UserAvatar Name="@_ticket.Owner?.Fullname" Size="Size.Small" />
                                <div style="flex:1;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.creator")</MudText>
                                    <MudText Typo="Typo.body2">@(_ticket.Owner?.Fullname ?? L.T("common.unknown"))</MudText>
                                </div>
                            </div>
                            <MudDivider Class="my-2" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.type")</MudText>
                                <MudText Typo="Typo.body2">@(_ticket.Type?.TranslatedName ?? "-")</MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.created")</MudText>
                                <MudText Typo="Typo.body2">@_ticket.Date.ToLocalDisplayString("dd.MM.yyyy HH:mm")</MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.updated")</MudText>
                                <MudText Typo="Typo.body2">@_ticket.LastActivityAt.ToLocalDisplayString("dd.MM.yyyy HH:mm")</MudText>
                            </div>
                            @if (_ticket.DueDate != DateTime.MinValue)
                            {
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("detail.due")</MudText>
                                    <MudText Typo="Typo.body2" Color="@(TicketDueDateHelper.IsOverdue(_ticket.DueDate) ? Color.Error : Color.Default)">
                                        @_ticket.DueDate.ToLocalDisplayString("dd.MM.yyyy HH:mm")
                                    </MudText>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>

            @* Attachments — Bilder als Thumbnail-Grid, sonstige Dateien als Liste.
               Foto-Aufnahme nutzt `capture="environment"` (Smartphone öffnet die
               Rück-Kamera direkt; Desktop ignoriert das Attribut). *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    @L.T("attachments.title")
                    @if (_ticket.Attachments?.Count > 0)
                    {
                        <span style="font-weight:normal; opacity:0.7;">(@_ticket.Attachments.Count)</span>
                    }
                </MudText>

                @if (_ticket.Attachments != null && _ticket.Attachments.Count > 0)
                {
                    var images = _ticket.Attachments.Where(a => a.IsImage).ToList();
                    var docs = _ticket.Attachments.Where(a => !a.IsImage).ToList();

                    @if (images.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            @foreach (var img in images)
                            {
                                var a = img;
                                var url = ApiService.GetAttachmentUrl(a.Path ?? string.Empty);
                                <div style="position:relative; width:96px; height:96px;">
                                    <a href="@url" target="_blank" rel="noopener" aria-label="@a.Name">
                                        <img src="@url" alt="@a.Name"
                                             style="width:100%; height:100%; object-fit:cover; border-radius:4px; border:1px solid var(--mud-palette-lines-default);" />
                                    </a>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   Style="position:absolute; top:-6px; right:-6px; background:var(--mud-palette-surface); border:1px solid var(--mud-palette-lines-default);"
                                                   OnClick="@(() => DeleteAttachmentAsync(a))"
                                                   aria-label="@L.T("common.delete")" />
                                </div>
                            }
                        </div>
                    }
                    @if (docs.Count > 0)
                    {
                        <div class="d-flex flex-column gap-1 mb-2">
                            @foreach (var doc in docs)
                            {
                                var a = doc;
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                                    <MudLink Typo="Typo.body2" Style="flex:1; min-width:0; word-break:break-all;"
                                             OnClick="@(() => DownloadAttachment(a))">@a.Name</MudLink>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@a.SizeFormatted</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="() => DeleteAttachmentAsync(a)" />
                                </div>
                            }
                        </div>
                    }
                }

                @* Wrapping div carries id="attachment-dropzone" so the
                   dropzone-interop module can wire drag-and-drop. Drops are
                   forwarded into the `attachment-upload` InputFile which
                   then triggers OnFileSelectedAsync — same code path as
                   the click-to-pick flow. *@
                <div id="attachment-dropzone" class="pwa-dropzone pa-2">
                    <div class="d-flex gap-2 align-center flex-wrap">
                        <InputFile id="attachment-upload" OnChange="OnFileSelectedAsync" hidden
                                   accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.heic,.heif,.tif,.tiff,.doc,.docx,.xls,.xlsx,.txt,.zip,.mp3,.wav" />
                        <MudButton HtmlTag="label" Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CloudUpload" for="attachment-upload"
                                   Disabled="_isUploading">
                            @(_isUploading ? L.T("attachments.uploading") : L.T("attachments.upload"))
                        </MudButton>
                        <InputFile id="attachment-camera" OnChange="OnFileSelectedAsync" hidden
                                   accept="image/*" capture="environment" />
                        <MudButton HtmlTag="label" Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CameraAlt" for="attachment-camera"
                                   Disabled="_isUploading">
                            @L.T("attachments.take_photo")
                        </MudButton>
                        @if (_isUploading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                    </div>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                    @L.T("attachments.dsgvo_hint")
                </MudText>
            </MudPaper>

            @* Linked tickets — server-backed via trudesk v2 bidirectional links.
               "blockedBy" is server-generated (the inverse of "blocks") and only
               shown on received links, so it isn't offered in the add dropdown. *@
            <MudPaper Elevation="1" Class="pa-4 mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("detail.linked")</MudText>
                @if (_ticket.LinkedTickets.Count > 0)
                {
                    <div class="d-flex flex-column gap-1 mb-2">
                        @foreach (var link in _ticket.LinkedTickets)
                        {
                            var l = link;
                            <div class="d-flex align-center gap-2">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@LinkTypeLabel(l.LinkType)</MudChip>
                                <MudLink Href="@($"/tickets/{l.Ticket?.Uid}")" Typo="Typo.body2" Style="flex:1; min-width:0;">
                                    #@l.Ticket?.Uid – @l.Ticket?.Subject
                                </MudLink>
                                @if (l.Ticket?.Status?.Name is { Length: > 0 } statusName)
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Style="@($"background:{l.Ticket.Status.HtmlColor};color:#fff;")">@statusName</MudChip>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="@(() => RemoveLinkedTicketAsync(l))" Disabled="_isLoading" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-2">@L.T("detail.no_links")</MudText>
                }
                <div class="d-flex gap-1 align-center">
                    <MudNumericField @bind-Value="_linkTicketUid" Placeholder="#" Variant="Variant.Outlined"
                                     Margin="Margin.Dense" Style="max-width: 80px;" T="int" />
                    <MudSelect @bind-Value="_linkType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Dense="true" T="string" Style="flex:1;">
                        <MudSelectItem Value="@("related")">@L.T("detail.link_related")</MudSelectItem>
                        <MudSelectItem Value="@("blocks")">@L.T("detail.link_blocks")</MudSelectItem>
                        <MudSelectItem Value="@("duplicate")">@L.T("detail.link_duplicate")</MudSelectItem>
                    </MudSelect>
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                   OnClick="AddLinkedTicketAsync" Disabled="_isLoading" />
                </div>
            </MudPaper>

            @* Time tracking entfernt auf Nutzerwunsch (2026-05-19) — die
               Funktion wurde nirgendwo verwendet und hat die Sidebar
               aufgebläht. localStorage-Keys "time_entries_<uid>" bleiben
               liegen, schaden aber nicht. *@
        </MudItem>
    </MudGrid>

    @* Verlauf am Ende des Tickets — volle Breite unter dem Grid, damit
       Statushistorie etc. wirklich ganz unten landet (Nutzerwunsch
       2026-05-19). Default zu, damit es nicht stört. *@
    <MudExpansionPanels Elevation="1" Class="pwa-no-print mt-4">
        <MudExpansionPanel>
            <TitleContent>
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2">@L.T("detail.activity_history")</MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <TicketActivityFeed Ticket="_ticket"
                                    Kinds="@(new[] { TicketActivityFeed.ActivityKind.History })" />
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@code {
    [Parameter] public int TicketUid { get; set; }

    private Ticket? _ticket;
    private bool _isLoading;
    // Which TicketUid the currently displayed data belongs to. Guards
    // OnParametersSetAsync so it only reloads when the route parameter actually
    // changes (not on every parameter set).
    private int? _loadedUid;

    // Inline editing state
    private bool _editingTitle;
    private bool _editingDescription;
    private string _editSubject = string.Empty;
    private string _editIssue = string.Empty;
    private DateTime? _dueDateLocal;

    // True while an inline editor (title/description) is open. A realtime
    // refresh that arrives during an edit is deferred (see _pendingRefresh)
    // so the ticket model isn't swapped out from under the open editor.
    private bool IsInlineEditing => _editingTitle || _editingDescription;
    private bool _pendingRefresh;

    // Composer state — hidden behind the toggle icon next to the
    // comments header. Defaults to closed so the conversation stays
    // visible without a giant text field crowding it.
    private bool _composerOpen;
    private int _composerTab;
    private string _newComment = string.Empty;
    private bool _commentPreview;
    private string _newNote = string.Empty;

    // Reference data (loaded once after ticket)
    private List<Status> _statuses = [];
    private List<Priority> _priorities = [];
    private List<Group> _groups = [];
    private List<User> _users = [];
    private List<Tag> _availableTags = [];
    private List<TicketType> _ticketTypes = [];

    // Soft breaks → <br>: trudesk's UPDATE endpoint stores plain text with
    // raw newlines (CREATE wraps them in <br>, UPDATE does not), so the
    // first edit-and-save round-trip turns multi-line descriptions into
    // Markdig's default "newline = space" Fließtext without this option.
    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseSoftlineBreakAsHardlineBreak()
        .Build();

    // Render a user-typed Issue body to HTML. MarkdownBlankLines.Preserve runs
    // first so empty lines the user added survive Markdig's blank-line collapse
    // (see the helper for the full why); the pipeline then turns each line into
    // a hard break.
    private static MarkupString RenderMarkdown(string? text)
        => (MarkupString)SafeHtml.Sanitize(Markdown.ToHtml(MarkdownBlankLines.Preserve(text), _mdPipeline));

    // Checklist
    private string _newChecklistTitle = string.Empty;

    // Subscription + favorites
    private bool _isSubscribed;
    private bool _isFavorite;

    // Attachments
    private bool _isUploading;
    private IJSObjectReference? _dropzoneModule;

    // Quick replies
    private List<string> _quickReplyTemplates = new();
    private bool _showQuickReplyEditor;

    // Linked tickets (server-backed; the list lives on _ticket.LinkedTickets)
    private int _linkTicketUid;
    private string _linkType = "related";

    private CancellationTokenSource? _refreshDebounceCts;

    // ─── Lifecycle ───────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Ticket-INDEPENDENT, one-time setup only. The ticket itself (and its
        // per-ticket favorite/subscription state) loads in OnParametersSetAsync:
        // navigating straight from /tickets/5 to /tickets/9 reuses this component
        // instance and does NOT re-run OnInitializedAsync, so loading here would
        // leave #5 on screen while the URL says #9 (issue #194).
        _ = LoadReferenceDataAsync();
        await LoadQuickRepliesAsync();
        Realtime.AnyTicketChanged += OnRealtimeChange;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedUid == TicketUid) return;
        _loadedUid = TicketUid;

        // Switching tickets on the reused instance: drop any per-ticket UI state
        // so a half-typed comment or an open inline editor from the previous
        // ticket doesn't bleed into this one.
        ResetPerTicketState();

        await LoadTicketAsync();
        await LoadFavoriteStateAsync();
        await LoadSubscriptionStateAsync();
    }

    private void ResetPerTicketState()
    {
        _refreshDebounceCts?.Cancel();
        _editingTitle = false;
        _editingDescription = false;
        _pendingRefresh = false;
        _newComment = string.Empty;
        _newNote = string.Empty;
        _newChecklistTitle = string.Empty;
        _showQuickReplyEditor = false;
        _linkTicketUid = 0;
        _linkType = "related";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _ticket == null) return;
        try
        {
            _dropzoneModule = await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/dropzone-interop.js");
            await _dropzoneModule.InvokeVoidAsync("register",
                "attachment-dropzone", "attachment-upload");
        }
        catch { /* drag-drop is optional — button still works */ }
    }

    private void OnRealtimeChange(string ticketId)
    {
        if (string.IsNullOrEmpty(ticketId) || _ticket?.Id != ticketId) return;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts = new CancellationTokenSource();
        var token = _refreshDebounceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                if (token.IsCancellationRequested) return;
                await LoadTicketAsync(background: true);
            }
            catch (TaskCanceledException) { }
        });
    }

    // ─── Data loading ────────────────────────────────────────────────────

    private async Task LoadTicketAsync(bool background = false)
    {
        // A realtime-triggered refresh must never interrupt an open inline
        // editor: defer it and replay once the editor closes (see
        // ApplyPendingRefreshAsync). A foreground load (initial open, post-save)
        // always proceeds.
        if (background && IsInlineEditing)
        {
            _pendingRefresh = true;
            return;
        }
        _pendingRefresh = false;

        // Background refreshes stay silent — flipping _isLoading would flash the
        // loading skeleton over whatever the user is doing on every socket event.
        if (!background)
        {
            _isLoading = true;
            StateHasChanged();
        }
        try
        {
            var json = await ApiService.GetTicketAsync(TicketUid.ToString());
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            using var doc = JsonDocument.Parse(json);
            _ticket = doc.RootElement.TryGetProperty("ticket", out var ticketEl)
                ? JsonSerializer.Deserialize<Ticket>(ticketEl.GetRawText(), options)
                : JsonSerializer.Deserialize<Ticket>(json, options);

            if (_ticket != null)
            {
                TrudeskTranslationHelper.TranslateTicket(_ticket);
                // Don't clobber the inline-edit-bound fields while their editor is open: a background
                // realtime refresh (AnyTicketChanged) would otherwise wipe the user's unsaved text mid-typing.
                if (!_editingTitle)
                {
                    _editSubject = _ticket.Subject ?? string.Empty;
                }
                if (!_editingDescription)
                {
                    _editIssue = _ticket.Issue ?? string.Empty;
                }
                _dueDateLocal = _ticket.DueDate == DateTime.MinValue ? null : _ticket.DueDate;
                _ = RecentTickets.RecordAsync(
                    _ticket.Uid.ToString(),
                    _ticket.Subject ?? string.Empty,
                    _ticket.Status?.Uid);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ErrorHelper.Categorize(ex).Message}", Severity.Error);
        }
        finally
        {
            if (!background) _isLoading = false;
            StateHasChanged();
        }
    }

    // Replays a realtime refresh that was deferred because an inline editor was
    // open. Called when the title/description editor closes (save or cancel).
    private async Task ApplyPendingRefreshAsync()
    {
        if (_pendingRefresh && !IsInlineEditing)
        {
            await LoadTicketAsync(background: true);
        }
    }

    private async Task LoadReferenceDataAsync()
    {
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var statusTask = ApiService.GetStatusesAsync();
            var tagsTask = ApiService.GetTagsAsync();
            var groupsTask = ApiService.GetGroupsAsync();
            // Types + priority union from the shared cached lookup; both
            // render via TranslatedName (generic Translator), so no
            // per-name post-processing is needed here.
            var lookupTask = Lookup.GetTypesAndPrioritiesAsync();
            await Task.WhenAll(statusTask, tagsTask, groupsTask, lookupTask);

            var (types, priorities) = lookupTask.Result;
            _ticketTypes = types.ToList();
            _priorities = priorities.ToList();

            _statuses = JsonHelper.DeserializeWrappedArray<Status>(statusTask.Result, "status", options).ToList();
            foreach (var s in _statuses) s.Name = TrudeskTranslationHelper.TranslateStatus(s.Name);

            _availableTags = JsonHelper.DeserializeWrappedArray<Tag>(tagsTask.Result, "tags", options).ToList();

            var groupResp = JsonSerializer.Deserialize<GetGroupResponse>(groupsTask.Result, options);
            _groups = groupResp?.Groups ?? [];

            try
            {
                var usersJson = await ApiService.GetAssigneesAsync();
                var userResponse = JsonSerializer.Deserialize<GetUserResponse>(usersJson, options);
                _users = userResponse?.UsersOrAccounts ?? [];
            }
            catch { _users = []; }

            StateHasChanged();
        }
        catch { /* sidebar functionality degrades but core view works */ }
    }

    // ─── Inline title/description editing ───────────────────────────────

    private void StartTitleEdit()
    {
        _editSubject = _ticket?.Subject ?? string.Empty;
        _editingTitle = true;
    }
    private async Task CancelTitleEdit()
    {
        _editingTitle = false;
        await ApplyPendingRefreshAsync();
    }

    private async Task SaveTitleAsync()
    {
        if (_ticket == null || string.IsNullOrWhiteSpace(_editSubject)) return;
        _isLoading = true;
        var ticketId = _ticket.Id;
        var ticketUid = _ticket.Uid;
        var subject = _editSubject;
        var updatedAt = _ticket.Updated;
        try
        {
            if (!AppState.IsOnline)
            {
                await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, subject, null, null, null, null, null, updatedAt);
                _editingTitle = false;
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }
            _ticket.Subject = subject;
            if (await ApiService.EditTicketAsync(_ticket))
            {
                _editingTitle = false;
                Snackbar.Add(L.T("detail.ticket_updated"), Severity.Success);
                await LoadTicketAsync();
            }
            else Snackbar.Add(L.T("detail.update_failed"), Severity.Error);
        }
        catch (HttpRequestException)
        {
            await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, subject, null, null, null, null, null, updatedAt);
            _editingTitle = false;
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isLoading = false; }
    }

    private void StartDescriptionEdit()
    {
        // trudesk stores Issue as HTML (e.g. <p>…</p>), so feed it through
        // HtmlToPlainText before dropping it into the MudTextField —
        // otherwise the user sees raw tags when editing.
        _editIssue = HtmlToPlainText.Convert(_ticket?.Issue);
        _editingDescription = true;
    }
    private async Task CancelDescriptionEdit()
    {
        _editingDescription = false;
        await ApplyPendingRefreshAsync();
    }

    private async Task SaveDescriptionAsync()
    {
        if (_ticket == null) return;
        _isLoading = true;
        var ticketId = _ticket.Id;
        var ticketUid = _ticket.Uid;
        var issue = _editIssue;
        var updatedAt = _ticket.Updated;
        try
        {
            if (!AppState.IsOnline)
            {
                await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, null, issue, null, null, null, null, updatedAt);
                _editingDescription = false;
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }
            _ticket.Issue = issue;
            if (await ApiService.EditTicketAsync(_ticket))
            {
                _editingDescription = false;
                Snackbar.Add(L.T("detail.ticket_updated"), Severity.Success);
                await LoadTicketAsync();
            }
            else Snackbar.Add(L.T("detail.update_failed"), Severity.Error);
        }
        catch (HttpRequestException)
        {
            await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, null, issue, null, null, null, null, updatedAt);
            _editingDescription = false;
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isLoading = false; }
    }

    // ─── Chip menu actions ──────────────────────────────────────────────

    // Filter the global status list down to those allowed for the ticket's
    // current type. Empty Statuses[] on a type means "no restriction" — the
    // backend default after migration, so we fall back to all statuses.
    private IEnumerable<Status> AllowedStatusesForCurrentType()
    {
        var allowed = _ticket?.Type?.Statuses;
        if (allowed == null || allowed.Count == 0) return _statuses;
        var allowedIds = new HashSet<string>(allowed.Select(s => s.Id ?? "").Where(id => id.Length > 0));
        return _statuses.Where(s => s.Id != null && allowedIds.Contains(s.Id));
    }

    private async Task QuickChangeStatusAsync(Status s)
    {
        if (_ticket == null || string.IsNullOrEmpty(s.Id)) return;
        var ticketId = _ticket.Id;
        var ticketUid = _ticket.Uid;
        var statusId = s.Id;
        var updatedAt = _ticket.Updated;
        try
        {
            if (!AppState.IsOnline)
            {
                await SyncService.EnqueueStatusAsync(ticketId, ticketUid, statusId, updatedAt);
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }
            if (await ApiService.UpdateTicketStatusAsync(ticketId, ticketUid, statusId))
            {
                Snackbar.Add(string.Format(L.T("tickets.status_changed"), s.Name), Severity.Success);
                await LoadTicketAsync();
            }
            else Snackbar.Add(L.T("detail.update_failed"), Severity.Error);
        }
        catch (HttpRequestException)
        {
            await SyncService.EnqueueStatusAsync(ticketId, ticketUid, statusId, updatedAt);
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
    }

    private async Task QuickChangePriorityAsync(Priority p)
    {
        if (_ticket == null) return;
        var ticketId = _ticket.Id;
        var ticketUid = _ticket.Uid;
        var priorityId = p.Id;
        var updatedAt = _ticket.Updated;
        try
        {
            if (!AppState.IsOnline)
            {
                await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, null, null, priorityId, null, null, null, updatedAt);
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }
            _ticket.Priority = p;
            if (await ApiService.EditTicketAsync(_ticket))
            {
                Snackbar.Add(L.T("detail.ticket_updated"), Severity.Success);
                await LoadTicketAsync();
            }
            else Snackbar.Add(L.T("detail.update_failed"), Severity.Error);
        }
        catch (HttpRequestException)
        {
            await SyncService.EnqueueUpdateTicketFieldsAsync(ticketId, ticketUid, null, null, priorityId, null, null, null, updatedAt);
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
