    internal static string TruncateTemplate(string t) => t.Length > 50 ? t[..47] + "..." : t;
    private void OpenQuickReplyEditor() => _showQuickReplyEditor = true;
    private void AddEmptyQuickReply() => _quickReplyTemplates.Add(string.Empty);
    private void RemoveQuickReply(int idx) { if (idx < _quickReplyTemplates.Count) _quickReplyTemplates.RemoveAt(idx); }

    private async Task SaveQuickRepliesAsync()
    {
        _quickReplyTemplates.RemoveAll(string.IsNullOrWhiteSpace);
