    private IJSObjectReference? _printQrModule;

    private async Task PrintQrCodeAsync()
    {
        // Renders the QR + ticket number into a popup window and triggers
        // print() — bypasses the dialog so it's one click from the menu.
        var url = $"{Navigation.BaseUri.TrimEnd('/')}/tickets/{TicketUid}";
        string svg;
        using (var generator = new QRCodeGenerator())
        using (var data = generator.CreateQrCode(url, QRCodeGenerator.ECCLevel.Q))
        {
            svg = new SvgQRCode(data).GetGraphic(8);
        }

        try
        {
            _printQrModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/print-qr.js");
            var ok = await _printQrModule.InvokeAsync<bool>("printQr",
                svg, $"#{TicketUid}", url);
            if (!ok) Snackbar.Add(L.T("common.popup_blocked"), Severity.Warning);
        }
        catch
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }

