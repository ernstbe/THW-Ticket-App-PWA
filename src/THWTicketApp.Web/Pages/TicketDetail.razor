        var favs = System.Text.Json.JsonSerializer.Deserialize<List<int>>(favJson) ?? [];
        _isFavorite = favs.Contains(TicketUid);
    }

    private async Task ToggleFavoriteAsync()
    {
        var favJson = await LocalStorage.GetItemAsync("favorite_tickets") ?? "[]";
        var favs = System.Text.Json.JsonSerializer.Deserialize<List<int>>(favJson) ?? [];

