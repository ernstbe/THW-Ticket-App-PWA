@page "/notifications"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.RealtimeService Realtime
@inject THWTicketApp.Web.Services.LocalizationService L
@implements IDisposable

<PageTitle>@L.T("nav.notifications") - THW Ticket App</PageTitle>

<div class="d-flex justify-space-between align-center mb-4 flex-wrap gap-2">
    <MudText Typo="Typo.h4">@L.T("nav.notifications")</MudText>
    <div class="d-flex gap-2">
        @if (_notifications.Any(n => !n.IsRead))
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DoneAll"
                       OnClick="MarkAllReadAsync" Disabled="_isLoading || _markingAll">
                @L.T("notifications.mark_all_read")
            </MudButton>
        }
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadNotificationsAsync"
                       Disabled="_isLoading" aria-label="@L.T("common.refresh")" />
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <MudChip T="string" Color="@(_activeFilter == "all" ? Color.Primary : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("all"))">
        @L.T("common.all") (@_notifications.Count)
    </MudChip>
    <MudChip T="string" Color="@(_activeFilter == "unread" ? Color.Warning : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("unread"))">
        @L.T("notifications.unread") (@_notifications.Count(n => !n.IsRead))
    </MudChip>
    <MudChip T="string" Color="@(_activeFilter == "read" ? Color.Success : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("read"))">
        @L.T("notifications.read") (@_notifications.Count(n => n.IsRead))
    </MudChip>
</div>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

@if (FilteredNotifications.Count == 0 && !_isLoading)
{
    <MudAlert Severity="Severity.Normal" Class="mb-4">
        <MudText>@L.T("notifications.none")</MudText>
    </MudAlert>
}
else
{
    <MudStack Spacing="2">
        @foreach (var notification in PagedNotifications)
        {
            var n = notification;
            var unread = !n.IsRead;
            <MudPaper Class="pa-3 cursor-pointer" Elevation="1"
                      Style="@($"border-left: 4px solid {(unread ? "var(--mud-palette-primary)" : "transparent")}; {(unread ? "background: var(--mud-palette-background-grey, rgba(0,51,153,0.04));" : "")}")"
                      @onclick="@(() => OpenNotification(n))">
                <div class="d-flex align-center gap-3">
                    <MudIcon Icon="@GetNotificationIcon(n)" Color="@GetNotificationColor(n)" />
                    <div class="flex-grow-1" style="min-width:0;">
                        <MudText Typo="Typo.body2" Style="@($"font-weight: {(unread ? "700" : "500")};")">
                            @(n.Title ?? L.T("notifications.default_title"))
                        </MudText>
                        @if (!string.IsNullOrEmpty(n.Description))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @n.Description
                            </MudText>
                        }
                        @if (n.Date != default)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                @n.Date.ToString("dd.MM.yyyy HH:mm")
                            </MudText>
                        }
                    </div>
                    @if (unread)
                    {
                        <div @onclick:stopPropagation="true">
                            <MudTooltip Text="@L.T("notifications.mark_read")">
                                <MudIconButton Icon="@Icons.Material.Filled.MarkEmailRead" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(async () => await MarkReadAsync(n))" />
                            </MudTooltip>
                        </div>
                    }
                </div>
            </MudPaper>
        }
    </MudStack>

    @if (FilteredNotifications.Count > _displayedCount)
    {
        <div class="d-flex justify-center mt-4">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       OnClick="LoadMore" StartIcon="@Icons.Material.Filled.ExpandMore">
                @L.T("notifications.load_more") (@(FilteredNotifications.Count - _displayedCount))
            </MudButton>
        </div>
    }
}

@code {
    private const int PageSize = 20;
    private bool _isLoading;
    private bool _markingAll;
    private List<NotificationItem> _notifications = [];
    private string _activeFilter = "all";
    private int _displayedCount = PageSize;

    private List<NotificationItem> FilteredNotifications => _activeFilter switch
    {
        "unread" => _notifications.Where(n => !n.IsRead).ToList(),
        "read" => _notifications.Where(n => n.IsRead).ToList(),
        _ => _notifications
    };

    private IEnumerable<NotificationItem> PagedNotifications => FilteredNotifications.Take(_displayedCount);

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        _displayedCount = PageSize;
        StateHasChanged();
    }

    private void LoadMore()
    {
        _displayedCount += PageSize;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadNotificationsAsync();
        Realtime.NotificationUpdate += OnNotificationUpdate;
    }

    private async void OnNotificationUpdate()
    {
        await InvokeAsync(LoadNotificationsAsync);
    }

    public void Dispose()
    {
        Realtime.NotificationUpdate -= OnNotificationUpdate;
    }

    private async Task LoadNotificationsAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        StateHasChanged();

        try
        {
            var json = await ApiService.GetNotificationsAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            using var doc = JsonDocument.Parse(json);
            _notifications.Clear();

            JsonElement notificationsEl;
            if (doc.RootElement.TryGetProperty("notifications", out notificationsEl) && notificationsEl.ValueKind == JsonValueKind.Array)
            {
                foreach (var el in notificationsEl.EnumerateArray())
                {
                    var item = new NotificationItem();

                    if (el.TryGetProperty("_id", out var idEl))
                        item.Id = idEl.GetString();
                    if (el.TryGetProperty("title", out var titleEl))
                        item.Title = titleEl.GetString();
                    if (el.TryGetProperty("message", out var msgEl))
                        item.Description = msgEl.GetString();
                    if (el.TryGetProperty("description", out var descEl))
                        item.Description ??= descEl.GetString();
                    if (el.TryGetProperty("type", out var typeEl))
                        item.EventType = typeEl.ValueKind == JsonValueKind.String
                            ? typeEl.GetString()
                            : typeEl.ToString();
                    if (el.TryGetProperty("unread", out var unreadEl))
                        item.IsRead = unreadEl.ValueKind == JsonValueKind.True ? false
                            : unreadEl.ValueKind == JsonValueKind.False ? true
                            : !unreadEl.GetBoolean();
                    // API returns "created" not "date"
                    var dateField = el.TryGetProperty("date", out var dateEl) ? dateEl
                        : el.TryGetProperty("created", out var createdEl) ? createdEl
                        : default;
                    if (dateField.ValueKind == JsonValueKind.String && DateTime.TryParse(dateField.GetString(), out var dt))
                        item.Date = dt;
                    if (el.TryGetProperty("data", out var dataEl))
                    {
                        if (dataEl.TryGetProperty("ticket", out var ticketEl))
                        {
                            if (ticketEl.ValueKind == JsonValueKind.Object && ticketEl.TryGetProperty("uid", out var uidEl))
                                item.TicketUid = uidEl.GetInt32().ToString();
                            else if (ticketEl.ValueKind == JsonValueKind.String)
                                item.TicketId = ticketEl.GetString();
                        }
                    }

                    _notifications.Add(item);
                }
            }

            _notifications = _notifications.OrderByDescending(n => n.Date).ToList();
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            Snackbar.Add(message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenNotification(NotificationItem notification)
    {
        // Persist the read state before navigating away, so the count in
        // the app bar updates immediately and a reload doesn't bring it
        // back as unread.
        if (!notification.IsRead && !string.IsNullOrEmpty(notification.Id))
        {
            notification.IsRead = true;
            _ = ApiService.MarkNotificationReadAsync(notification.Id);
        }

        if (!string.IsNullOrEmpty(notification.TicketUid))
            Navigation.NavigateTo($"tickets/{notification.TicketUid}");
        else if (!string.IsNullOrEmpty(notification.TicketId))
            Navigation.NavigateTo($"tickets/{notification.TicketId}");
    }

    private async Task MarkReadAsync(NotificationItem notification)
    {
        if (notification.IsRead || string.IsNullOrEmpty(notification.Id)) return;
        // Optimistic: flip locally first; revert if the server rejects.
        notification.IsRead = true;
        StateHasChanged();
        var ok = await ApiService.MarkNotificationReadAsync(notification.Id);
        if (!ok)
        {
            notification.IsRead = false;
            StateHasChanged();
            Snackbar.Add(L.T("notifications.mark_failed"), Severity.Error);
        }
    }

    private async Task MarkAllReadAsync()
    {
        _markingAll = true;
        try
        {
            var updated = await ApiService.MarkAllNotificationsReadAsync();
            foreach (var n in _notifications) n.IsRead = true;
            Snackbar.Add(string.Format(L.T("notifications.marked_all"), updated), Severity.Success);
        }
        finally
        {
            _markingAll = false;
            StateHasChanged();
        }
    }

    private static string GetNotificationIcon(NotificationItem n) => n.EventType switch
    {
        "ticket:created" => Icons.Material.Filled.AddCircle,
        "ticket:updated" => Icons.Material.Filled.Edit,
        "comment:added" => Icons.Material.Filled.Comment,
        "note:added" => Icons.Material.Filled.Note,
        "ticket:status" => Icons.Material.Filled.SwapHoriz,
        _ => Icons.Material.Filled.Notifications
    };

    private static Color GetNotificationColor(NotificationItem n) => n.EventType switch
    {
        "ticket:created" => Color.Success,
        "ticket:updated" => Color.Info,
        "comment:added" => Color.Primary,
        "ticket:status" => Color.Warning,
        _ => Color.Default
    };

    private class NotificationItem
    {
        public string? Id { get; set; }   // Notification _id — needed for server-side markRead
        public string? Title { get; set; }
        public string? Description { get; set; }
        public string? EventType { get; set; }
        public string? TicketId { get; set; }
        public string? TicketUid { get; set; }
        public DateTime Date { get; set; }
        public bool IsRead { get; set; }
    }
}
