@page "/tickets"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@using System.Net.Http
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage
@inject THWTicketApp.Web.Services.RealtimeService Realtime
@inject THWTicketApp.Web.Services.LocalizationService L
@inject IJSRuntime JsRuntime
@inject ISyncService SyncService
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>@L.T("tickets.title") - THW Ticket App</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L.T("tickets.title")</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navigation.NavigateTo("tickets/add"))">
            @L.T("tickets.new")
        </MudButton>
    </div>
</div>

@* Search bar *@
<MudTextField @bind-Value="_searchText" Placeholder="@L.T("tickets.search")" Variant="Variant.Outlined"
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" DebounceInterval="400" TextChanged="OnSearchChanged"
              Class="mb-3" Clearable="true" />

@* Filter chips — "Aktiv" (offen + in Bearbeitung, alles außer
   geschlossen) is the default on user request 2026-05-19. *@
<div class="d-flex flex-wrap gap-2 mb-3">
    <MudChip T="string" Color="@(_activeFilter == "active" ? Color.Primary : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("active"))">@L.T("tickets.active")</MudChip>
    <MudChip T="string" Color="@(_activeFilter == "all" ? Color.Primary : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("all"))">@L.T("common.all")</MudChip>
    <MudChip T="string" Color="@(_activeFilter == "open" ? Color.Info : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("open"))">@L.T("tickets.open")</MudChip>
    <MudChip T="string" Color="@(_activeFilter == "pending" ? Color.Warning : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("pending"))">@L.T("tickets.pending")</MudChip>
    <MudChip T="string" Color="@(_activeFilter == "closed" ? Color.Success : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("closed"))">@L.T("tickets.closed")</MudChip>
    <MudChip T="string" Color="@(_activeFilter == "overdue" ? Color.Error : Color.Default)"
             Variant="Variant.Filled" OnClick="@(() => SetFilter("overdue"))">@L.T("dashboard.overdue")</MudChip>
    <MudChip T="string" Color="@(_showOnlyMyTickets ? Color.Secondary : Color.Default)"
             Variant="Variant.Filled" OnClick="ToggleMyTickets">@L.T("tickets.mytickets")</MudChip>
    <MudSpacer />
    <MudIconButton Icon="@(_showAdvancedFilter ? Icons.Material.Filled.FilterListOff : Icons.Material.Filled.Tune)"
                   OnClick="@(() => { _showAdvancedFilter = !_showAdvancedFilter; StateHasChanged(); })"
                   Size="Size.Small" Color="@(_hasAdvancedFilter ? Color.Primary : Color.Default)"
                   aria-label="@L.T("search.advanced")" />
</div>

@if (_showAdvancedFilter)
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" @bind-Value="_filterPriority" Label="@L.T("detail.priority")"
                           Variant="Variant.Outlined" Clearable="true" Margin="Margin.Dense">
                    @foreach (var p in _allPriorities)
                    {
                        <MudSelectItem Value="@p">@p</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" @bind-Value="_filterGroup" Label="@L.T("detail.group")"
                           Variant="Variant.Outlined" Clearable="true" Margin="Margin.Dense">
                    @foreach (var g in _allGroups)
                    {
                        <MudSelectItem Value="@g">@g</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" @bind-Value="_filterType" Label="@L.T("detail.type")"
                           Variant="Variant.Outlined" Clearable="true" Margin="Margin.Dense">
                    @foreach (var t in _allTypes)
                    {
                        <MudSelectItem Value="@t">@t</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker @bind-Date="_filterDateFrom" Label="@L.T("search.date_from")"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker @bind-Date="_filterDateTo" Label="@L.T("search.date_to")"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
            </MudItem>
        </MudGrid>
        <div class="d-flex gap-2 mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="ApplyAdvancedFilter">@L.T("common.filter")</MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="ClearAdvancedFilter">@L.T("search.clear_filter")</MudButton>
        </div>
    </MudPaper>
}

@* Sort selector. flex-wrap so mobile clients don't get a horizontal
   scrollbar — Sortier-Select + 3 Icons + Counter + Saved-Filter-Menu
   together overflow a phone viewport without it. *@
<div class="d-flex align-center gap-2 mb-4 flex-wrap">
    @* @bind-Value:after re-applies the local sort the moment the user
       picks a new option, otherwise the list only reflects the change
       after the next manual refresh / filter click. *@
    <MudSelect T="string" @bind-Value="_activeSort" @bind-Value:after="ApplyFilters"
               Label="@L.T("tickets.sort")" Variant="Variant.Outlined"
               Dense="true" Style="max-width: 250px;">
        <MudSelectItem Value="@("date_desc")">@L.T("tickets.sort.newest")</MudSelectItem>
        <MudSelectItem Value="@("date_asc")">@L.T("tickets.sort.oldest")</MudSelectItem>
        <MudSelectItem Value="@("updated")">@L.T("tickets.sort.updated")</MudSelectItem>
        <MudSelectItem Value="@("priority")">@L.T("tickets.sort.priority")</MudSelectItem>
        <MudSelectItem Value="@("subject")">@L.T("tickets.sort.subject")</MudSelectItem>
    </MudSelect>
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadTicketsAsync"
                   Disabled="_isLoading" aria-label="@L.T("common.refresh")" />
    <MudToggleIconButton @bind-Toggled="_batchMode" Icon="@Icons.Material.Filled.CheckBoxOutlineBlank"
                          ToggledIcon="@Icons.Material.Filled.CheckBox" Size="Size.Medium"
                          ToggledColor="Color.Primary"
                          aria-label="@L.T("batch.toggle")" />
    <MudIconButton Icon="@Icons.Material.Filled.FileDownload" OnClick="ExportCsvAsync"
                   Disabled="@(!_filteredTickets.Any())" aria-label="@L.T("tickets.export_csv")" />
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        @_filteredTickets.Count Ticket(s)
    </MudText>
    <MudSpacer />
    @* Saved Filters *@
    @if (_savedFilters.Count > 0)
    {
        <MudMenu Label="@L.T("tickets.loadfilter")" Variant="Variant.Outlined" Size="Size.Small"
                 StartIcon="@Icons.Material.Filled.FilterList" Dense="true">
            @foreach (var f in _savedFilters)
            {
                <MudMenuItem>
                    <div class="d-flex align-center gap-2">
                        <MudLink OnClick="@(() => ApplySavedFilter(f))">@f.Name</MudLink>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => DeleteSavedFilterAsync(f))" />
                    </div>
                </MudMenuItem>
            }
        </MudMenu>
    }
    <MudIconButton Icon="@Icons.Material.Filled.BookmarkAdd" Size="Size.Small"
                   OnClick="@(() => _showSaveFilterDialog = true)" />
</div>

@if (_showSaveFilterDialog)
{
    <MudPaper Elevation="2" Class="pa-3 mb-3 d-flex gap-2 align-center">
        <MudTextField @bind-Value="_saveFilterName" Label="@L.T("tickets.filtername")" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Style="max-width: 250px;" T="string" />
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SaveCurrentFilterAsync" Disabled="@string.IsNullOrWhiteSpace(_saveFilterName)">
            @L.T("common.save")
        </MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Text"
                   OnClick="@(() => _showSaveFilterDialog = false)">@L.T("common.cancel")</MudButton>
    </MudPaper>
}

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <MudAlert Severity="Severity.Info" Class="mb-4">@_statusMessage</MudAlert>
}

@* Batch toolbar — show "select all visible" once batch mode is on,
   regardless of whether anything is currently selected. *@
@if (_batchMode)
{
    <MudPaper Elevation="3" Class="pa-3 mb-3 d-flex align-center gap-3 flex-wrap">
        <MudText Typo="Typo.body2">
            @if (_selectedTicketIds.Count == 0)
            {
                @L.T("batch.empty")
            }
            else
            {
                @string.Format(L.T("batch.selected"), _selectedTicketIds.Count)
            }
        </MudText>
        <MudButton Variant="Variant.Text" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.SelectAll"
                   OnClick="SelectAllVisible" Disabled="_isLoading">
            @L.T("batch.select_all_visible")
        </MudButton>
        <MudSpacer />
        @if (_selectedTicketIds.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Person"
                       OnClick="BatchAssignToMeAsync" Disabled="_isLoading">
                @L.T("tickets.assign_me")
            </MudButton>
            @if (_assignableUsers.Count > 0)
            {
                <MudMenu Label="@L.T("batch.assign_to")"
                         StartIcon="@Icons.Material.Filled.PersonAddAlt"
                         Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                         Disabled="_isLoading" Dense="true" MaxHeight="400">
                    @foreach (var u in _assignableUsers)
                    {
                        var user = u;
                        <MudMenuItem OnClick="@(() => BatchAssignToUserAsync(user))">
                            @(string.IsNullOrWhiteSpace(user.Fullname) ? user.Username : user.Fullname)
                        </MudMenuItem>
                    }
                </MudMenu>
            }
            @if (_allStatuses.Count > 0)
            {
                <MudMenu Label="@L.T("batch.change_status")"
                         StartIcon="@Icons.Material.Filled.SwapHoriz"
                         Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                         Disabled="_isLoading" Dense="true">
                    @foreach (var s in _allStatuses)
                    {
                        var status = s;
                        <MudMenuItem OnClick="@(() => BatchChangeStatusAsync(status))">
                            @status.Name
                        </MudMenuItem>
                    }
                </MudMenu>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="BatchDeleteAsync" Disabled="_isLoading">
                @L.T("common.delete")
            </MudButton>
        }
        <MudButton Variant="Variant.Text" Size="Size.Small"
                   OnClick="ClearSelection">@L.T("common.cancel")</MudButton>
    </MudPaper>
}

@* Ticket list *@
@if (_isLoading && _filteredTickets.Count == 0)
{
    <MudStack Spacing="2">
        @for (var i = 0; i < 5; i++)
        {
            <MudPaper Elevation="1" Class="pa-4">
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudSkeleton Width="60%" Height="24px" />
                    <MudSkeleton Width="80px" Height="24px" />
                </div>
                <MudSkeleton Width="40%" Height="16px" Class="mb-1" />
                <MudSkeleton Width="30%" Height="16px" />
            </MudPaper>
        }
    </MudStack>
}
else if (_filteredTickets.Count == 0)
{
    <EmptyState Icon="@Icons.Material.Outlined.ConfirmationNumber"
                Title="@L.T("tickets.none")"
                Description="@L.T("tickets.empty_description")"
                ActionLabel="@L.T("tickets.new")"
                ActionHref="tickets/add" />
}
else
{
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
    }
    <MudStack Spacing="0">
        @foreach (var ticket in PagedTickets)
        {
            var t = ticket;
            <TicketCard Ticket="t" ShowActions="true"
                        IsSelectable="_batchMode"
                        IsSelected="_selectedTicketIds.Contains(t.Id)"
                        OnSelectedChanged="@(v => ToggleSelection(t.Id, v))"
                        OnClick="NavigateToDetail"
                        OnAssignToMe="AssignToMeAsync"
                        OnClose="CloseTicketAsync"
                        AvailableStatuses="_allStatuses"
                        OnChangeStatus="QuickChangeStatusAsync" />
        }
    </MudStack>

    @if (_totalPages > 1)
    {
        <div class="d-flex justify-center mt-4">
            <MudPagination Count="_totalPages" Selected="_currentPage"
                           SelectedChanged="OnPageChanged"
                           Color="Color.Primary" Variant="Variant.Filled"
                           ShowFirstButton="true" ShowLastButton="true" />
        </div>
    }
}

@code {
    [SupplyParameterFromQuery(Name = "filter")]
    public string? InitialFilter { get; set; }

    private const int PageSize = 20;
    private bool _isLoading;
    private string _searchText = string.Empty;
    private string _activeFilter = "active";
    private string _activeSort = "updated";
    private bool _showOnlyMyTickets;
    private string _statusMessage = string.Empty;
    private List<Ticket> _allTickets = [];
    private List<Ticket> _filteredTickets = [];
    private int _currentPage = 1;
    private int _totalPages => Math.Max(1, (int)Math.Ceiling(_filteredTickets.Count / (double)PageSize));
    private IEnumerable<Ticket> PagedTickets => _filteredTickets.Skip((_currentPage - 1) * PageSize).Take(PageSize);
    private bool _isServerSearchActive;
    private List<SavedFilterItem> _savedFilters = [];
    private bool _showSaveFilterDialog;
    private string _saveFilterName = string.Empty;

    // Batch selection
    private bool _batchMode;
    private HashSet<string> _selectedTicketIds = new();
    private List<Status> _allStatuses = [];
    private List<User> _assignableUsers = [];

    // Advanced filter
    private bool _showAdvancedFilter;
    private string? _filterPriority;
    private string? _filterGroup;
    private string? _filterType;
    private DateTime? _filterDateFrom;
    private DateTime? _filterDateTo;
    private bool _hasAdvancedFilter => _filterPriority != null || _filterGroup != null || _filterType != null || _filterDateFrom != null || _filterDateTo != null;
    private List<string> _allPriorities = [];
    private List<string> _allGroups = [];
    private List<string> _allTypes = [];

    private CancellationTokenSource? _refreshDebounceCts;
    private IJSObjectReference? _ptrModule;
    private DotNetObjectReference<Tickets>? _ptrRef;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(InitialFilter))
            _activeFilter = InitialFilter;
        await LoadSavedFiltersAsync();
        await LoadStatusesAsync();
        await LoadAssignableUsersAsync();
        await LoadTicketsAsync();
        Realtime.AnyTicketChanged += OnRealtimeChange;
    }

    private async Task LoadStatusesAsync()
    {
        try
        {
            var json = await ApiService.GetStatusesAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            _allStatuses = JsonHelper.DeserializeWrappedArray<Status>(json, "status", options).ToList();
            foreach (var s in _allStatuses)
                s.Name = TrudeskTranslationHelper.TranslateStatus(s.Name ?? string.Empty);
        }
        catch { /* status dropdowns just stay empty — bulk close fallback still works */ }
    }

    private async Task LoadAssignableUsersAsync()
    {
        try
        {
            var json = await ApiService.GetAssigneesAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var response = JsonSerializer.Deserialize<GetUserResponse>(json, options);
            _assignableUsers = (response?.UsersOrAccounts ?? [])
                .Where(u => !u.Deleted)
                .OrderBy(u => u.Fullname ?? u.Username, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch { /* bulk "assign to…" menu just stays hidden */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _ptrModule = await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/pull-to-refresh-interop.js");
            _ptrRef = DotNetObjectReference.Create(this);
            await _ptrModule.InvokeVoidAsync("register", _ptrRef);
        }
        catch
        {
            // Non-fatal — pull-to-refresh is a nice-to-have, not a hard
            // dependency. Manual refresh button continues to work.
        }
    }

    [JSInvokable]
    public async Task OnPullRefresh()
    {
        await LoadTicketsAsync();
        StateHasChanged();
    }

    private void OnRealtimeChange(string ticketId)
    {
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts = new CancellationTokenSource();
        var token = _refreshDebounceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                if (token.IsCancellationRequested) return;
                await LoadTicketsAsync();
            }
            catch (TaskCanceledException) { }
        });
    }

    public void Dispose()
    {
        Realtime.AnyTicketChanged -= OnRealtimeChange;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts?.Dispose();
        // Detach pull-to-refresh — the JS module attaches global touch
        // listeners that would survive page navigation otherwise.
        if (_ptrModule != null)
        {
            try { _ = _ptrModule.InvokeVoidAsync("unregister"); } catch { }
            _ = _ptrModule.DisposeAsync();
        }
        _ptrRef?.Dispose();
    }

    private async Task LoadTicketsAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _statusMessage = string.Empty;
        StateHasChanged();

        try
        {
            var json = await ApiService.GetTicketsAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var tickets = JsonHelper.DeserializeWrappedArray<Ticket>(json, "tickets", options);

            _allTickets.Clear();
            foreach (var t in tickets)
            {
                TrudeskTranslationHelper.TranslateTicket(t);
                _allTickets.Add(t);
            }

            // Populate advanced filter options from data
            _allPriorities = _allTickets
                .Where(t => t.Priority?.Name != null)
                .Select(t => t.Priority!.Name!)
                .Distinct().OrderBy(n => n).ToList();
            _allGroups = _allTickets
                .Where(t => t.Group?.Name != null)
                .Select(t => t.Group!.Name!)
                .Distinct().OrderBy(n => n).ToList();
            _allTypes = _allTickets
                .Where(t => t.Type?.Name != null)
                .Select(t => t.Type!.TranslatedName)
                .Distinct().OrderBy(n => n).ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            _statusMessage = message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchChanged(string value)
    {
        _searchText = value;
        _currentPage = 1;
        if (string.IsNullOrWhiteSpace(value))
        {
            _isServerSearchActive = false;
            ApplyFilters();
            return;
        }
        if (value.Length < 2) { ApplyFilters(); return; }

        try
        {
            var json = await ApiService.SearchTicketsAsync(value);
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var response = JsonSerializer.Deserialize<GetTicketsResponse>(json, options);
            if (response?.Tickets != null && response.Tickets.Count > 0)
            {
                _isServerSearchActive = true;
                foreach (var t in response.Tickets) TrudeskTranslationHelper.TranslateTicket(t);
                _filteredTickets = ApplySorting(ApplyLocalFilters(response.Tickets)).ToList();
                StateHasChanged();
                return;
            }
        }
        catch { }
        _isServerSearchActive = false;
        ApplyFilters();
    }

    private void SetFilter(string filter) { _activeFilter = filter; _currentPage = 1; ApplyFilters(); }
    private void ToggleMyTickets() { _showOnlyMyTickets = !_showOnlyMyTickets; _currentPage = 1; ApplyFilters(); }
    private void OnPageChanged(int page) { _currentPage = page; StateHasChanged(); }

    private void ApplyFilters()
    {
        var source = _allTickets.AsEnumerable();
        if (!_isServerSearchActive && !string.IsNullOrWhiteSpace(_searchText))
        {
            var search = _searchText.ToLowerInvariant();
            source = source.Where(t =>
                (t.Subject?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Issue?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Owner?.Fullname?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Assignee?.Fullname?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                t.Uid.ToString().Contains(search));
        }
        _filteredTickets = ApplySorting(ApplyLocalFilters(source)).ToList();
        StateHasChanged();
    }

    private IEnumerable<Ticket> ApplyLocalFilters(IEnumerable<Ticket> source)
    {
        source = _activeFilter switch
        {
            // "Aktiv" = everything that is NOT closed/resolved. Picks up
            // "Offen", "In Bearbeitung", and any custom non-resolved
            // status the trudesk admin may have added.
            "active" => source.Where(t => TicketStatusHelper.IsActive(t.Status)),
            "open" => source.Where(t => TicketStatusHelper.IsOpen(t.Status)),
            "pending" => source.Where(t => t.Status?.IsInProgress == true),
            "closed" => source.Where(t => TicketStatusHelper.IsClosed(t.Status)),
            "overdue" => source.Where(t => TicketDueDateHelper.IsOverdue(t.DueDate) && TicketStatusHelper.IsActive(t.Status)),
            _ => source
        };
        if (_showOnlyMyTickets && !string.IsNullOrEmpty(ApiService.CurrentUserId))
            source = source.Where(t => t.Assignee?.Id == ApiService.CurrentUserId
                || t.AdditionalAssignees.Any(a => a.Id == ApiService.CurrentUserId));

        // Advanced filters
        if (!string.IsNullOrEmpty(_filterPriority))
            source = source.Where(t => t.Priority?.Name == _filterPriority);
        if (!string.IsNullOrEmpty(_filterGroup))
            source = source.Where(t => t.Group?.Name == _filterGroup);
        if (!string.IsNullOrEmpty(_filterType))
            source = source.Where(t => t.Type?.TranslatedName == _filterType);
        if (_filterDateFrom.HasValue)
            source = source.Where(t => t.Date >= _filterDateFrom.Value);
        if (_filterDateTo.HasValue)
            source = source.Where(t => t.Date <= _filterDateTo.Value.AddDays(1));

        return source;
    }

    private void ApplyAdvancedFilter() { _currentPage = 1; ApplyFilters(); }

    private void ClearAdvancedFilter()
    {
        _filterPriority = null;
        _filterGroup = null;
        _filterType = null;
        _filterDateFrom = null;
        _filterDateTo = null;
        _currentPage = 1;
        ApplyFilters();
    }

    private IOrderedEnumerable<Ticket> ApplySorting(IEnumerable<Ticket> source)
    {
        return _activeSort switch
        {
            "date_asc" => source.OrderBy(t => t.Date),
            "updated" => source.OrderByDescending(t => t.LastActivityAt),
            // Sort by Priority.MigrationNum (1=lowest … N=highest), highest first.
            // The previous key was OverdueIn (minutes until a ticket counts as
            // overdue), which (a) is the wrong direction — a longer fuse means
            // *less* urgent — and (b) is set equal across priorities on some
            // installations (ov-emm-tickets.de uses 2880 min for all three),
            // so the list didn't reorder at all.
            "priority" => source.OrderByDescending(t => t.Priority?.MigrationNum ?? 0),
            "subject" => source.OrderBy(t => t.Subject, StringComparer.OrdinalIgnoreCase),
            _ => source.OrderByDescending(t => t.Date)
        };
    }

    private void NavigateToDetail(Ticket ticket)
    {
        Navigation.NavigateTo($"tickets/{ticket.Uid}");
    }

    private async Task AssignToMeAsync(Ticket ticket)
    {
        var userId = ApiService.CurrentUserId;
        if (string.IsNullOrEmpty(userId)) return;
        try
        {
            if (await ApiService.AssignTicketAsync(ticket.Id, ticket.Uid, userId))
            { Snackbar.Add(L.T("tickets.assigned"), Severity.Success); await LoadTicketsAsync(); }
        }
        catch { Snackbar.Add(L.T("tickets.assign_failed"), Severity.Error); }
    }

    private async Task QuickChangeStatusAsync((Ticket Ticket, Status Status) args)
    {
        if (string.IsNullOrEmpty(args.Status.Id)) return;
        var ticketId = args.Ticket.Id;
        var ticketUid = args.Ticket.Uid;
        var statusId = args.Status.Id;
        var updatedAt = args.Ticket.Updated;
        try
        {
            if (!AppState.IsOnline)
            {
                await SyncService.EnqueueStatusAsync(ticketId, ticketUid, statusId, updatedAt);
                Snackbar.Add(L.T("offline.queued"), Severity.Info);
                return;
            }
            if (await ApiService.UpdateTicketStatusAsync(ticketId, ticketUid, statusId))
            {
                Snackbar.Add(string.Format(L.T("tickets.status_changed"), args.Status.Name), Severity.Success);
                await LoadTicketsAsync();
            }
            else
            {
                Snackbar.Add(L.T("tickets.close_failed"), Severity.Error);
            }
        }
        catch (HttpRequestException)
        {
            await SyncService.EnqueueStatusAsync(ticketId, ticketUid, statusId, updatedAt);
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
    }

    private async Task CloseTicketAsync(Ticket ticket)
    {
        try
        {
            // Same situation as Dashboard.QuickCloseAsync — we need the live
            // status catalogue to pick the "resolved" one, which requires the
            // network. Skip cleanly when offline.
            if (!AppState.IsOnline)
            {
                Snackbar.Add(L.T("offline.action_unavailable"), Severity.Warning);
                return;
            }
            var statusJson = await ApiService.GetStatusesAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var statuses = JsonHelper.DeserializeWrappedArray<Status>(statusJson, "status", options);
            var closedStatus = statuses.FirstOrDefault(s => s.IsResolved);
            if (closedStatus != null && await ApiService.UpdateTicketStatusAsync(ticket.Id, ticket.Uid, closedStatus.Id!))
            { Snackbar.Add(L.T("tickets.closed_success"), Severity.Success); await LoadTicketsAsync(); }
        }
        catch (HttpRequestException) { Snackbar.Add(L.T("offline.action_unavailable"), Severity.Warning); }
        catch { Snackbar.Add(L.T("tickets.close_failed"), Severity.Error); }
    }

    // Batch operations
    private void ToggleSelection(string ticketId, bool selected)
    {
        if (selected) _selectedTicketIds.Add(ticketId);
        else _selectedTicketIds.Remove(ticketId);
        StateHasChanged();
    }

    private void ClearSelection()
    {
        _selectedTicketIds.Clear();
        _batchMode = false;
        StateHasChanged();
    }

    private async Task BatchDeleteAsync()
    {
        if (_selectedTicketIds.Count == 0) return;
        if (!EnsureOnline()) return;

        // Bulk delete is irreversible and can hit many tickets at once — make
        // the user confirm with the exact count first.
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L.T("batch.delete_confirm_title") },
            { x => x.Message, string.Format(L.T("batch.delete_confirm"), _selectedTicketIds.Count) },
            { x => x.ConfirmText, L.T("common.delete") },
            { x => x.CancelText, L.T("common.cancel") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        _isLoading = true;
        try
        {
            var (deleted, failed) = await ApiService.BatchDeleteTicketsAsync(_selectedTicketIds);
            Snackbar.Add(string.Format(L.T("batch.deleted"), deleted, failed), deleted > 0 ? Severity.Success : Severity.Error);
            _selectedTicketIds.Clear();
            await LoadTicketsAsync();
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isLoading = false; }
    }

    private void SelectAllVisible()
    {
        // Select every ticket currently rendered on the active page only.
        // Cross-page select-all is intentionally not offered — the user
        // would have no way to verify which tickets they're acting on.
        foreach (var t in PagedTickets) _selectedTicketIds.Add(t.Id);
        StateHasChanged();
    }

    // Batch endpoints are v2-only with no offline queue, so gate the bulk
    // actions on connectivity with a clear message instead of a raw failure.
    private bool EnsureOnline()
    {
        if (AppState.IsOnline) return true;
        Snackbar.Add(L.T("offline.action_unavailable"), Severity.Warning);
        return false;
    }

    private async Task BatchChangeStatusAsync(Status target)
    {
        if (_selectedTicketIds.Count == 0 || string.IsNullOrEmpty(target.Id)) return;
        if (!EnsureOnline()) return;
        _isLoading = true;
        try
        {
            var batch = _selectedTicketIds
                .Select(id => new Dictionary<string, object?> { ["id"] = id, ["status"] = target.Id })
                .ToList();
            var (updated, failed) = await ApiService.BatchUpdateTicketsAsync(batch);
            Snackbar.Add(string.Format(L.T("batch.status_changed"), updated, target.Name, failed),
                updated > 0 ? Severity.Success : Severity.Error);
            _selectedTicketIds.Clear();
            await LoadTicketsAsync();
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isLoading = false; }
    }

    private Task BatchAssignToMeAsync()
    {
        var userId = ApiService.CurrentUserId;
        if (string.IsNullOrEmpty(userId)) return Task.CompletedTask;
        return BatchAssignAsync(userId, L.T("tickets.assign_me"));
    }

    private Task BatchAssignToUserAsync(User user)
        => BatchAssignAsync(user.Id, string.IsNullOrWhiteSpace(user.Fullname) ? user.Username ?? string.Empty : user.Fullname);

    private async Task BatchAssignAsync(string userId, string displayName)
    {
        if (string.IsNullOrEmpty(userId) || _selectedTicketIds.Count == 0) return;
        if (!EnsureOnline()) return;
        _isLoading = true;
        try
        {
            var batch = _selectedTicketIds.Select(id => new Dictionary<string, object?> { ["id"] = id, ["assignee"] = userId }).ToList();
            var (updated, failed) = await ApiService.BatchUpdateTicketsAsync(batch);
            Snackbar.Add(string.Format(L.T("batch.assigned_to"), updated, displayName, failed),
                updated > 0 ? Severity.Success : Severity.Error);
            _selectedTicketIds.Clear();
            await LoadTicketsAsync();
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isLoading = false; }
    }

    // Saved Filters
    private async Task LoadSavedFiltersAsync()
    {
        try
        {
            var json = await LocalStorage.GetItemAsync("saved_filters");
            if (!string.IsNullOrEmpty(json))
                _savedFilters = JsonSerializer.Deserialize<List<SavedFilterItem>>(json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
        }
        catch { _savedFilters = []; }
    }

    private async Task SaveCurrentFilterAsync()
    {
        if (string.IsNullOrWhiteSpace(_saveFilterName)) return;
        _savedFilters.Add(new SavedFilterItem
        {
            Name = _saveFilterName.Trim(),
            Filter = _activeFilter,
            Sort = _activeSort,
            MyTickets = _showOnlyMyTickets,
            SearchText = _searchText
        });
        await PersistSavedFiltersAsync();
        _saveFilterName = string.Empty;
        _showSaveFilterDialog = false;
        Snackbar.Add(L.T("tickets.filter_saved"), Severity.Success);
    }

    private void ApplySavedFilter(SavedFilterItem f)
    {
        _activeFilter = f.Filter;
        _activeSort = f.Sort;
        _showOnlyMyTickets = f.MyTickets;
        _searchText = f.SearchText ?? string.Empty;
        ApplyFilters();
    }

    private async Task DeleteSavedFilterAsync(SavedFilterItem f)
    {
        _savedFilters.Remove(f);
        await PersistSavedFiltersAsync();
        Snackbar.Add(L.T("tickets.filter_deleted"), Severity.Info);
    }

    private async Task PersistSavedFiltersAsync()
    {
        await LocalStorage.SetItemAsync("saved_filters", JsonSerializer.Serialize(_savedFilters));
    }

    private async Task ExportCsvAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("UID;Subject;Status;Priority;Assignee;Group;Created;Updated");
        foreach (var t in _filteredTickets)
        {
            sb.AppendLine($"{t.Uid};\"{Escape(t.Subject)}\";\"{Escape(t.Status?.Name)}\";\"{Escape(t.Priority?.Name)}\";\"{Escape(t.Assignee?.Fullname)}\";\"{Escape(t.Group?.Name)}\";{t.Date:yyyy-MM-dd};{t.Updated:yyyy-MM-dd}");
        }
        var bytes = System.Text.Encoding.UTF8.GetPreamble().Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
        var base64 = Convert.ToBase64String(bytes);
        await JsRuntime.InvokeVoidAsync("pwaHelpers.downloadBase64", "text/csv", base64, "tickets-export.csv");
    }

    private static string Escape(string? s) => s?.Replace("\"", "\"\"") ?? "";

    private class SavedFilterItem
    {
        public string Name { get; set; } = string.Empty;
        public string Filter { get; set; } = "all";
        public string Sort { get; set; } = "date_desc";
        public bool MyTickets { get; set; }
        public string? SearchText { get; set; }
    }
}
