@page "/kanban"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@using System.Net.Http
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.RealtimeService Realtime
@inject THWTicketApp.Web.Services.LocalizationService L
@inject ISyncService SyncService
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject THWTicketApp.Web.Services.LocalStorageService LocalStorage
@implements IDisposable

<PageTitle>@L.T("nav.kanban") - THW Ticket App</PageTitle>

@* ─── Header + filters ───────────────────────────────────────────── *@
<div class="d-flex justify-space-between align-center mb-3 flex-wrap gap-2">
    <MudText Typo="Typo.h4">@L.T("nav.kanban")</MudText>
    <div class="d-flex align-center gap-2">
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadBoardAsync"
                       Disabled="_isLoading" aria-label="@L.T("common.refresh")" />
    </div>
</div>

<div class="d-flex align-center gap-2 mb-3 flex-wrap">
    <MudTextField @bind-Value="_searchText" @bind-Value:after="RecomputeFiltered"
                  Placeholder="@L.T("tickets.search")"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" DebounceInterval="200"
                  Clearable="true" Style="min-width: 220px; flex: 1; max-width: 400px;" />
    <MudChip T="string"
             Color="@(_onlyMine ? Color.Secondary : Color.Default)"
             Variant="Variant.Filled"
             Icon="@Icons.Material.Filled.PersonPin"
             OnClick="@ToggleOnlyMine">
        @L.T("tickets.mytickets")
    </MudChip>
    @if (_allPriorities.Any())
    {
        <MudSelect T="string" @bind-Value="_priorityFilter" Placeholder="@L.T("detail.priority")"
                   @bind-Value:after="RecomputeFiltered"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   Clearable="true" Style="min-width: 140px;">
            @foreach (var p in _allPriorities)
            {
                <MudSelectItem Value="@p">@p</MudSelectItem>
            }
        </MudSelect>
    }
    @if (_ticketTypes.Any())
    {
        @* Type filter — shows the per-type counts in the dropdown
           labels so users can see at a glance how many tickets are
           in each type. Selecting a type also collapses the board
           to only that type's allowed statuses (see _columns build
           in RecomputeFiltered). *@
        <MudSelect T="string" @bind-Value="_typeFilter" Placeholder="@L.T("detail.type")"
                   @bind-Value:after="RecomputeFiltered"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   Clearable="true" Style="min-width: 170px;">
            @foreach (var t in _ticketTypes)
            {
                var typeId = t.Id ?? "";
                var typeName = t.TranslatedName ?? t.Name ?? "?";
                var count = _typeCounts.TryGetValue(typeId, out var c) ? c : 0;
                <MudSelectItem Value="@typeId">@typeName (@count)</MudSelectItem>
            }
        </MudSelect>
    }
    @if (_myMembershipCount > 1)
    {
        @* Group filter — lets users board-view only one team's tickets
           (e.g. Jugend vs. Stab). Visibility is gated on the user's
           server-resolved group count from `/api/v2/login` (sessionUser),
           NOT on `_allGroups.Count`: `/api/v1/groups` returns every
           group to admins/agents and adds public groups to customer
           responses, which would always over-count. sessionUser already
           does the right thing — admins/agents get the Team → Department
           → Group chain, customers get their direct memberships. <=1
           means the dropdown has nothing meaningful to switch between. *@
        <MudSelect T="string" @bind-Value="_groupFilter" Placeholder="@L.T("detail.group")"
                   @bind-Value:after="OnGroupFilterChanged"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   Clearable="true" Style="min-width: 170px;">
            @foreach (var g in _allGroups)
            {
                var gid = g.Id ?? "";
                var gname = g.Name ?? "?";
                var count = _groupCounts.TryGetValue(gid, out var c) ? c : 0;
                <MudSelectItem Value="@gid">@gname (@count)</MudSelectItem>
            }
        </MudSelect>
    }
    <MudSpacer />
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        @_ticketItems.Count(MatchesFilter) / @_ticketItems.Count
    </MudText>
</div>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
}
else
{
    @* ─── Mobile: status tabs + single column of cards ────────────── *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <div role="region" aria-label="@L.T("kanban.board")">
            <MudTabs ActivePanelIndex="_mobileTabIndex"
                     ActivePanelIndexChanged="@((int i) => _mobileTabIndex = i)"
                     Rounded="true" Border="false" Elevation="0"
                     AlwaysShowScrollButtons="false" Color="Color.Primary">
                @foreach (var column in _columns)
                {
                    var col = column;
                    var visibleCount = FilteredItemsForColumn(col.StatusId).Count();
                    <MudTabPanel>
                        <TabContent>
                            <div class="d-flex align-center gap-2">
                                <span style="@($"width: 8px; height: 8px; border-radius: 50%; background: {col.StatusColor};")"></span>
                                <span>@col.StatusName</span>
                                @if (visibleCount > 0)
                                {
                                    <MudChip T="string" Size="Size.Small">@visibleCount</MudChip>
                                }
                            </div>
                        </TabContent>
                        <ChildContent>
                            @{ var items = FilteredItemsForColumn(col.StatusId).ToList(); }
                            @if (items.Count == 0)
                            {
                                <MudPaper Class="pa-4 my-2" Outlined="true"
                                          Style="border-style: dashed; text-align: center;">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @L.T("kanban.column_empty")
                                    </MudText>
                                </MudPaper>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-2 mt-2">
                                    @foreach (var item in items)
                                    {
                                        @CardContent(item, mobileLayout: true)
                                    }
                                </div>
                            }
                        </ChildContent>
                    </MudTabPanel>
                }
            </MudTabs>
        </div>
    </MudHidden>

    @* ─── Desktop: horizontal columns with drag-drop ───────────────── *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudDropContainer T="KanbanTicketItem" @ref="_dropContainer"
                          Items="_filteredItems"
                          ItemsSelector="@((item, zone) => item.StatusId == zone)"
                          ItemDropped="OnItemDropped"
                          Class="d-flex flex-row overflow-auto gap-3 pa-1"
                          Style="min-height: calc(100vh - 260px);"
                          role="region" aria-label="@L.T("kanban.board")">
                <ChildContent>
                    @foreach (var column in _columns)
                    {
                        var col = column;
                        var visibleCount = FilteredItemsForColumn(col.StatusId).Count();
                        var disabledForDrag = IsColumnDisabledForDrag(col.StatusId);
                        <MudPaper Class="@($"flex-shrink-0 rounded-lg d-flex flex-column kanban-column {(disabledForDrag ? "kanban-column-disabled" : "")}")"
                                  Style="width: 300px; background: var(--mud-palette-surface);"
                                  Elevation="1" role="group"
                                  aria-label="@($"{col.StatusName} — {visibleCount} {L.T("kanban.tickets")}")">
                            <div class="d-flex align-center pa-3 rounded-t-lg"
                                 style="@($"border-bottom: 3px solid {col.StatusColor};")">
                                <div style="@($"width: 4px; height: 24px; border-radius: 2px; background-color: {col.StatusColor};")"
                                     class="mr-2" aria-hidden="true"></div>
                                <MudText Typo="Typo.subtitle1" Class="flex-grow-1" Style="font-weight: 600;">
                                    @col.StatusName
                                </MudText>
                                <MudChip T="string" Size="Size.Small"
                                         Style="@($"background-color: {col.StatusColor}; color: white;")">
                                    @visibleCount
                                </MudChip>
                            </div>
                            <MudDropZone T="KanbanTicketItem" Identifier="@col.StatusId"
                                         CanDrop="@(item => IsStatusAllowedForItem(item, col.StatusId))"
                                         CanDropClass="kanban-zone-allowed"
                                         NoDropClass="kanban-zone-blocked"
                                         Class="pa-2" Style="min-height: 200px; flex: 1;"
                                         AllowReorder="true" />
                            @if (visibleCount == 0)
                            {
                                <div class="pa-3 ma-2 mt-0" style="border: 1px dashed var(--mud-palette-lines-default);
                                            border-radius: 6px; text-align: center; pointer-events: none;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @L.T("kanban.column_empty")
                                    </MudText>
                                </div>
                            }
                        </MudPaper>
                    }
                </ChildContent>
                <ItemRenderer>
                    <div @ondragstart="@(() => OnDragStart(context))"
                         @ondragend="ClearDragState">
                        @CardContent(context, mobileLayout: false)
                    </div>
                </ItemRenderer>
            </MudDropContainer>
    </MudHidden>
}

@* Card renderer reused for mobile + desktop. mobileLayout=true shows
   a "Status ändern" button instead of relying on drag-drop. *@
@code {
    private RenderFragment CardContent(KanbanTicketItem item, bool mobileLayout) => __builder =>
    {
        <MudPaper Class="pa-3 rounded kanban-card" Elevation="0" Outlined="true" tabindex="0"
                  role="link"
                  aria-label="@($"#{item.Uid} {item.Subject}")"
                  @onclick="@(() => Navigation.NavigateTo($"tickets/{item.Uid}"))"
                  @onkeydown="@(e => { if (e.Key == "Enter" || e.Key == " ") Navigation.NavigateTo($"tickets/{item.Uid}"); })">
            <div class="d-flex align-center gap-2 mb-1">
                <MudText Typo="Typo.caption" Color="Color.Secondary">#@item.Uid</MudText>
                @if (item.PriorityRef != null)
                {
                    <PriorityBadge Priority="item.PriorityRef" />
                }
            </div>
            <MudText Typo="Typo.body2" Style="font-weight: 600;" Class="mb-2">@item.Subject</MudText>
            @if (item.DueDate != DateTime.MinValue)
            {
                var overdue = item.DueDate < DateTime.Now && !item.StatusIsResolved;
                <MudText Typo="Typo.caption" Color="@(overdue ? Color.Error : Color.Secondary)" Class="mb-1 d-flex align-center"
                         Style="@(overdue ? "font-weight:600;" : null)">
                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-1" />
                    @item.DueDate.ToLocalDisplayString("dd.MM.yyyy")
                </MudText>
            }
            <div class="d-flex align-center gap-2">
                <UserAvatar Name="@item.AssigneeName" Size="Size.Small"
                            Style="width: 20px; height: 20px; font-size: 10px;" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="flex-grow-1"
                         Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(item.AssigneeName ?? L.T("detail.unassigned"))
                </MudText>
                @if (mobileLayout)
                {
                    <MudMenu Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Dense="true"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                             @onclick:stopPropagation="true"
                             aria-label="@L.T("kanban.move_to")">
                        @foreach (var target in _columns.Where(c => c.StatusId != item.StatusId
                                                                   && IsStatusAllowedForItem(item, c.StatusId)))
                        {
                            var t = target;
                            <MudMenuItem OnClick="@(() => MoveCardAsync(item, t.StatusId))">
                                <div class="d-flex align-center gap-2">
                                    <span style="@($"width:8px;height:8px;border-radius:50%;background:{t.StatusColor};")"></span>
                                    @t.StatusName
                                </div>
                            </MudMenuItem>
                        }
                    </MudMenu>
                }
            </div>
        </MudPaper>
    };
}

<style>
    .kanban-card {
        cursor: pointer;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .kanban-card:hover {
        border-color: var(--mud-palette-primary) !important;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }
    /* While a card is being dragged, columns whose status isn't allowed
       for that ticket's type fade out + block pointer events. */
    .kanban-column {
        transition: opacity 0.15s ease, filter 0.15s ease;
    }
    .kanban-column-disabled {
        opacity: 0.4;
        filter: grayscale(0.6);
        pointer-events: none;
    }
    /* Per-zone hover hints driven by MudDropZone's CanDrop callback. */
    .kanban-zone-allowed {
        background: rgba(76, 175, 80, 0.08);
    }
    .kanban-zone-blocked {
        background: rgba(244, 67, 54, 0.10);
        cursor: not-allowed;
    }
</style>

@code {
    private bool _isLoading;
    private string? _errorMessage;
    private List<KanbanColumn> _columns = [];
    private List<KanbanTicketItem> _ticketItems = [];
    private List<KanbanTicketItem> _filteredItems = [];
    private MudDropContainer<KanbanTicketItem>? _dropContainer;

    // Filters
    private string _searchText = string.Empty;
    private bool _onlyMine;
    private string? _priorityFilter;
    private string? _typeFilter;
    private string? _groupFilter;
    private List<string> _allPriorities = [];
    private List<TicketType> _ticketTypes = [];
    private List<Group> _allGroups = [];
    // Count of groups the current user can act on, resolved server-side
    // by trudesk's `accountsApi.sessionUser` (Team→Department chain for
    // admin/agent, direct Group.members for customer). Drives the group
    // filter's visibility — see the `@if` above the MudSelect.
    private int _myMembershipCount;
    private Dictionary<string, int> _typeCounts = new();
    private Dictionary<string, int> _groupCounts = new();
    private List<KanbanColumn> _allColumns = [];
    private int _mobileTabIndex;

    // Persist the group filter across sessions — once a Jugend user picks
    // their group, the board should keep showing only their tickets on
    // every visit instead of resetting to "everything" each reload.
    private const string GroupFilterStorageKey = "kanban_group_filter";

    // "Neu" is the trudesk-default initial status (Uid 0, isLocked=true).
    // Hidden from the Kanban on user request 2026-05-20 — it represents a
    // pre-triage state that doesn't belong on the active board.
    private static readonly HashSet<string> _hiddenStatusNames =
        new(StringComparer.OrdinalIgnoreCase) { "Neu", "New" };

    private CancellationTokenSource? _refreshDebounceCts;

    protected override async Task OnInitializedAsync()
    {
        // Restore the persisted group filter before LoadBoardAsync runs —
        // LoadBoardAsync clears it again if the saved id no longer matches
        // any group the user can see (e.g. they were removed from Jugend).
        _groupFilter = await LocalStorage.GetItemAsync(GroupFilterStorageKey);
        await LoadBoardAsync();
        Realtime.AnyTicketChanged += OnRealtimeChange;
    }

    private void OnRealtimeChange(string ticketId)
    {
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts = new CancellationTokenSource();
        var token = _refreshDebounceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                if (token.IsCancellationRequested) return;
                await LoadBoardAsync();
            }
            catch (TaskCanceledException) { }
        });
    }

    public void Dispose()
    {
        Realtime.AnyTicketChanged -= OnRealtimeChange;
        _refreshDebounceCts?.Cancel();
        _refreshDebounceCts?.Dispose();
    }

    private async Task LoadBoardAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var statusJson = await ApiService.GetStatusesAsync();
            var ticketJson = await ApiService.GetTicketsAsync();
            var typesJson = await ApiService.GetTicketTypesAsync();
            var groupsJson = await ApiService.GetGroupsAsync();

            var statuses = JsonHelper.DeserializeWrappedArray<Status>(statusJson, "status", options);
            var tickets = JsonHelper.DeserializeWrappedArray<Ticket>(ticketJson, "tickets", options);
            _ticketTypes = JsonSerializer.Deserialize<List<TicketType>>(typesJson, options) ?? [];
            var groupResp = JsonSerializer.Deserialize<GetGroupResponse>(groupsJson, options);
            _allGroups = (groupResp?.Groups ?? [])
                .Where(g => !string.IsNullOrEmpty(g.Id))
                .OrderBy(g => g.Name)
                .ToList();

            // Resolve the user's actionable group count via sessionUser
            // (Team → Department → Group chain for admin/agent, direct
            // memberships for customer). Hides the group filter when the
            // user has <=1 group to pick between — see the @if above.
            // GetCurrentUserProfileAsync returns null on failure; we
            // treat that as 0 (hide).
            try
            {
                var profile = await ApiService.GetCurrentUserProfileAsync();
                _myMembershipCount = profile?.Groups.Count ?? 0;
            }
            catch
            {
                _myMembershipCount = 0;
            }

            foreach (var t in tickets) TrudeskTranslationHelper.TranslateTicket(t);

            // Pre-filter the visible column set: drop the "Neu" status so
            // the pre-triage state doesn't take up board real estate.
            _allColumns = statuses
                .OrderBy(s => s.Order)
                .Where(s => !_hiddenStatusNames.Contains(s.Name ?? ""))
                .Select(s => new KanbanColumn
                {
                    StatusId = s.Id ?? string.Empty,
                    StatusName = TrudeskTranslationHelper.TranslateStatus(s.Name) ?? s.Name ?? L.T("common.unknown"),
                    StatusColor = s.HtmlColor ?? "#9E9E9E"
                }).ToList();

            _ticketItems = tickets.Select(t => new KanbanTicketItem
            {
                TicketId = t.Id ?? string.Empty,
                Uid = t.Uid,
                Subject = t.Subject ?? L.T("kanban.no_subject"),
                StatusId = t.Status?.Id ?? string.Empty,
                PriorityRef = t.Priority,
                PriorityName = t.Priority?.TranslatedName ?? t.Priority?.Name,
                PriorityColor = t.Priority?.HtmlColor ?? "#888",
                PrioritySortOrder = t.Priority?.OverdueIn ?? 0,
                AssigneeId = t.Assignee?.Id,
                AssigneeName = t.Assignee?.Fullname,
                AdditionalAssigneeIds = t.AdditionalAssignees
                    .Select(a => a.Id)
                    .Where(id => !string.IsNullOrEmpty(id))
                    .ToHashSet(),
                TypeId = t.Type?.Id,
                TypeName = t.Type?.TranslatedName ?? t.Type?.Name,
                GroupId = t.Group?.Id,
                GroupName = t.Group?.Name,
                AllowedStatusIds = t.Type?.Statuses is { Count: > 0 } st
                    ? new HashSet<string>(st.Select(x => x.Id ?? "").Where(id => id.Length > 0))
                    : [],
                DueDate = t.DueDate,
                StatusIsResolved = t.Status?.IsResolved == true
            })
            // Sort by priority urgency first, newest within the same priority.
            // `PrioritySortOrder` is trudesk's `priority.overdueIn` (minutes
            // until overdue) — LOWER values = MORE urgent. Tickets without a
            // resolved priority fall to the bottom (int.MaxValue), then by
            // descending Uid so the newest still surface first.
            .OrderBy(t => t.PrioritySortOrder > 0 ? t.PrioritySortOrder : int.MaxValue)
            .ThenByDescending(t => t.Uid)
            .ToList();

            _allPriorities = _ticketItems
                .Select(t => t.PriorityName)
                .Where(p => !string.IsNullOrEmpty(p))
                .Distinct()
                .Cast<string>()
                .OrderBy(p => p)
                .ToList();

            // Count tickets per type for the dropdown labels.
            _typeCounts = _ticketItems
                .Where(t => !string.IsNullOrEmpty(t.TypeId))
                .GroupBy(t => t.TypeId!)
                .ToDictionary(g => g.Key, g => g.Count());

            // Same per-group, used by the group filter dropdown.
            _groupCounts = _ticketItems
                .Where(t => !string.IsNullOrEmpty(t.GroupId))
                .GroupBy(t => t.GroupId!)
                .ToDictionary(g => g.Key, g => g.Count());

            // Drop the persisted filter if the user can no longer reach
            // the dropdown to clear it themselves — either because the
            // saved group is gone from the visible list (membership
            // change, group deleted) or because the dropdown is now
            // hidden entirely (`_myMembershipCount <= 1`). Otherwise
            // the board would stay silently scoped to one group with
            // no UI to undo it.
            if (!string.IsNullOrEmpty(_groupFilter) &&
                (_myMembershipCount <= 1 || !_allGroups.Any(g => g.Id == _groupFilter)))
            {
                _groupFilter = null;
                _ = LocalStorage.RemoveItemAsync(GroupFilterStorageKey);
            }

            RecomputeFiltered();
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            _errorMessage = message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ─── Filters ─────────────────────────────────────────────────────────

    private bool MatchesFilter(KanbanTicketItem item)
    {
        if (_onlyMine && item.AssigneeId != ApiService.CurrentUserId
            && !(ApiService.CurrentUserId is { } me && item.AdditionalAssigneeIds.Contains(me))) return false;
        if (!string.IsNullOrEmpty(_priorityFilter) && item.PriorityName != _priorityFilter) return false;
        if (!string.IsNullOrEmpty(_typeFilter) && item.TypeId != _typeFilter) return false;
        if (!string.IsNullOrEmpty(_groupFilter) && item.GroupId != _groupFilter) return false;
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var q = _searchText.Trim();
            if (!(item.Subject.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                  item.Uid.ToString().Contains(q)))
                return false;
        }
        return true;
    }

    private IEnumerable<KanbanTicketItem> FilteredItemsForColumn(string statusId)
        => _filteredItems.Where(t => t.StatusId == statusId);

    private void RecomputeFiltered()
    {
        _filteredItems = _ticketItems.Where(MatchesFilter).ToList();

        // If a type filter is active, collapse the column set to only the
        // statuses that type allows. Otherwise show every non-hidden status
        // (i.e. _allColumns, which already drops "Neu").
        if (!string.IsNullOrEmpty(_typeFilter))
        {
            var selectedType = _ticketTypes.FirstOrDefault(t => t.Id == _typeFilter);
            var allowed = selectedType?.Statuses is { Count: > 0 } st
                ? new HashSet<string>(st.Select(s => s.Id ?? "").Where(id => id.Length > 0))
                : null;
            _columns = allowed == null
                ? new List<KanbanColumn>(_allColumns)
                : _allColumns.Where(c => allowed.Contains(c.StatusId)).ToList();
        }
        else
        {
            _columns = new List<KanbanColumn>(_allColumns);
        }

        // Mobile tabs may now point past the end of the trimmed column list.
        if (_mobileTabIndex >= _columns.Count) _mobileTabIndex = 0;

        // Notify the MudDropContainer that its source list has changed,
        // otherwise it keeps showing the previous filter view.
        _dropContainer?.Refresh();
    }

    private void ToggleOnlyMine()
    {
        _onlyMine = !_onlyMine;
        RecomputeFiltered();
        StateHasChanged();
    }

    private async Task OnGroupFilterChanged()
    {
        if (string.IsNullOrEmpty(_groupFilter))
            await LocalStorage.RemoveItemAsync(GroupFilterStorageKey);
        else
            await LocalStorage.SetItemAsync(GroupFilterStorageKey, _groupFilter);
        RecomputeFiltered();
    }

    // Live re-filter as the user types or toggles select.
    protected override void OnParametersSet() => RecomputeFiltered();

    // ─── Drag-drop (desktop) + tap-menu (mobile) ────────────────────────

    private async Task OnItemDropped(MudItemDropInfo<KanbanTicketItem> dropInfo)
    {
        var draggedBefore = _draggedItem;
        ClearDragState();

        var item = dropInfo.Item;
        if (item == null) return;
        var newStatusId = dropInfo.DropzoneIdentifier;

        if (item.StatusId == newStatusId)
        {
            // Reorder within column — purely visual, no API change.
            _ticketItems.Remove(item);
            var zoneItems = _ticketItems.Where(t => t.StatusId == newStatusId).ToList();
            var insertIndex = Math.Min(dropInfo.IndexInZone, zoneItems.Count);
            var globalIndex = insertIndex < zoneItems.Count
                ? _ticketItems.IndexOf(zoneItems[insertIndex])
                : _ticketItems.Count;
            _ticketItems.Insert(globalIndex, item);
            RecomputeFiltered();
            return;
        }

        // Defensive: even though MudDropZone.CanDrop already blocks this
        // path on desktop, the keyboard/mobile fallback might bypass it.
        if (!IsStatusAllowedForItem(item, newStatusId))
        {
            var targetName = _columns.FirstOrDefault(c => c.StatusId == newStatusId)?.StatusName ?? "?";
            Snackbar.Add(string.Format(L.T("kanban.status_not_allowed"), targetName, item.TypeName ?? "?"),
                Severity.Warning);
            // Force a re-render so the optimistic UI snaps back.
            RecomputeFiltered();
            return;
        }

        await MoveCardAsync(item, newStatusId);
    }

    private bool IsStatusAllowedForItem(KanbanTicketItem item, string statusId)
        => item.AllowedStatusIds.Count == 0 || item.AllowedStatusIds.Contains(statusId);

    // Disabled-column visual state during drag: a column is disabled iff
    // there's a card currently being picked up AND that card's type does
    // not allow the column's status.
    private bool IsColumnDisabledForDrag(string statusId)
        => _draggedItem != null && !IsStatusAllowedForItem(_draggedItem, statusId);

    private KanbanTicketItem? _draggedItem;

    private void OnDragStart(KanbanTicketItem item)
    {
        _draggedItem = item;
        StateHasChanged();
    }

    private void ClearDragState()
    {
        if (_draggedItem == null) return;
        _draggedItem = null;
        StateHasChanged();
    }

    private async Task MoveCardAsync(KanbanTicketItem item, string newStatusId)
    {
        var oldStatusId = item.StatusId;
        item.StatusId = newStatusId;
        RecomputeFiltered();

        var ticketId = item.TicketId;
        var ticketUid = item.Uid;
        var targetName = _columns.FirstOrDefault(c => c.StatusId == newStatusId)?.StatusName ?? "?";

        // Offline: keep the optimistic swap, queue the status change, stay green.
        if (!AppState.IsOnline)
        {
            await SyncService.EnqueueStatusAsync(ticketId, ticketUid, newStatusId);
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
            return;
        }

        try
        {
            var success = await ApiService.UpdateTicketStatusAsync(ticketId, newStatusId);
            if (success)
            {
                Snackbar.Add($"#{item.Uid} → {targetName}", Severity.Success);
            }
            else
            {
                item.StatusId = oldStatusId;
                RecomputeFiltered();
                Snackbar.Add(L.T("kanban.move_failed"), Severity.Error);
            }
        }
        catch (HttpRequestException)
        {
            // Network dropped mid-move — keep optimistic swap, queue the change.
            await SyncService.EnqueueStatusAsync(ticketId, ticketUid, newStatusId);
            Snackbar.Add(L.T("offline.queued"), Severity.Info);
        }
        catch
        {
            item.StatusId = oldStatusId;
            RecomputeFiltered();
            Snackbar.Add(L.T("kanban.move_failed"), Severity.Error);
        }
    }

    // ─── DTOs ───────────────────────────────────────────────────────────

    private class KanbanColumn
    {
        public string StatusId { get; set; } = string.Empty;
        public string StatusName { get; set; } = string.Empty;
        public string StatusColor { get; set; } = "#9E9E9E";
    }

    private class KanbanTicketItem
    {
        public string TicketId { get; set; } = string.Empty;
        public int Uid { get; set; }
        public string Subject { get; set; } = string.Empty;
        public string StatusId { get; set; } = string.Empty;
        public Priority? PriorityRef { get; set; }
        public string? PriorityName { get; set; }
        public string PriorityColor { get; set; } = "#888";
        public int PrioritySortOrder { get; set; }
        public string? AssigneeId { get; set; }
        public string? AssigneeName { get; set; }
        public HashSet<string> AdditionalAssigneeIds { get; set; } = [];
        public string? TypeId { get; set; }
        public string? TypeName { get; set; }
        public string? GroupId { get; set; }
        public string? GroupName { get; set; }
        // Empty set = no per-type restriction → all statuses allowed.
        public HashSet<string> AllowedStatusIds { get; set; } = [];
        public DateTime DueDate { get; set; }
        public bool StatusIsResolved { get; set; }
    }
}
