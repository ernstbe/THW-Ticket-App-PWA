@page "/profile"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject THWTicketApp.Web.Services.LocalizationService L
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject IJSRuntime JsRuntime

<PageTitle>@L.T("profile.title") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("profile.title")</MudText>

<MudGrid>
    @* Profile Info *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("profile.info")</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (_isLoading)
                {
                    <MudSkeleton Width="100%" Height="56px" Class="mb-3" />
                    <MudSkeleton Width="100%" Height="56px" Class="mb-3" />
                    <MudSkeleton Width="100%" Height="56px" Class="mb-3" />
                    <MudSkeleton Width="100%" Height="56px" Class="mb-3" />
                }
                else
                {
                    <div class="d-flex flex-column align-center mb-4">
                        <UserAvatar Name="@_fullname" ImageUrl="@ApiService.BuildUserImageUrl(_avatarImage)"
                                    Size="Size.Large" Style="width:96px;height:96px;font-size:2rem;" Class="mb-2" />
                        <InputFile id="avatar-upload" OnChange="OnAvatarPicked" hidden
                                   accept=".png,.jpg,.jpeg,.gif,.webp" />
                        <MudButton HtmlTag="label" for="avatar-upload" Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PhotoCamera" Disabled="_isUploadingAvatar">
                            @(_isUploadingAvatar ? L.T("profile.avatar_uploading") : L.T("profile.avatar_pick"))
                        </MudButton>
                    </div>

                    <MudTextField @bind-Value="_fullname" Label="@L.T("profile.fullname")"
                                  Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_jobTitle" Label="@L.T("profile.job_title")"
                                  Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_workNumber" Label="@L.T("profile.work_number")"
                                  Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_mobileNumber" Label="@L.T("profile.mobile_number")"
                                  Variant="Variant.Outlined" Class="mb-3" />

                    <MudTextField Value="@(_username ?? string.Empty)" Label="@L.T("profile.username")"
                                  Variant="Variant.Outlined" ReadOnly="true" Class="mb-3" />
                    @if (!string.IsNullOrEmpty(_email))
                    {
                        <MudTextField Value="@_email" Label="@L.T("profile.email")"
                                      Variant="Variant.Outlined" ReadOnly="true" Class="mb-3" />
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="SaveProfileAsync" Disabled="_isSaving"
                               StartIcon="@Icons.Material.Filled.Save">
                        @L.T("common.save")
                    </MudButton>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Active Sessions (PR #52 backend, multi-device tokens) *@
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@L.T("profile.sessions_title")</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@L.T("profile.sessions_subtitle")</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                   OnClick="LoadSessionsAsync" Disabled="_sessionsLoading"
                                   aria-label="@L.T("common.refresh")" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (_sessionsLoading)
                {
                    <MudSkeleton Width="100%" Height="48px" Class="mb-2" />
                    <MudSkeleton Width="100%" Height="48px" Class="mb-2" />
                }
                else if (_sessions.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@L.T("profile.sessions_empty")</MudText>
                }
                else
                {
                    <MudList T="SessionInfo" Dense="true">
                        @foreach (var s in _sessions)
                        {
                            <MudListItem T="SessionInfo" Value="s">
                                <div class="d-flex align-center gap-3" style="width:100%;">
                                    <MudIcon Icon="@SessionIcon(s)" Color="@(s.IsCurrent ? Color.Primary : Color.Default)" />
                                    <div class="flex-grow-1">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">
                                            @SessionLabel(s)
                                            @if (s.IsCurrent)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">
                                                    @L.T("profile.sessions_current")
                                                </MudChip>
                                            }
                                            @if (s.IsLegacy)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-2">
                                                    @L.T("profile.sessions_legacy")
                                                </MudChip>
                                            }
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            @SessionMeta(s)
                                        </MudText>
                                    </div>
                                    @if (!s.IsCurrent && !s.IsLegacy && !string.IsNullOrEmpty(s.DeviceId))
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RevokeSessionAsync(s.DeviceId!))"
                                                       Disabled="_sessionRevoking"
                                                       aria-label="@L.T("profile.sessions_revoke")" />
                                    }
                                </div>
                            </MudListItem>
                        }
                    </MudList>

                    @if (_sessions.Count(s => !s.IsCurrent) > 0)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Class="mt-3"
                                   StartIcon="@Icons.Material.Filled.RemoveCircle"
                                   OnClick="RevokeAllOtherSessionsAsync" Disabled="_sessionRevoking">
                            @L.T("profile.sessions_revoke_others")
                        </MudButton>
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Change Password *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("profile.change_password")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_currentPassword" Label="@L.T("profile.current_password")"
                              Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-3" />
                <MudTextField @bind-Value="_newPassword" Label="@L.T("profile.new_password")"
                              Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-3" />
                <MudTextField @bind-Value="_confirmPassword" Label="@L.T("profile.confirm_password")"
                              Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-3" />

                @if (!string.IsNullOrEmpty(_passwordError))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_passwordError</MudAlert>
                }

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="ChangePasswordAsync" Disabled="_isSaving"
                           StartIcon="@Icons.Material.Filled.Lock">
                    @L.T("profile.update_password")
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* DSGVO data export (Art. 15) *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@L.T("profile.my_data_title")</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@L.T("profile.my_data_subtitle")</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="ExportMyDataAsync"
                           Disabled="@(_isExporting || !AppState.IsOnline)">
                    @L.T("profile.export_data")
                </MudButton>
                @if (!AppState.IsOnline)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-2">
                        @L.T("profile.export_offline")
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _fullname = string.Empty;
    private string _jobTitle = string.Empty;
    private string _workNumber = string.Empty;
    private string _mobileNumber = string.Empty;
    private string? _username;
    private string? _email;
    private string? _avatarImage;
    private bool _isUploadingAvatar;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _passwordError = string.Empty;
    private bool _isSaving;
    private bool _isLoading = true;
    private bool _isExporting;

    private List<SessionInfo> _sessions = new();
    private bool _sessionsLoading = true;
    private bool _sessionRevoking;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
        await LoadSessionsAsync();
    }

    private async Task LoadSessionsAsync()
    {
        _sessionsLoading = true;
        StateHasChanged();
        try
        {
            _sessions = await ApiService.GetSessionsAsync();
            // Current session first, then by last used descending.
            _sessions = _sessions
                .OrderByDescending(s => s.IsCurrent)
                .ThenByDescending(s => s.LastUsedAt ?? DateTime.MinValue)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sessionsLoading = false;
            StateHasChanged();
        }
    }

    private async Task RevokeSessionAsync(string deviceId)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L.T("profile.sessions_revoke_title") },
            { x => x.Message, L.T("profile.sessions_revoke_confirm") },
            { x => x.ConfirmText, L.T("profile.sessions_revoke") },
            { x => x.CancelText, L.T("common.cancel") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        _sessionRevoking = true;
        try
        {
            var ok = await ApiService.RevokeSessionAsync(deviceId);
            if (ok)
            {
                Snackbar.Add(L.T("profile.sessions_revoked"), Severity.Success);
                await LoadSessionsAsync();
            }
            else
            {
                Snackbar.Add(L.T("profile.sessions_revoke_failed"), Severity.Error);
            }
        }
        finally { _sessionRevoking = false; }
    }

    private async Task RevokeAllOtherSessionsAsync()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L.T("profile.sessions_revoke_others_title") },
            { x => x.Message, L.T("profile.sessions_revoke_others_confirm") },
            { x => x.ConfirmText, L.T("profile.sessions_revoke_others") },
            { x => x.CancelText, L.T("common.cancel") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        _sessionRevoking = true;
        try
        {
            var ok = await ApiService.RevokeAllOtherSessionsAsync();
            if (ok)
            {
                Snackbar.Add(L.T("profile.sessions_revoked"), Severity.Success);
                await LoadSessionsAsync();
            }
            else
            {
                Snackbar.Add(L.T("profile.sessions_revoke_failed"), Severity.Error);
            }
        }
        finally { _sessionRevoking = false; }
    }

    private string SessionIcon(SessionInfo s)
    {
        var ua = s.UserAgent?.ToLowerInvariant() ?? string.Empty;
        if (ua.Contains("mobile") || ua.Contains("android") || ua.Contains("iphone"))
            return Icons.Material.Filled.PhoneIphone;
        if (ua.Contains("ipad") || ua.Contains("tablet"))
            return Icons.Material.Filled.Tablet;
        if (string.IsNullOrEmpty(s.UserAgent))
            return Icons.Material.Filled.QuestionMark;
        return Icons.Material.Filled.Computer;
    }

    private string SessionLabel(SessionInfo s)
    {
        if (s.IsLegacy) return L.T("profile.sessions_legacy_label");
        if (!string.IsNullOrEmpty(s.UserAgent))
        {
            // First ~60 chars of the UA — enough to distinguish Chrome on Win
            // from Safari on iPhone without dumping a wall of vendor string.
            var ua = s.UserAgent;
            return ua.Length > 60 ? ua.Substring(0, 60) + "…" : ua;
        }
        return s.DeviceId ?? L.T("profile.sessions_unknown_device");
    }

    private string SessionMeta(SessionInfo s)
    {
        var parts = new List<string>();
        if (s.LastUsedAt.HasValue)
            parts.Add($"{L.T("profile.sessions_last_seen")}: {FormatRelative(s.LastUsedAt.Value)}");
        if (s.CreatedAt.HasValue)
            parts.Add($"{L.T("profile.sessions_created")}: {s.CreatedAt.Value.ToLocalTime():yyyy-MM-dd}");
        return parts.Count == 0 ? string.Empty : string.Join(" · ", parts);
    }

    // Instance (not static) so it can use the injected LocalizationService —
    // a static method can't reach L, which is why this used to be hardcoded
    // English and ignored the language switch (same fix as Dashboard).
    private string FormatRelative(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return L.T("time.just_now");
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} {L.T("time.minutes_ago")}";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} {L.T("time.hours_ago")}";
        return $"{(int)diff.TotalDays} {L.T("time.days_ago")}";
    }

    private async Task LoadProfileAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            // Fetch the actual profile from the server. The cached
            // ApiService.CurrentUsername only contains the display name and
            // is missing job title, phone numbers, email — which is why the
            // form used to look empty after saving (the save round-trip
            // worked, the load never happened).
            var profile = await ApiService.GetCurrentUserProfileAsync();
            if (profile != null)
            {
                _fullname = profile.Fullname ?? string.Empty;
                _jobTitle = profile.Title ?? string.Empty;
                _workNumber = profile.WorkNumber ?? string.Empty;
                _mobileNumber = profile.MobileNumber ?? string.Empty;
                _username = profile.Username;
                _email = profile.Email;
                _avatarImage = profile.Image;
            }
            else
            {
                // Fall back to the cached values so the form isn't blank.
                _fullname = ApiService.CurrentUsername ?? string.Empty;
                _username = ApiService.CurrentUsername;
                Snackbar.Add(L.T("profile.load_failed"), Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_fullname)) return;
        _isSaving = true;
        try
        {
            if (await ApiService.UpdateProfileAsync(_fullname, _jobTitle, _workNumber, _mobileNumber))
            {
                Snackbar.Add(L.T("profile.saved"), Severity.Success);
                // Re-fetch from the server to confirm what actually got
                // persisted — and to catch any server-side normalization
                // (e.g. phone number formatting).
                await LoadProfileAsync();
            }
            else
            {
                Snackbar.Add(L.T("detail.update_failed"), Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error); }
        finally { _isSaving = false; }
    }

    // 5 MB pre-resize ceiling — matches the server cap; the server downscales
    // to a 512px JPEG, so the stored avatar lands far below this.
    private const long MaxAvatarBytes = 5 * 1024 * 1024;

    private async Task OnAvatarPicked(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        if (!AppState.IsOnline)
        {
            Snackbar.Add(L.T("profile.avatar_offline"), Severity.Info);
            return;
        }
        if (file.Size > MaxAvatarBytes)
        {
            Snackbar.Add(L.T("profile.avatar_too_large"), Severity.Warning);
            return;
        }
        _isUploadingAvatar = true;
        try
        {
            using var stream = file.OpenReadStream(MaxAvatarBytes);
            var newImage = await ApiService.UploadProfileImageAsync(stream, file.Name);
            if (!string.IsNullOrEmpty(newImage))
            {
                _avatarImage = newImage;
                Snackbar.Add(L.T("profile.avatar_saved"), Severity.Success);
            }
            else Snackbar.Add(L.T("profile.avatar_failed"), Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error); }
        finally { _isUploadingAvatar = false; }
    }

    private async Task ExportMyDataAsync()
    {
        if (!AppState.IsOnline)
        {
            Snackbar.Add(L.T("profile.export_offline"), Severity.Warning);
            return;
        }

        _isExporting = true;
        try
        {
            var json = await ApiService.ExportMyDataAsync();
            if (string.IsNullOrEmpty(json))
            {
                Snackbar.Add(L.T("profile.export_failed"), Severity.Error);
                return;
            }

            // Same CSP-safe download path as Reports/Settings: base64 data
            // URL via the named pwa-helpers function — no eval.
            var filename = $"datenexport-{_username ?? "benutzer"}-{DateTime.Now:yyyy-MM-dd}.json";
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
            await JsRuntime.InvokeVoidAsync("pwaHelpers.downloadBase64", "application/json", base64, filename);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
        finally { _isExporting = false; }
    }

    private async Task ChangePasswordAsync()
    {
        _passwordError = string.Empty;

        if (string.IsNullOrWhiteSpace(_currentPassword) || string.IsNullOrWhiteSpace(_newPassword))
        {
            _passwordError = L.T("profile.password_required");
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _passwordError = L.T("profile.password_mismatch");
            return;
        }
        if (_newPassword.Length < 6)
        {
            _passwordError = L.T("profile.password_too_short");
            return;
        }

        _isSaving = true;
        try
        {
            if (await ApiService.UpdatePasswordAsync(_currentPassword, _newPassword, _confirmPassword))
            {
                Snackbar.Add(L.T("profile.password_changed"), Severity.Success);
                _currentPassword = _newPassword = _confirmPassword = string.Empty;
            }
            else
            {
                _passwordError = L.T("profile.password_failed");
            }
        }
        catch (Exception ex) { _passwordError = $"{L.T("common.error")}: {ex.Message}"; }
        finally { _isSaving = false; }
    }
}
