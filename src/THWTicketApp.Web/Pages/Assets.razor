@page "/assets"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject THWTicketApp.Web.Services.LocalizationService L

<PageTitle>@L.T("nav.assets") - THW Ticket App</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L.T("nav.assets")</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowCreateDialog">@L.T("assets.new")</MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadAssetsAsync" Disabled="_isLoading"
                       aria-label="@L.T("common.refresh")" />
    </div>
</div>

@if (_isLoading && _assets.Length == 0)
{
    <MudTable Items="@(new int[3])" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true" Class="mb-4">
        <HeaderContent>
            <MudTh>@L.T("assets.name")</MudTh>
            <MudTh>@L.T("assets.tag")</MudTh>
            <MudTh>@L.T("assets.category")</MudTh>
            <MudTh>@L.T("assets.location")</MudTh>
            <MudTh>@L.T("common.edit")</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudSkeleton Width="80%" /></MudTd>
            <MudTd><MudSkeleton Width="60%" /></MudTd>
            <MudTd><MudSkeleton Width="50%" /></MudTd>
            <MudTd><MudSkeleton Width="50%" /></MudTd>
            <MudTd><MudSkeleton Width="60px" /></MudTd>
        </RowTemplate>
    </MudTable>
}
else if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<MudTextField @bind-Value="_searchText" Placeholder="@L.T("common.search")"
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" Margin="Margin.Dense" Class="mb-4" />

<MudTable Items="FilteredAssets" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
    <HeaderContent>
        <MudTh>@L.T("assets.name")</MudTh>
        <MudTh>@L.T("assets.tag")</MudTh>
        <MudTh>@L.T("assets.category")</MudTh>
        <MudTh>@L.T("assets.location")</MudTh>
        <MudTh>@L.T("common.edit")</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L.T("assets.name")">@context.Name</MudTd>
        <MudTd DataLabel="@L.T("assets.tag")">
            <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.AssetTag</MudChip>
        </MudTd>
        <MudTd DataLabel="@L.T("assets.category")">@context.Category</MudTd>
        <MudTd DataLabel="@L.T("assets.location")">@context.Location</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Link" Size="Size.Small" Color="Color.Primary"
                           OnClick="() => ShowLinkTicketDialog(context)"
                           aria-label="@L.T("assets.link_ticket")"
                           data-testid="link-ticket-btn" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="() => ShowEditDialog(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="() => DeleteAssetAsync(context)" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Color="Color.Secondary">@L.T("assets.none")</MudText>
    </NoRecordsContent>
</MudTable>

@* Link to Ticket Dialog *@
<MudDialog @bind-Visible="_linkDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">@L.T("assets.link_ticket")</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">@(_linkTargetAsset?.Name)</MudText>
        <MudTextField @bind-Value="_linkTicketUid" Label="@L.T("assets.link_ticket_prompt")"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ConfirmationNumber"
                      OnKeyDown="OnLinkTicketKeyDown"
                      Disabled="_linkProcessing"
                      data-testid="link-ticket-input" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _linkDialogVisible = false" Disabled="_linkProcessing">@L.T("common.cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="LinkAssetToTicketAsync" Disabled="_linkProcessing"
                   data-testid="link-ticket-confirm">
            @if (_linkProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L.T("assets.link_ticket")
        </MudButton>
    </DialogActions>
</MudDialog>

@* Create / Edit Dialog *@
<MudDialog @bind-Visible="_dialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingAsset == null ? L.T("assets.new") : L.T("common.edit"))</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_formName" Label="@L.T("assets.name")" Class="mb-2" />
        <MudTextField @bind-Value="_formTag" Label="@L.T("assets.tag")" Class="mb-2" />
        <MudTextField @bind-Value="_formCategory" Label="@L.T("assets.category")" Class="mb-2" />
        <MudTextField @bind-Value="_formLocation" Label="@L.T("assets.location")" Class="mb-2" />
        <MudTextField @bind-Value="_formDescription" Label="@L.T("detail.description")" Lines="3" Class="mb-2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogVisible = false">@L.T("common.cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAssetAsync">@L.T("common.save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _isLoading;
    private Asset[] _assets = [];
    private string _searchText = string.Empty;
    private bool _dialogVisible;
    private Asset? _editingAsset;
    private string _formName = string.Empty;
    private string _formTag = string.Empty;
    private string _formCategory = string.Empty;
    private string _formLocation = string.Empty;
    private string _formDescription = string.Empty;

    private bool _linkDialogVisible;
    private bool _linkProcessing;
    private Asset? _linkTargetAsset;
    private string _linkTicketUid = string.Empty;

    private IEnumerable<Asset> FilteredAssets => string.IsNullOrWhiteSpace(_searchText)
        ? _assets
        : _assets.Where(a =>
            (a.Name?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true) ||
            (a.AssetTag?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true) ||
            (a.Category?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true) ||
            (a.Location?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true));

    protected override async Task OnInitializedAsync() => await LoadAssetsAsync();

    private async Task LoadAssetsAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        StateHasChanged();
        try
        {
            var json = await ApiService.GetAssetsAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            _assets = JsonHelper.DeserializeWrappedArray<Asset>(json, "assets", options);
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            Snackbar.Add(message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowCreateDialog()
    {
        _editingAsset = null;
        _formName = _formTag = _formCategory = _formLocation = _formDescription = string.Empty;
        _dialogVisible = true;
    }

    private void ShowEditDialog(Asset asset)
    {
        _editingAsset = asset;
        _formName = asset.Name ?? string.Empty;
        _formTag = asset.AssetTag ?? string.Empty;
        _formCategory = asset.Category ?? string.Empty;
        _formLocation = asset.Location ?? string.Empty;
        _formDescription = asset.Description ?? string.Empty;
        _dialogVisible = true;
    }

    private async Task SaveAssetAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add(L.T("assets.name_required"), Severity.Warning);
            return;
        }

        var data = new Dictionary<string, object?>
        {
            ["name"] = _formName,
            ["assetTag"] = _formTag,
            ["category"] = _formCategory,
            ["location"] = _formLocation,
            ["description"] = _formDescription
        };

        bool success;
        if (_editingAsset != null)
            success = await ApiService.UpdateAssetAsync(_editingAsset.Id, data);
        else
            success = await ApiService.CreateAssetAsync(data);

        if (success)
        {
            _dialogVisible = false;
            Snackbar.Add(L.T("common.success"), Severity.Success);
            await LoadAssetsAsync();
        }
        else
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }

    internal void ShowLinkTicketDialog(Asset asset)
    {
        _linkTargetAsset = asset;
        _linkTicketUid = string.Empty;
        _linkDialogVisible = true;
    }

    private async Task OnLinkTicketKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_linkProcessing)
            await LinkAssetToTicketAsync();
    }

    internal async Task LinkAssetToTicketAsync()
    {
        if (_linkTargetAsset == null) return;
        _linkProcessing = true;
        try
        {
            var outcome = await TryLinkAssetAsync(ApiService, _linkTargetAsset, _linkTicketUid);
            switch (outcome)
            {
                case LinkTicketOutcome.EmptyUid:
                    Snackbar.Add(L.T("assets.link_ticket_empty"), Severity.Warning);
                    break;
                case LinkTicketOutcome.Success:
                    _linkDialogVisible = false;
                    Snackbar.Add(L.T("assets.link_ticket_success"), Severity.Success);
                    break;
                case LinkTicketOutcome.Failed:
                    Snackbar.Add(L.T("assets.link_ticket_failed"), Severity.Error);
                    break;
            }
        }
        finally
        {
            _linkProcessing = false;
        }
    }

    internal enum LinkTicketOutcome { EmptyUid, Success, Failed }

    internal static async Task<LinkTicketOutcome> TryLinkAssetAsync(ITrueDeskApiService api, Asset asset, string? rawUid)
    {
        var uid = rawUid?.Trim();
        if (string.IsNullOrWhiteSpace(uid))
            return LinkTicketOutcome.EmptyUid;
        try
        {
            return await api.LinkAssetToTicketAsync(asset.Id, uid) ? LinkTicketOutcome.Success : LinkTicketOutcome.Failed;
        }
        catch
        {
            return LinkTicketOutcome.Failed;
        }
    }

    private async Task DeleteAssetAsync(Asset asset)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L.T("common.delete") },
            { x => x.Message, L.T("assets.delete_confirm") },
            { x => x.ConfirmText, L.T("common.delete") },
            { x => x.CancelText, L.T("common.cancel") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        if (await ApiService.DeleteAssetAsync(asset.Id))
        {
            Snackbar.Add(L.T("common.success"), Severity.Success);
            await LoadAssetsAsync();
        }
        else
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }
}
