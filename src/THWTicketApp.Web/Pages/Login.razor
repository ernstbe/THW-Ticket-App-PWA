@page "/login"
@layout THWTicketApp.Web.Layout.LoginLayout
@using MudBlazor
@using Microsoft.JSInterop
@inject THWTicketApp.Shared.Services.ITrueDeskApiService ApiService
@inject THWTicketApp.Shared.Services.AppSettings AppSettings
@inject THWTicketApp.Web.Services.AuthStateProvider AuthStateProvider
@inject THWTicketApp.Web.Services.AppSettingsInitializer SettingsInit
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime
@inject THWTicketApp.Web.Services.LocalizationService L
@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudCard Elevation="4" Class="pa-8 mx-auto" Style="width: 100%; max-width: 420px;">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex flex-column align-center">
                    <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-2">THW</MudText>
                    <MudText Typo="Typo.h5">Ticket App</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @* Passkey Login Button *@
            @if (_passkeyAvailable)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           OnClick="@LoginWithPasskeyAsync" Disabled="@_isLoading" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Fingerprint" Class="mb-4">
                    @L.T("login.passkey")
                </MudButton>
                <div class="d-flex align-center gap-2 mb-4">
                    <MudDivider />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("common.or")</MudText>
                    <MudDivider />
                </div>
            }

            @if (!_serverConfigured)
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    @L.T("login.configure_server")
                </MudAlert>
            }

            <MudExpansionPanels Class="mb-4" Elevation="0">
                <MudExpansionPanel Text="@L.T("login.server_config")" Expanded="@(!_serverConfigured)"
                                   Style="background: transparent;">
                    <MudTextField @bind-Value="_serverUrl" Label="@L.T("login.server_url")"
                                  Placeholder="https://trudesk.example.com/api/v2"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Dns"
                                  Disabled="@_isLoading" Class="mb-2" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               OnClick="SaveServerUrlAsync" FullWidth="true">
                        @L.T("login.save_url")
                    </MudButton>
                </MudExpansionPanel>
            </MudExpansionPanels>

            <MudForm @ref="_form">
                <MudTextField @bind-Value="_username" Label="@L.T("login.username")" Variant="Variant.Outlined"
                              Required="true" RequiredError="@L.T("login.username_required")"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                              Disabled="@(_isLoading || !_serverConfigured)" Class="mb-4"
                              OnKeyDown="@OnKeyDown" />
                <MudTextField @bind-Value="_password" Label="@L.T("login.password")" Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Required="true" RequiredError="@L.T("login.password_required")"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                              Disabled="@(_isLoading || !_serverConfigured)"
                              OnKeyDown="@OnKeyDown" />
            </MudForm>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
            }
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column px-6 pb-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="@LoginAsync" Disabled="@(_isLoading || !_serverConfigured)" Size="Size.Large">
                @if (_isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">@L.T("login.submitting")</MudText>
                }
                else
                {
                    <MudText>@L.T("login.submit")</MudText>
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private MudForm _form = null!;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _serverUrl = string.Empty;
    private string? _errorMessage;
    private bool _isLoading;
    private bool _passkeyAvailable;
    private bool _serverConfigured;
    private IJSObjectReference? _webauthnModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SettingsInit.InitializeAsync();
            _serverUrl = AppSettings.ApiBaseUrl;
            _serverConfigured = AppSettings.IsConfigured;
            StateHasChanged();

            try
            {
                _webauthnModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/webauthn-interop.js");
                var supported = await _webauthnModule.InvokeAsync<bool>("isWebAuthnSupported");
                if (supported)
                {
                    _passkeyAvailable = await _webauthnModule.InvokeAsync<bool>("isPasskeyRegistered");
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task SaveServerUrlAsync()
    {
        if (string.IsNullOrWhiteSpace(_serverUrl))
        {
            _errorMessage = L.T("login.invalid_url");
            return;
        }
        await SettingsInit.SaveApiUrlAsync(_serverUrl);
        _serverConfigured = AppSettings.IsConfigured;
        _errorMessage = null;
        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoginAsync();
    }

    private async Task LoginAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var success = await ApiService.AuthenticateAsync(_username, _password);
            if (success)
            {
                AuthStateProvider.NotifyAuthStateChanged();
                Navigation.NavigateTo("./");
            }
            else
            {
                _errorMessage = L.T("login.failed");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"{L.T("login.connection_error")}: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoginWithPasskeyAsync()
    {
        if (_webauthnModule == null) return;
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await _webauthnModule.InvokeAsync<PasskeyAuthResult?>("authenticatePasskey");
            if (result != null && !string.IsNullOrEmpty(result.UserId))
            {
                // Passkey authentication succeeded - try to restore the stored session
                var restored = await ApiService.TryRestoreSessionAsync();
                if (restored)
                {
                    AuthStateProvider.NotifyAuthStateChanged();
                    Navigation.NavigateTo("./");
                    return;
                }
            }
            _errorMessage = L.T("login.passkey_failed");
        }
        catch
        {
            _errorMessage = L.T("login.passkey_cancelled");
        }
        finally
        {
            _isLoading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_webauthnModule != null)
            await _webauthnModule.DisposeAsync();
    }

    private class PasskeyAuthResult
    {
        public string? UserId { get; set; }
        public string? UserName { get; set; }
        public string? CredentialId { get; set; }
    }
}
