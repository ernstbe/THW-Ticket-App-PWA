@page "/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using THWTicketApp.Shared.Services
@using Microsoft.JSInterop
@inject ITrueDeskApiService ApiService
@inject AppSettings AppSettings
@inject LocalStorageService LocalStorage
@inject LocalizationService L
@inject BrowserNotificationService BrowserNotifications
@inject AuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject HttpClient HttpClient
@inject IJSRuntime JsRuntime
@inject IIndexedDbService IndexedDb
@inject IdleLockService IdleLock
@inject OnboardingService Onboarding
@implements IAsyncDisposable

<PageTitle>@L.T("settings.title") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("settings.title")</MudText>

<MudGrid>
    @* Appearance *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.appearance")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText>@L.T("settings.darkmode")</MudText>
                    <MudSwitch @bind-Value="_isDarkMode" Color="Color.Primary" T="bool" />
                </div>

                <MudDivider Class="mb-3" />

                <div class="d-flex justify-space-between align-center mb-2">
                    <div>
                        <MudText>@L.T("settings.notifications")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @L.T("settings.notifications_desc")
                        </MudText>
                    </div>
                    <MudSwitch @bind-Value="_isNotificationsEnabled" Color="Color.Primary" T="bool" />
                </div>

                @if (_isNotificationsEnabled)
                {
                    <div class="ml-4">
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@L.T("settings.notify_new")</MudText>
                            <MudSwitch @bind-Value="_notifyOnNewTickets" Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@L.T("settings.notify_comments")</MudText>
                            <MudSwitch @bind-Value="_notifyOnComments" Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@L.T("settings.notify_status")</MudText>
                            <MudSwitch @bind-Value="_notifyOnStatusChanges" Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <div>
                                <MudText Typo="Typo.body2">@L.T("settings.notify_mine")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @L.T("settings.notify_mine_desc")
                                </MudText>
                            </div>
                            <MudSwitch @bind-Value="_notifyOnlyMyTickets" Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center">
                            <div>
                                <MudText Typo="Typo.body2">@L.T("settings.notify_highprio")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @L.T("settings.notify_highprio_desc")
                                </MudText>
                            </div>
                            <MudSwitch @bind-Value="_notifyOnlyHighPriority" Color="Color.Primary" T="bool" />
                        </div>
                    </div>
                }

                <MudDivider Class="my-3" />

                <MudSelect T="string" @bind-Value="_selectedLanguage" Label="@L.T("settings.language")"
                           Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem Value="@("de")">Deutsch</MudSelectItem>
                    <MudSelectItem Value="@("en")">English</MudSelectItem>
                </MudSelect>

                <MudDivider Class="my-3" />

                <MudText Class="mb-2">@L.T("settings.theme_color")</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var color in _themeColors)
                    {
                        var c = color;
                        <MudIconButton Icon="@(_selectedColor == c.Value ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Circle)"
                                       Style="@($"color: {c.Value};")"
                                       Size="Size.Large"
                                       OnClick="@(() => _selectedColor = c.Value)"
                                       aria-label="@c.Name" />
                    }
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* API Configuration *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.api")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_apiBaseUrl" Label="@L.T("settings.api_url")"
                              Placeholder="http://localhost:8118/api/v1"
                              Variant="Variant.Outlined" Class="mb-3" />

                <MudNumericField @bind-Value="_connectionTimeout" Label="@L.T("settings.timeout")"
                                 Min="5" Max="300" Variant="Variant.Outlined" Class="mb-3" T="int" />

                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           OnClick="TestConnectionAsync" Disabled="_isTesting"
                           StartIcon="@Icons.Material.Filled.NetworkCheck">
                    @(_isTesting ? L.T("settings.testing") : L.T("settings.test_connection"))
                </MudButton>

                @if (!string.IsNullOrEmpty(_connectionStatus))
                {
                    <MudAlert Severity="@_connectionSeverity" Class="mt-3" Dense="true">
                        @_connectionStatus
                    </MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Passkey / Biometrics *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.passkey")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    @L.T("settings.passkey_desc")
                </MudText>

                @if (!_webauthnSupported)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @L.T("settings.passkey_not_supported")
                    </MudAlert>
                }
                else if (_passkeyRegistered)
                {
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Success" />
                        <MudText Color="Color.Success">@L.T("settings.passkey_registered")</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   OnClick="RemovePasskeyAsync">
                            @L.T("settings.passkey_remove")
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Fingerprint"
                               OnClick="RegisterPasskeyAsync">
                        @L.T("settings.passkey_register")
                    </MudButton>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Auto-Lock *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.idlelock")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    @L.T("settings.idlelock_desc")
                </MudText>

                @if (!_passkeyRegistered)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        @L.T("settings.idlelock_needs_passkey")
                    </MudAlert>
                }

                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText>@L.T("settings.idlelock_enable")</MudText>
                    <MudSwitch @bind-Value="_idleLockEnabled" Color="Color.Primary" T="bool"
                               Disabled="@(!_passkeyRegistered)" />
                </div>

                <MudSelect T="int" @bind-Value="_idleLockMinutes" Label="@L.T("settings.idlelock_timeout")"
                           Variant="Variant.Outlined" Dense="true"
                           Disabled="@(!_idleLockEnabled || !_passkeyRegistered)">
                    <MudSelectItem Value="5">5 Min</MudSelectItem>
                    <MudSelectItem Value="10">10 Min</MudSelectItem>
                    <MudSelectItem Value="15">15 Min</MudSelectItem>
                    <MudSelectItem Value="30">30 Min</MudSelectItem>
                    <MudSelectItem Value="60">60 Min</MudSelectItem>
                </MudSelect>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Cache *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.cache")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center mb-3">
                    <div>
                        <MudText>@L.T("settings.cache_enable")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @L.T("settings.cache_desc")
                        </MudText>
                    </div>
                    <MudSwitch @bind-Value="_isOfflineCacheEnabled" Color="Color.Primary" T="bool" />
                </div>

                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           OnClick="ClearCacheAsync"
                           StartIcon="@Icons.Material.Filled.DeleteSweep">
                    @L.T("settings.cache_clear")
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Sync Log *@
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@L.T("settings.synclog")</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadSyncLogAsync"
                                   aria-label="@L.T("common.refresh")" />
                    <MudIconButton Icon="@Icons.Material.Filled.FileDownload" OnClick="ExportSyncLogAsync"
                                   Disabled="!_syncLogEntries.Any()"
                                   aria-label="@L.T("settings.synclog_export")" />
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearSyncLogAsync"
                                   Disabled="!_syncLogEntries.Any()" Color="Color.Error"
                                   aria-label="@L.T("settings.synclog_clear")" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    @L.T("settings.synclog_desc")
                </MudText>

                @if (_loadingSyncLog)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (!_syncLogEntries.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L.T("settings.synclog_empty")</MudText>
                }
                else
                {
                    <MudTable Items="_syncLogEntries" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                              FixedHeader="true" Height="300px">
                        <HeaderContent>
                            <MudTh>@L.T("settings.synclog_time")</MudTh>
                            <MudTh>@L.T("settings.synclog_level")</MudTh>
                            <MudTh>@L.T("settings.synclog_action")</MudTh>
                            <MudTh>@L.T("settings.synclog_message")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@L.T("settings.synclog_time")">
                                <MudText Typo="Typo.caption">@FormatTimestamp(context.Timestamp)</MudText>
                            </MudTd>
                            <MudTd DataLabel="@L.T("settings.synclog_level")">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetLevelColor(context.Level)">
                                    @context.Level
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="@L.T("settings.synclog_action")">
                                @(context.ActionType ?? "—")
                            </MudTd>
                            <MudTd DataLabel="@L.T("settings.synclog_message")">
                                @context.Message
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* About *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardContent>
                <div class="d-flex align-center gap-4 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Size="Size.Large"
                             Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.h6" Color="Color.Primary">THW Ticket App</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Technisches Hilfswerk</MudText>
                    </div>
                </div>
                <MudDivider Class="mb-3" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Version: 1.0.0 (PWA)</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<div class="d-flex gap-3 mt-4 mb-6 flex-wrap">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettingsAsync"
               StartIcon="@Icons.Material.Filled.Save">
        @L.T("common.save")
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => Onboarding.ShowNow())"
               StartIcon="@Icons.Material.Filled.HelpOutline">
        @L.T("settings.show_onboarding")
    </MudButton>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="LogoutAsync"
               StartIcon="@Icons.Material.Filled.Logout">
        @L.T("common.logout")
    </MudButton>
</div>

@code {
    private bool _isDarkMode;
    private bool _isNotificationsEnabled;
    private bool _notifyOnNewTickets = true;
    private bool _notifyOnComments = true;
    private bool _notifyOnStatusChanges = true;
    private bool _notifyOnlyMyTickets;
    private bool _notifyOnlyHighPriority;
    private string _selectedLanguage = "de";
    private string _selectedColor = "#003399";

    private static readonly (string Name, string Value)[] _themeColors =
    [
        ("THW Blau", "#003399"),
        ("Dunkelblau", "#1A237E"),
        ("Indigo", "#3F51B5"),
        ("Petrol", "#00695C"),
        ("Grün", "#2E7D32"),
        ("Rot", "#C62828"),
        ("Orange", "#E65100"),
        ("Lila", "#6A1B9A"),
        ("Grau", "#455A64"),
    ];
    private string _apiBaseUrl = string.Empty;
    private int _connectionTimeout = 30;
    private bool _isOfflineCacheEnabled;
    private bool _isTesting;
    private string _connectionStatus = string.Empty;
    private Severity _connectionSeverity = Severity.Info;

    // Passkey
    private IJSObjectReference? _webauthnModule;
    private bool _webauthnSupported;
    private bool _passkeyRegistered;

    // Auto-Lock
    private bool _idleLockEnabled;
    private int _idleLockMinutes = IdleLockService.DefaultMinutes;

    // Sync Log
    private List<SyncLogDto> _syncLogEntries = new();
    private bool _loadingSyncLog;

    protected override async Task OnInitializedAsync()
    {
        _apiBaseUrl = AppSettings.ApiBaseUrl;
        _connectionTimeout = AppSettings.ConnectionTimeoutSeconds;

        _isDarkMode = await GetBoolSetting("settings_darkmode", false);
        _isNotificationsEnabled = await GetBoolSetting("settings_notifications", false);
        _notifyOnNewTickets = await GetBoolSetting("settings_notify_new", true);
        _notifyOnComments = await GetBoolSetting("settings_notify_comments", true);
        _notifyOnStatusChanges = await GetBoolSetting("settings_notify_status", true);
        _notifyOnlyMyTickets = await GetBoolSetting("settings_notify_only_mine", false);
        _notifyOnlyHighPriority = await GetBoolSetting("settings_notify_high_prio", false);
        _isOfflineCacheEnabled = await GetBoolSetting("settings_offline_cache", false);
        _selectedLanguage = await LocalStorage.GetItemAsync("settings_language") ?? "de";
        _selectedColor = await LocalStorage.GetItemAsync("settings_primary_color") ?? "#003399";

        var savedUrl = await LocalStorage.GetItemAsync("settings_apiurl");
        if (!string.IsNullOrEmpty(savedUrl)) _apiBaseUrl = savedUrl;

        var savedTimeout = await LocalStorage.GetItemAsync("settings_timeout");
        if (int.TryParse(savedTimeout, out var t)) _connectionTimeout = t;

        // Auto-Lock settings come from the IdleLockService (it owns the
        // localStorage keys + valid-range logic).
        await IdleLock.LoadSettingsAsync();
        _idleLockEnabled = IdleLock.Enabled;
        _idleLockMinutes = IdleLock.TimeoutMinutes;

        await LoadSyncLogAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _webauthnModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/webauthn-interop.js");
                _webauthnSupported = await _webauthnModule.InvokeAsync<bool>("isWebAuthnSupported");
                if (_webauthnSupported)
                    _passkeyRegistered = await _webauthnModule.InvokeAsync<bool>("isPasskeyRegistered");
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task<bool> GetBoolSetting(string key, bool defaultValue)
    {
        var val = await LocalStorage.GetItemAsync(key);
        return val != null ? val == "true" : defaultValue;
    }

    private async Task SaveSettingsAsync()
    {
        if (_connectionTimeout < 5 || _connectionTimeout > 300)
        {
            Snackbar.Add(L.T("settings.timeout_invalid"), Severity.Warning);
            return;
        }

        AppSettings.ApiBaseUrl = _apiBaseUrl;
        AppSettings.ConnectionTimeoutSeconds = _connectionTimeout;

        await LocalStorage.SetItemAsync("settings_apiurl", _apiBaseUrl);
        await LocalStorage.SetItemAsync("settings_timeout", _connectionTimeout.ToString());
        await LocalStorage.SetItemAsync("settings_darkmode", _isDarkMode.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notifications", _isNotificationsEnabled.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_new", _notifyOnNewTickets.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_comments", _notifyOnComments.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_status", _notifyOnStatusChanges.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_only_mine", _notifyOnlyMyTickets.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_high_prio", _notifyOnlyHighPriority.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_offline_cache", _isOfflineCacheEnabled.ToString().ToLower());

        // Update language via service
        await L.SetLanguageAsync(_selectedLanguage);

        // Update theme color
        await LocalStorage.SetItemAsync("settings_primary_color", _selectedColor);

        // Request notification permission if enabled
        if (_isNotificationsEnabled)
            await BrowserNotifications.RequestPermissionAsync();

        // Persist auto-lock preference. Service applies the new timeout
        // (or stops the watcher) live, no reload needed.
        await IdleLock.SaveSettingsAsync(_idleLockEnabled && _passkeyRegistered, _idleLockMinutes);

        Snackbar.Add(L.T("settings.saved"), Severity.Success);
    }

    private async Task RegisterPasskeyAsync()
    {
        if (_webauthnModule == null) return;
        try
        {
            var userId = ApiService.CurrentUserId ?? "unknown";
            var userName = ApiService.CurrentUsername ?? "user";
            var credentialId = await _webauthnModule.InvokeAsync<string?>("registerPasskey", userId, userName);
            if (!string.IsNullOrEmpty(credentialId))
            {
                _passkeyRegistered = true;
                Snackbar.Add(L.T("settings.passkey_registered"), Severity.Success);
            }
            else
            {
                Snackbar.Add(L.T("settings.passkey_register_failed"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemovePasskeyAsync()
    {
        if (_webauthnModule == null) return;
        await _webauthnModule.InvokeAsync<bool>("removePasskey");
        _passkeyRegistered = false;
        // Auto-lock without a passkey is a one-way trip to the login screen —
        // disable it implicitly when the passkey is gone.
        if (_idleLockEnabled)
        {
            _idleLockEnabled = false;
            await IdleLock.SaveSettingsAsync(false, _idleLockMinutes);
        }
        Snackbar.Add(L.T("settings.passkey_removed"), Severity.Info);
    }

    private async Task TestConnectionAsync()
    {
        _isTesting = true;
        _connectionStatus = L.T("settings.connection_testing");
        _connectionSeverity = Severity.Info;
        StateHasChanged();

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            var testUrl = _apiBaseUrl.TrimEnd('/');
            var response = await HttpClient.GetAsync(testUrl, cts.Token);

            if (response.IsSuccessStatusCode)
            {
                _connectionStatus = L.T("settings.connection_success");
                _connectionSeverity = Severity.Success;
            }
            else
            {
                _connectionStatus = $"{L.T("common.error")}: {(int)response.StatusCode} {response.ReasonPhrase}";
                _connectionSeverity = Severity.Error;
            }
        }
        catch (TaskCanceledException)
        {
            _connectionStatus = L.T("settings.connection_timeout");
            _connectionSeverity = Severity.Warning;
        }
        catch (HttpRequestException)
        {
            _connectionStatus = L.T("settings.connection_failed");
            _connectionSeverity = Severity.Error;
        }
        catch (Exception ex)
        {
            _connectionStatus = $"{L.T("common.error")}: {ex.Message}";
            _connectionSeverity = Severity.Error;
        }
        finally
        {
            _isTesting = false;
            StateHasChanged();
        }
    }

    private async Task ClearCacheAsync()
    {
        await LocalStorage.RemoveItemAsync("ticket_cache");
        Snackbar.Add(L.T("settings.cache_cleared"), Severity.Success);
    }

    private async Task LogoutAsync()
    {
        await ApiService.LogoutAsync();
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("login");
    }

    // -----------------------------------------------------------------
    // Sync Log
    // -----------------------------------------------------------------

    private async Task LoadSyncLogAsync()
    {
        _loadingSyncLog = true;
        try
        {
            var json = await IndexedDb.GetSyncLogAsync(200);
            _syncLogEntries = System.Text.Json.JsonSerializer.Deserialize<List<SyncLogDto>>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch { _syncLogEntries = new(); }
        finally { _loadingSyncLog = false; }
    }

    private async Task ExportSyncLogAsync()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_syncLogEntries,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JsRuntime.InvokeVoidAsync("eval",
            $"const a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='sync-log.json';a.click()");
    }

    private async Task ClearSyncLogAsync()
    {
        await IndexedDb.ClearSyncLogAsync();
        _syncLogEntries = new();
        Snackbar.Add(L.T("settings.synclog_cleared"), Severity.Success);
    }

    internal static string FormatTimestamp(string iso)
    {
        if (DateTime.TryParse(iso, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        return iso;
    }

    internal static Color GetLevelColor(string level) => level switch
    {
        "error" => Color.Error,
        "warn" => Color.Warning,
        _ => Color.Default
    };

    internal sealed class SyncLogDto
    {
        public string Timestamp { get; set; } = string.Empty;
        public string Level { get; set; } = string.Empty;
        public int? ActionId { get; set; }
        public string? ActionType { get; set; }
        public string? TicketId { get; set; }
        public string Message { get; set; } = string.Empty;
        public string? Exception { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_webauthnModule != null)
            await _webauthnModule.DisposeAsync();
    }
}
