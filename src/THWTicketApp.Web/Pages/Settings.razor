@page "/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using THWTicketApp.Shared.Services
@using Microsoft.JSInterop
@inject ITrueDeskApiService ApiService
@inject AppSettings AppSettings
@inject LocalStorageService LocalStorage
@inject LocalizationService L
@inject BrowserNotificationService BrowserNotifications
@inject AuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject HttpClient HttpClient
@inject IJSRuntime JsRuntime
@inject IIndexedDbService IndexedDb
@inject IdleLockService IdleLock
@inject OnboardingService Onboarding
@inject WhatsNewService WhatsNew
@inject ISyncService SyncService
@inject WebPushService WebPush
@implements IAsyncDisposable

<PageTitle>@L.T("settings.title") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("settings.title")</MudText>

<MudAlert Severity="Severity.Info" Dense="true" Class="mb-3" Variant="Variant.Outlined">
    <MudText Typo="Typo.caption">@L.T("settings.autosave_hint")</MudText>
</MudAlert>

@* CSS-column masonry instead of a flex MudGrid — short cards (Passkey,
   Sync-Konflikte, About) used to leave huge empty space under them when
   paired with a taller neighbour. With column-count cards pack
   vertically, so each column ends up roughly the same height. *@
<div class="settings-masonry">
    @* Appearance — auto-saves on every change *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.appearance")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText>@L.T("settings.darkmode")</MudText>
                    <MudSwitch Value="@_isDarkMode" ValueChanged="@(async (bool v) => await SetDarkModeAsync(v))"
                               Color="Color.Primary" T="bool" />
                </div>

                <MudDivider Class="my-3" />

                <MudSelect T="string" Value="@_selectedLanguage"
                           ValueChanged="@(async (string v) => await SetLanguageAsync(v))"
                           Label="@L.T("settings.language")"
                           Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem Value="@("de")">Deutsch</MudSelectItem>
                    <MudSelectItem Value="@("en")">English</MudSelectItem>
                </MudSelect>

                <MudDivider Class="my-3" />

                <MudText Class="mb-2">@L.T("settings.theme_color")</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var color in _themeColors)
                    {
                        var c = color;
                        <MudIconButton Icon="@(_selectedColor == c.Value ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Circle)"
                                       Style="@($"color: {c.Value};")"
                                       Size="Size.Large"
                                       OnClick="@(async () => await SetThemeColorAsync(c.Value))"
                                       aria-label="@c.Name" />
                    }
                </div>
            </MudCardContent>
        </MudCard>
    </div>

    @* Notifications — split out so it can grow without crowding Appearance *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.notifications")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center mb-2">
                    <div>
                        <MudText>@L.T("settings.notifications_enable")</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @L.T("settings.notifications_desc")
                        </MudText>
                    </div>
                    <MudSwitch Value="@_isNotificationsEnabled"
                               ValueChanged="@(async (bool v) => await SetNotificationsEnabledAsync(v))"
                               Color="Color.Primary" T="bool" />
                </div>
                @* Web Push (separate from local-tab notifications) — sub-toggle
                   that only matters when the master notifications switch is on.
                   When off, the local-tab Notification API still works while
                   the tab is open; Web Push adds delivery while the tab is
                   closed or backgrounded. *@
                @if (_isNotificationsEnabled && _webPushSupported)
                {
                    <div class="d-flex justify-space-between align-center mb-2 ml-4">
                        <div>
                            <MudText Typo="Typo.body2">@L.T("settings.push_enable")</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @L.T("settings.push_desc")
                            </MudText>
                        </div>
                        <MudSwitch Value="@_webPushEnabled"
                                   ValueChanged="@(async (bool v) => await SetWebPushAsync(v))"
                                   Disabled="@_webPushBusy"
                                   Color="Color.Primary" T="bool" />
                    </div>
                }
                @if (_isNotificationsEnabled)
                {
                    <div class="ml-4">
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@L.T("settings.notify_new")</MudText>
                            <MudSwitch Value="@_notifyOnNewTickets"
                                       ValueChanged="@(async (bool v) => await AutoSaveBoolAsync("settings_notify_new", v, x => _notifyOnNewTickets = x))"
                                       Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@L.T("settings.notify_comments")</MudText>
                            <MudSwitch Value="@_notifyOnComments"
                                       ValueChanged="@(async (bool v) => await AutoSaveBoolAsync("settings_notify_comments", v, x => _notifyOnComments = x))"
                                       Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@L.T("settings.notify_status")</MudText>
                            <MudSwitch Value="@_notifyOnStatusChanges"
                                       ValueChanged="@(async (bool v) => await AutoSaveBoolAsync("settings_notify_status", v, x => _notifyOnStatusChanges = x))"
                                       Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <div>
                                <MudText Typo="Typo.body2">@L.T("settings.notify_mine")</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @L.T("settings.notify_mine_desc")
                                </MudText>
                            </div>
                            <MudSwitch Value="@_notifyOnlyMyTickets"
                                       ValueChanged="@(async (bool v) => await AutoSaveBoolAsync("settings_notify_only_mine", v, x => _notifyOnlyMyTickets = x))"
                                       Color="Color.Primary" T="bool" />
                        </div>
                        <div class="d-flex justify-space-between align-center">
                            <div>
                                <MudText Typo="Typo.body2">@L.T("settings.notify_highprio")</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @L.T("settings.notify_highprio_desc")
                                </MudText>
                            </div>
                            <MudSwitch Value="@_notifyOnlyHighPriority"
                                       ValueChanged="@(async (bool v) => await AutoSaveBoolAsync("settings_notify_high_prio", v, x => _notifyOnlyHighPriority = x))"
                                       Color="Color.Primary" T="bool" />
                        </div>
                    </div>
                }
            </MudCardContent>
        </MudCard>
    </div>

    @* API Configuration — hidden behind an "Erweitert" expander so normal
       users can't accidentally break the app by editing the URL. *@
    <div class="settings-cell">
        <MudExpansionPanels Elevation="0">
            <MudExpansionPanel Text="@L.T("settings.advanced")"
                               Style="background: transparent; border: 1px solid var(--mud-palette-lines-default); border-radius: 4px;">
                <MudCard Elevation="0">
                    <MudCardContent>
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                            @L.T("settings.advanced_warning")
                        </MudAlert>
                        <MudTextField @bind-Value="_apiBaseUrl" Label="@L.T("settings.api_url")"
                                      Placeholder="http://localhost:8118/api/v1"
                                      Variant="Variant.Outlined" Class="mb-3" />
                        <MudNumericField @bind-Value="_connectionTimeout" Label="@L.T("settings.timeout")"
                                         Min="5" Max="300" Variant="Variant.Outlined" Class="mb-3" T="int" />
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       OnClick="TestConnectionAsync" Disabled="_isTesting"
                                       StartIcon="@Icons.Material.Filled.NetworkCheck">
                                @(_isTesting ? L.T("settings.testing") : L.T("settings.test_connection"))
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="SaveAdvancedAsync"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @L.T("common.save")
                            </MudButton>
                        </div>
                        @if (!string.IsNullOrEmpty(_connectionStatus))
                        {
                            <MudAlert Severity="@_connectionSeverity" Class="mt-3" Dense="true">
                                @_connectionStatus
                            </MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </div>

    @* Passkey / Biometrics *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.passkey")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                    @L.T("settings.passkey_desc")
                </MudText>

                @if (!_webauthnSupported)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @L.T("settings.passkey_not_supported")
                    </MudAlert>
                }
                else if (_passkeyRegistered)
                {
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Success" />
                        <MudText Color="Color.Success">@L.T("settings.passkey_registered")</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   OnClick="RemovePasskeyAsync">
                            @L.T("settings.passkey_remove")
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Fingerprint"
                               OnClick="RegisterPasskeyAsync">
                        @L.T("settings.passkey_register")
                    </MudButton>
                }
            </MudCardContent>
        </MudCard>
    </div>

    @* Auto-Lock *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.idlelock")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                    @L.T("settings.idlelock_desc")
                </MudText>

                @if (!_passkeyRegistered)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        @L.T("settings.idlelock_needs_passkey")
                    </MudAlert>
                }

                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText>@L.T("settings.idlelock_enable")</MudText>
                    <MudSwitch @bind-Value="_idleLockEnabled" @bind-Value:after="SaveIdleLockAsync"
                               Color="Color.Primary" T="bool"
                               Disabled="@(!_passkeyRegistered)" />
                </div>

                <MudSelect T="int" @bind-Value="_idleLockMinutes" @bind-Value:after="SaveIdleLockAsync"
                           Label="@L.T("settings.idlelock_timeout")"
                           Variant="Variant.Outlined" Dense="true"
                           Disabled="@(!_idleLockEnabled || !_passkeyRegistered)">
                    <MudSelectItem Value="5">5 Min</MudSelectItem>
                    <MudSelectItem Value="10">10 Min</MudSelectItem>
                    <MudSelectItem Value="15">15 Min</MudSelectItem>
                    <MudSelectItem Value="30">30 Min</MudSelectItem>
                    <MudSelectItem Value="60">60 Min</MudSelectItem>
                </MudSelect>
            </MudCardContent>
        </MudCard>
    </div>

    @* Cache *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.cache")</MudText>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center mb-3">
                    <div>
                        <MudText>@L.T("settings.cache_enable")</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @L.T("settings.cache_desc")
                        </MudText>
                    </div>
                    <MudSwitch Value="@_isOfflineCacheEnabled"
                               ValueChanged="@(async (bool v) => await AutoSaveBoolAsync("settings_offline_cache", v, x => _isOfflineCacheEnabled = x))"
                               Color="Color.Primary" T="bool" />
                </div>

                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           OnClick="ClearCacheAsync"
                           StartIcon="@Icons.Material.Filled.DeleteSweep">
                    @L.T("settings.cache_clear")
                </MudButton>
            </MudCardContent>
        </MudCard>
    </div>

    @* Sync Log *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@L.T("settings.synclog")</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadSyncLogAsync"
                                   aria-label="@L.T("common.refresh")" />
                    <MudIconButton Icon="@Icons.Material.Filled.FileDownload" OnClick="ExportSyncLogAsync"
                                   Disabled="!_syncLogEntries.Any()"
                                   aria-label="@L.T("settings.synclog_export")" />
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearSyncLogAsync"
                                   Disabled="!_syncLogEntries.Any()" Color="Color.Error"
                                   aria-label="@L.T("settings.synclog_clear")" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                    @L.T("settings.synclog_desc")
                </MudText>

                @if (_loadingSyncLog)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (!_syncLogEntries.Any())
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@L.T("settings.synclog_empty")</MudText>
                }
                else
                {
                    <MudTable Items="_syncLogEntries" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                              FixedHeader="true" Height="300px">
                        <HeaderContent>
                            <MudTh>@L.T("settings.synclog_time")</MudTh>
                            <MudTh>@L.T("settings.synclog_level")</MudTh>
                            <MudTh>@L.T("settings.synclog_action")</MudTh>
                            <MudTh>@L.T("settings.synclog_message")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@L.T("settings.synclog_time")">
                                <MudText Typo="Typo.caption">@FormatTimestamp(context.Timestamp)</MudText>
                            </MudTd>
                            <MudTd DataLabel="@L.T("settings.synclog_level")">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetLevelColor(context.Level)">
                                    @context.Level
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="@L.T("settings.synclog_action")">
                                @(context.ActionType ?? "—")
                            </MudTd>
                            <MudTd DataLabel="@L.T("settings.synclog_message")">
                                @context.Message
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudCardContent>
        </MudCard>
    </div>

    @* Sync conflicts — surface the conflict count + a deep-link to the
       full resolution page so users notice unresolved offline writes
       without keeping the entry in the main nav. *@
    <div class="settings-cell">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.T("settings.sync")</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (_conflictCount == 0)
                {
                    <MudAlert Severity="Severity.Success" Dense="true">@L.T("sync.no_conflicts")</MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        @string.Format(L.T("sync.conflicts_found"), _conflictCount)
                    </MudAlert>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.SyncProblem"
                               OnClick="@(() => Navigation.NavigateTo("sync-conflicts"))">
                        @L.T("settings.sync_resolve")
                    </MudButton>
                }
            </MudCardContent>
        </MudCard>
    </div>

    @* About *@
    <div class="settings-cell">
        <MudCard>
            <MudCardContent>
                <div class="d-flex align-center gap-4 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Size="Size.Large"
                             Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.h6" Color="Color.Primary">THW Ticket App</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Technisches Hilfswerk</MudText>
                    </div>
                </div>
                <MudDivider Class="mb-3" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Version: @_appVersion
                </MudText>
                @if (!string.IsNullOrEmpty(_appBuiltAt))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Build: @_appBuiltAt
                    </MudText>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.SystemUpdate"
                           OnClick="CheckForUpdatesAsync"
                           Disabled="_updateChecking"
                           Class="mt-3">
                    @(_updateChecking ? L.T("settings.update_checking") : L.T("settings.update_check"))
                </MudButton>
            </MudCardContent>
        </MudCard>
    </div>
</div>

@* Helper actions — non-destructive *@
<div class="d-flex gap-3 mt-4 flex-wrap">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => Onboarding.ShowNow())"
               StartIcon="@Icons.Material.Filled.HelpOutline">
        @L.T("settings.show_onboarding")
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => WhatsNew.ShowAll())"
               StartIcon="@Icons.Material.Filled.Campaign">
        @L.T("settings.show_whatsnew")
    </MudButton>
</div>

@* Danger zone — visually separated from the rest with extra margin
   and a red-bordered card so Logout can't be accidentally tapped
   from the same gesture that toggled a switch. *@
<MudPaper Elevation="0" Class="pa-4 mt-8 mb-6"
          Style="border: 1px solid var(--mud-palette-error); border-radius: 8px; background: rgba(244,67,54,0.04);">
    <div class="d-flex justify-space-between align-center flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.subtitle2" Color="Color.Error">@L.T("settings.danger_zone")</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@L.T("settings.logout_hint")</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="LogoutAsync"
                   StartIcon="@Icons.Material.Filled.Logout">
            @L.T("common.logout")
        </MudButton>
    </div>
</MudPaper>

@code {
    private bool _isDarkMode;
    private bool _isNotificationsEnabled;
    private bool _notifyOnNewTickets = true;
    private bool _notifyOnComments = true;
    private bool _notifyOnStatusChanges = true;
    private bool _notifyOnlyMyTickets;
    private bool _notifyOnlyHighPriority;
    private string _selectedLanguage = "de";
    private string _selectedColor = "#003399";

    private static readonly (string Name, string Value)[] _themeColors =
    [
        ("THW Blau", "#003399"),
        ("Dunkelblau", "#1A237E"),
        ("Indigo", "#3F51B5"),
        ("Petrol", "#00695C"),
        ("Grün", "#2E7D32"),
        ("Rot", "#C62828"),
        ("Orange", "#E65100"),
        ("Lila", "#6A1B9A"),
        ("Grau", "#455A64"),
    ];
    private string _apiBaseUrl = string.Empty;
    private int _connectionTimeout = 30;
    private bool _isOfflineCacheEnabled;
    private bool _isTesting;
    private string _connectionStatus = string.Empty;
    private Severity _connectionSeverity = Severity.Info;

    // Passkey
    private IJSObjectReference? _webauthnModule;
    private bool _webauthnSupported;
    private bool _passkeyRegistered;

    // Auto-Lock
    private bool _idleLockEnabled;
    private int _idleLockMinutes = IdleLockService.DefaultMinutes;

    // Sync Log
    private List<SyncLogDto> _syncLogEntries = new();
    private bool _loadingSyncLog;

    // Sync conflicts — pulled once on init; the user pops into
    // /sync-conflicts to act on them.
    private int _conflictCount;

    // Web Push state — `_webPushSupported` is checked once after first
    // render so the sub-toggle only appears in browsers that can
    // actually subscribe; `_webPushEnabled` reflects whether the
    // PushManager has a live subscription right now.
    private bool _webPushSupported;
    private bool _webPushEnabled;
    private bool _webPushBusy;

    // App version info — fetched from version.json baked in at Docker build.
    private string _appVersion = "dev";
    private string _appBuiltAt = string.Empty;
    private bool _updateChecking;

    protected override async Task OnInitializedAsync()
    {
        _apiBaseUrl = AppSettings.ApiBaseUrl;
        _connectionTimeout = AppSettings.ConnectionTimeoutSeconds;
        await LoadAppVersionAsync();

        _isDarkMode = await GetBoolSetting("settings_darkmode", false);
        _isNotificationsEnabled = await GetBoolSetting("settings_notifications", false);
        _notifyOnNewTickets = await GetBoolSetting("settings_notify_new", true);
        _notifyOnComments = await GetBoolSetting("settings_notify_comments", true);
        _notifyOnStatusChanges = await GetBoolSetting("settings_notify_status", true);
        _notifyOnlyMyTickets = await GetBoolSetting("settings_notify_only_mine", false);
        _notifyOnlyHighPriority = await GetBoolSetting("settings_notify_high_prio", false);
        _isOfflineCacheEnabled = await GetBoolSetting("settings_offline_cache", false);
        _selectedLanguage = await LocalStorage.GetItemAsync("settings_language") ?? "de";
        _selectedColor = await LocalStorage.GetItemAsync("settings_primary_color") ?? "#003399";

        var savedUrl = await LocalStorage.GetItemAsync("settings_apiurl");
        if (!string.IsNullOrEmpty(savedUrl)) _apiBaseUrl = savedUrl;

        var savedTimeout = await LocalStorage.GetItemAsync("settings_timeout");
        if (int.TryParse(savedTimeout, out var t)) _connectionTimeout = t;

        // Auto-Lock settings come from the IdleLockService (it owns the
        // localStorage keys + valid-range logic).
        await IdleLock.LoadSettingsAsync();
        _idleLockEnabled = IdleLock.Enabled;
        _idleLockMinutes = IdleLock.TimeoutMinutes;

        await LoadSyncLogAsync();
        await LoadConflictCountAsync();

        // Keep the sync-conflicts card honest: refresh the count when
        // the SyncService detects a fresh conflict, and when the pending
        // queue changes (resolving or discarding a conflict on the
        // /sync-conflicts page reduces the count and we want that
        // reflected here if the user navigates back).
        SyncService.ConflictDetected += OnConflictDetected;
        SyncService.PendingCountChanged += OnPendingCountChanged;
    }

    private void OnConflictDetected(THWTicketApp.Shared.Data.PendingAction action)
    {
        InvokeAsync(async () =>
        {
            await LoadConflictCountAsync();
            StateHasChanged();
        });
    }

    private void OnPendingCountChanged(int count)
    {
        InvokeAsync(async () =>
        {
            await LoadConflictCountAsync();
            StateHasChanged();
        });
    }

    /// <summary>
    /// Force-checks for a new Service Worker right now instead of waiting
    /// for the hourly reg.update() interval in index.html. If a new SW
    /// reaches the "waiting" state, post SKIP_WAITING — the
    /// `controllerchange` listener already wired up at boot reloads the
    /// page. If nothing new shows up after a short grace window, snackbar
    /// "up to date".
    /// </summary>
    private async Task CheckForUpdatesAsync()
    {
        if (_updateChecking) return;
        _updateChecking = true;
        StateHasChanged();
        try
        {
            var foundUpdate = await JsRuntime.InvokeAsync<bool>("pwaHelpers.checkForUpdate");

            if (!foundUpdate)
            {
                Snackbar.Add(L.T("settings.update_uptodate"), Severity.Info);
            }
            // If foundUpdate==true, controllerchange will reload the page
            // for us — no snackbar needed (page is about to unmount).
        }
        catch
        {
            Snackbar.Add(L.T("settings.update_failed"), Severity.Error);
        }
        finally
        {
            _updateChecking = false;
            StateHasChanged();
        }
    }

    private async Task LoadConflictCountAsync()
    {
        try
        {
            var conflicts = await SyncService.GetConflictedActionsAsync();
            _conflictCount = conflicts.Count;
        }
        catch
        {
            _conflictCount = 0;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _webauthnModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/webauthn-interop.js");
                _webauthnSupported = await _webauthnModule.InvokeAsync<bool>("isWebAuthnSupported");
                if (_webauthnSupported)
                    _passkeyRegistered = await _webauthnModule.InvokeAsync<bool>("isPasskeyRegistered");

                _webPushSupported = await WebPush.IsSupportedAsync();
                if (_webPushSupported)
                    _webPushEnabled = await WebPush.IsSubscribedAsync();
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task SetWebPushAsync(bool enabled)
    {
        if (_webPushBusy) return;
        _webPushBusy = true;
        StateHasChanged();
        try
        {
            bool ok;
            if (enabled)
            {
                ok = await WebPush.EnableAsync();
                if (!ok) Snackbar.Add(L.T("settings.push_enable_failed"), Severity.Warning);
            }
            else
            {
                ok = await WebPush.DisableAsync();
                if (!ok) Snackbar.Add(L.T("settings.push_disable_failed"), Severity.Warning);
            }
            _webPushEnabled = await WebPush.IsSubscribedAsync();
        }
        finally
        {
            _webPushBusy = false;
            StateHasChanged();
        }
    }

    private async Task<bool> GetBoolSetting(string key, bool defaultValue)
    {
        var val = await LocalStorage.GetItemAsync(key);
        return val != null ? val == "true" : defaultValue;
    }

    private async Task LoadAppVersionAsync()
    {
        try
        {
            // version.json is written by the Dockerfile build step. Local dev
            // serves no file -> 404 -> we keep the "dev" default.
            using var doc = await HttpClient.GetFromJsonAsync<System.Text.Json.JsonDocument>("version.json");
            if (doc == null) return;
            var root = doc.RootElement;
            if (root.TryGetProperty("version", out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String)
                _appVersion = ShortenCommit(v.GetString());
            if (root.TryGetProperty("builtAt", out var b) && b.ValueKind == System.Text.Json.JsonValueKind.String)
                _appBuiltAt = b.GetString() ?? string.Empty;
        }
        catch
        {
            // Local dev or fetch failure — leave defaults in place.
        }
    }

    private static string ShortenCommit(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "dev";
        // Trim long git SHAs down to 7 chars for readability; pass through
        // semver-like strings unchanged.
        return value.Length >= 40 ? value[..7] : value;
    }

    // ─── Auto-save helpers ──────────────────────────────────────────────
    // Each toggle on the page wires its ValueChanged to one of these so
    // settings persist on every interaction. Removes the foot-gun of
    // "I changed the dark mode but didn't press Save".

    private async Task AutoSaveBoolAsync(string key, bool value, Action<bool> setField)
    {
        setField(value);
        await LocalStorage.SetItemAsync(key, value ? "true" : "false");
    }

    private async Task SetDarkModeAsync(bool value)
    {
        _isDarkMode = value;
        await LocalStorage.SetItemAsync("settings_darkmode", value ? "true" : "false");
        // MainLayout reads settings_darkmode on every mount; for an
        // immediate effect the user would need to navigate away and back.
        // Documenting the existing behaviour rather than papering over it.
    }

    private async Task SetLanguageAsync(string value)
    {
        _selectedLanguage = value;
        await L.SetLanguageAsync(value);  // fires LanguageChanged → re-render
    }

    private async Task SetThemeColorAsync(string value)
    {
        _selectedColor = value;
        await LocalStorage.SetItemAsync("settings_primary_color", value);
    }

    private async Task SetNotificationsEnabledAsync(bool value)
    {
        _isNotificationsEnabled = value;
        await LocalStorage.SetItemAsync("settings_notifications", value ? "true" : "false");
        if (value) await BrowserNotifications.RequestPermissionAsync();
    }

    /// <summary>Persists only the API URL + timeout (validated). Called
    /// from the "Erweitert" expander's Save button.</summary>
    private async Task SaveAdvancedAsync()
    {
        if (_connectionTimeout < 5 || _connectionTimeout > 300)
        {
            Snackbar.Add(L.T("settings.timeout_invalid"), Severity.Warning);
            return;
        }
        AppSettings.ApiBaseUrl = _apiBaseUrl;
        AppSettings.ConnectionTimeoutSeconds = _connectionTimeout;
        await LocalStorage.SetItemAsync("settings_apiurl", _apiBaseUrl);
        await LocalStorage.SetItemAsync("settings_timeout", _connectionTimeout.ToString());
        Snackbar.Add(L.T("settings.saved"), Severity.Success);
    }

    // Auto-Lock has no Save button and its switch/select previously only mutated
    // local fields — SaveSettingsAsync (the only caller of IdleLock.SaveSettingsAsync)
    // is never invoked, so the control was inert (#215). Persist + start/stop the
    // watcher immediately whenever either control changes.
    private async Task SaveIdleLockAsync()
    {
        await IdleLock.SaveSettingsAsync(_idleLockEnabled && _passkeyRegistered, _idleLockMinutes);
    }

    private async Task SaveSettingsAsync()
    {
        if (_connectionTimeout < 5 || _connectionTimeout > 300)
        {
            Snackbar.Add(L.T("settings.timeout_invalid"), Severity.Warning);
            return;
        }

        AppSettings.ApiBaseUrl = _apiBaseUrl;
        AppSettings.ConnectionTimeoutSeconds = _connectionTimeout;

        await LocalStorage.SetItemAsync("settings_apiurl", _apiBaseUrl);
        await LocalStorage.SetItemAsync("settings_timeout", _connectionTimeout.ToString());
        await LocalStorage.SetItemAsync("settings_darkmode", _isDarkMode.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notifications", _isNotificationsEnabled.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_new", _notifyOnNewTickets.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_comments", _notifyOnComments.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_status", _notifyOnStatusChanges.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_only_mine", _notifyOnlyMyTickets.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_notify_high_prio", _notifyOnlyHighPriority.ToString().ToLower());
        await LocalStorage.SetItemAsync("settings_offline_cache", _isOfflineCacheEnabled.ToString().ToLower());

        // Update language via service
        await L.SetLanguageAsync(_selectedLanguage);

        // Update theme color
        await LocalStorage.SetItemAsync("settings_primary_color", _selectedColor);

        // Request notification permission if enabled
        if (_isNotificationsEnabled)
            await BrowserNotifications.RequestPermissionAsync();

        // Persist auto-lock preference. Service applies the new timeout
        // (or stops the watcher) live, no reload needed.
        await IdleLock.SaveSettingsAsync(_idleLockEnabled && _passkeyRegistered, _idleLockMinutes);

        Snackbar.Add(L.T("settings.saved"), Severity.Success);
    }

    private async Task RegisterPasskeyAsync()
    {
        if (_webauthnModule == null) return;
        try
        {
            var userId = ApiService.CurrentUserId ?? "unknown";
            var userName = ApiService.CurrentUsername ?? "user";
            var credentialId = await _webauthnModule.InvokeAsync<string?>("registerPasskey", userId, userName);
            if (!string.IsNullOrEmpty(credentialId))
            {
                _passkeyRegistered = true;
                Snackbar.Add(L.T("settings.passkey_registered"), Severity.Success);
            }
            else
            {
                Snackbar.Add(L.T("settings.passkey_register_failed"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemovePasskeyAsync()
    {
        if (_webauthnModule == null) return;
        await _webauthnModule.InvokeAsync<bool>("removePasskey");
        _passkeyRegistered = false;
        // Auto-lock without a passkey is a one-way trip to the login screen —
        // disable it implicitly when the passkey is gone.
        if (_idleLockEnabled)
        {
            _idleLockEnabled = false;
            await IdleLock.SaveSettingsAsync(false, _idleLockMinutes);
        }
        Snackbar.Add(L.T("settings.passkey_removed"), Severity.Info);
    }

    private async Task TestConnectionAsync()
    {
        _isTesting = true;
        _connectionStatus = L.T("settings.connection_testing");
        _connectionSeverity = Severity.Info;
        StateHasChanged();

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            var testUrl = _apiBaseUrl.TrimEnd('/');
            var response = await HttpClient.GetAsync(testUrl, cts.Token);

            if (response.IsSuccessStatusCode)
            {
                _connectionStatus = L.T("settings.connection_success");
                _connectionSeverity = Severity.Success;
            }
            else
            {
                _connectionStatus = $"{L.T("common.error")}: {(int)response.StatusCode} {response.ReasonPhrase}";
                _connectionSeverity = Severity.Error;
            }
        }
        catch (TaskCanceledException)
        {
            _connectionStatus = L.T("settings.connection_timeout");
            _connectionSeverity = Severity.Warning;
        }
        catch (HttpRequestException)
        {
            _connectionStatus = L.T("settings.connection_failed");
            _connectionSeverity = Severity.Error;
        }
        catch (Exception ex)
        {
            _connectionStatus = $"{L.T("common.error")}: {ex.Message}";
            _connectionSeverity = Severity.Error;
        }
        finally
        {
            _isTesting = false;
            StateHasChanged();
        }
    }

    private async Task ClearCacheAsync()
    {
        await LocalStorage.RemoveItemAsync("ticket_cache");
        Snackbar.Add(L.T("settings.cache_cleared"), Severity.Success);
    }

    private async Task LogoutAsync()
    {
        await ApiService.LogoutAsync();
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("login");
    }

    // -----------------------------------------------------------------
    // Sync Log
    // -----------------------------------------------------------------

    private async Task LoadSyncLogAsync()
    {
        _loadingSyncLog = true;
        try
        {
            var json = await IndexedDb.GetSyncLogAsync(200);
            _syncLogEntries = System.Text.Json.JsonSerializer.Deserialize<List<SyncLogDto>>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch { _syncLogEntries = new(); }
        finally { _loadingSyncLog = false; }
    }

    private async Task ExportSyncLogAsync()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_syncLogEntries,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JsRuntime.InvokeVoidAsync("pwaHelpers.downloadBase64", "application/json", base64, "sync-log.json");
    }

    private async Task ClearSyncLogAsync()
    {
        await IndexedDb.ClearSyncLogAsync();
        _syncLogEntries = new();
        Snackbar.Add(L.T("settings.synclog_cleared"), Severity.Success);
    }

    internal static string FormatTimestamp(string iso)
    {
        if (DateTime.TryParse(iso, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        return iso;
    }

    internal static Color GetLevelColor(string level) => level switch
    {
        "error" => Color.Error,
        "warn" => Color.Warning,
        _ => Color.Default
    };

    internal sealed class SyncLogDto
    {
        public string Timestamp { get; set; } = string.Empty;
        public string Level { get; set; } = string.Empty;
        public int? ActionId { get; set; }
        public string? ActionType { get; set; }
        public string? TicketId { get; set; }
        public string Message { get; set; } = string.Empty;
        public string? Exception { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        SyncService.ConflictDetected -= OnConflictDetected;
        SyncService.PendingCountChanged -= OnPendingCountChanged;
        if (_webauthnModule != null)
            await _webauthnModule.DisposeAsync();
    }
