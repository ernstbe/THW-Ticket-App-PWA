@page "/recurring-tasks"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Models.Responses
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject THWTicketApp.Web.Services.LocalizationService L

<PageTitle>@L.T("nav.recurring") - THW Ticket App</PageTitle>

<div class="d-flex justify-space-between align-center flex-wrap gap-2 mb-4">
    <MudText Typo="Typo.h4">@L.T("nav.recurring")</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowCreateDialog">@L.T("recurring.new")</MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadTasksAsync" Disabled="_isLoading"
                       aria-label="@L.T("common.refresh")" />
    </div>
</div>

@if (_isLoading && _tasks.Length == 0)
{
    <MudGrid Class="mb-4">
        @for (var i = 0; i < 3; i++)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudSkeleton Width="60%" Height="28px" />
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSkeleton Width="80%" Class="mb-2" />
                        <MudSkeleton Width="50%" Class="mb-2" />
                        <MudSkeleton Width="40%" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<MudGrid>
    @foreach (var task in _tasks)
    {
        <MudItem xs="12" md="6" lg="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center flex-wrap gap-2">
                            <MudText Typo="Typo.h6" Style="word-break: break-word;">@task.Name</MudText>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(task.Enabled ? Color.Success : Color.Default)">
                                @(task.Enabled ? L.T("recurring.active") : L.T("recurring.inactive"))
                            </MudChip>
                        </div>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="() => ShowEditDialog(task)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteTaskAsync(task)" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (!string.IsNullOrEmpty(task.Description))
                    {
                        <MudText Typo="Typo.body2" Class="mb-2">@task.Description</MudText>
                    }
                    <MudText Typo="Typo.body2"><strong>@L.T("recurring.schedule"):</strong> @FormatSchedule(task)</MudText>
                    <MudText Typo="Typo.body2"><strong>@L.T("recurring.ticket_subject"):</strong> @task.TicketSubject</MudText>
                    @{
                        var typeName = ResolveTypeName(task);
                        var priorityName = ResolvePriorityName(task);
                    }
                    @if (typeName != null || priorityName != null || task.Checklist.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-1 mt-2">
                            @if (typeName != null)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@typeName</MudChip>
                            }
                            @if (priorityName != null)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@priorityName</MudChip>
                            }
                            @if (task.Checklist.Count > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Icon="@Icons.Material.Filled.Checklist">@task.Checklist.Count</MudChip>
                            }
                        </div>
                    }
                    @if (task.NextRun.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            @L.T("recurring.next_run"): @task.NextRun.ToLocalDisplayString("dd.MM.yyyy")
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@if (!_isLoading && _tasks.Length == 0)
{
    <MudText Color="Color.Secondary" Class="mt-4">@L.T("recurring.none")</MudText>
}

@* Create / Edit Dialog *@
<MudDialog @bind-Visible="_dialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingTask == null ? L.T("recurring.new") : L.T("common.edit"))</MudText>
    </TitleContent>
    <DialogContent>
        @if (_templates.Count > 0)
        {
            <MudSelect T="TicketTemplate" Value="_selectedTemplate" ValueChanged="OnTemplateSelected"
                       Label="@L.T("tickets.use_template")" Clearable="true" Class="mb-2"
                       ToStringFunc="@(t => t?.Name ?? "")">
                @foreach (var tpl in _templates)
                {
                    <MudSelectItem Value="tpl">@tpl.Name</MudSelectItem>
                }
            </MudSelect>
        }
        <MudTextField @bind-Value="_formName" Label="@L.T("assets.name")" Class="mb-2" />
        <MudTextField @bind-Value="_formDescription" Label="@L.T("detail.description")" Lines="2" Class="mb-2" />
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("recurring.ticket_template")</MudText>
        <MudTextField @bind-Value="_formTicketSubject" Label="@L.T("detail.subject")" Class="mb-2" />
        <MudTextField @bind-Value="_formTicketIssue" Label="@L.T("detail.description")" Lines="3" Class="mb-2" />
        <MudSelect T="string" @bind-Value="_formTypeId" Label="@L.T("detail.type")" Required="true" Class="mb-2">
            @foreach (var t in _types)
            {
                <MudSelectItem T="string" Value="@t.Id">@t.TranslatedName</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" @bind-Value="_formPriorityId" Label="@L.T("detail.priority")" Required="true" Class="mb-2">
            @foreach (var p in _priorities)
            {
                <MudSelectItem T="string" Value="@p.Id">@p.TranslatedName</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" @bind-Value="_formGroupId" Label="@L.T("detail.group")" Required="true"
                   RequiredError="@L.T("tickets.group_required")" Class="mb-2">
            @foreach (var g in _groups)
            {
                <MudSelectItem T="string" Value="@g.Id">@g.Name</MudSelectItem>
            }
        </MudSelect>
        @if (_noVisibleGroups)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                @L.T("tickets.no_visible_groups")
            </MudAlert>
        }
        @if (_formChecklist.Count > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">
                @string.Format(L.T("tickets.template_checklist_info"), _formChecklist.Count)
            </MudText>
            <ChecklistEditor Items="_formChecklist" ItemsChanged="StateHasChanged" />
        }
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">@L.T("recurring.schedule")</MudText>
        <MudSelect @bind-Value="_formScheduleType" Label="@L.T("recurring.schedule_type")" Class="mb-2">
            <MudSelectItem Value="@("monthly")">@L.T("recurring.monthly")</MudSelectItem>
            <MudSelectItem Value="@("quarterly")">@L.T("recurring.quarterly")</MudSelectItem>
            <MudSelectItem Value="@("annual")">@L.T("recurring.annual")</MudSelectItem>
        </MudSelect>
        <MudNumericField @bind-Value="_formDayOfMonth" Label="@L.T("recurring.day_of_month")" Min="1" Max="28" Class="mb-2" />
        <MudNumericField @bind-Value="_formDaysBeforeDeadline" Label="@L.T("recurring.days_before")" Min="0" Max="365" Class="mb-2" />
        <MudSwitch @bind-Value="_formEnabled" Label="@L.T("recurring.enabled")" Color="Color.Primary" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogVisible = false">@L.T("common.cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTaskAsync">@L.T("common.save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _isLoading;
    private RecurringTask[] _tasks = [];
    private bool _dialogVisible;
    private RecurringTask? _editingTask;
    private string _formName = string.Empty;
    private string _formDescription = string.Empty;
    private string _formTicketSubject = string.Empty;
    private string _formTicketIssue = string.Empty;
    private string _formScheduleType = "monthly";
    private int _formDayOfMonth = 1;
    private int _formDaysBeforeDeadline = 7;
    private bool _formEnabled = true;
    private string? _formTypeId;
    private string? _formPriorityId;
    private string? _formGroupId;
    private List<string> _formChecklist = [];
    private List<TicketTemplate> _templates = [];
    private TicketTemplate? _selectedTemplate;
    private List<TicketType> _types = [];
    private List<Priority> _priorities = [];
    private List<Group> _groups = [];
    private bool _noVisibleGroups;

    // Snapshot of the ticket-template fields taken when the dialog opens,
    // so clearing the template picker restores what the user started with
    // (instead of wiping e.g. the checklist loaded from the edited task).
    private string _stashTicketSubject = string.Empty;
    private string _stashTicketIssue = string.Empty;
    private string? _stashTypeId;
    private string? _stashPriorityId;
    private List<string> _stashChecklist = [];

    private static readonly JsonSerializerOptions JsonOptions = new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTypesAsync(), LoadGroupsAsync(), LoadTemplatesAsync(), LoadTasksAsync());
    }

    private async Task LoadTypesAsync()
    {
        try
        {
            var typesJson = await ApiService.GetTicketTypesAsync();
            var types = JsonSerializer.Deserialize<TicketType[]>(typesJson, JsonOptions);
            if (types != null)
            {
                _types = types.ToList();
                _priorities = types.SelectMany(t => t.Priorities).DistinctBy(p => p.Id).ToList();
            }
        }
        catch
        {
            // Type/priority are required on save — tell the user the
            // reference data is missing instead of failing silently later.
            Snackbar.Add(L.T("tickets.form_load_error"), Severity.Error);
        }
    }

    private async Task LoadGroupsAsync()
    {
        try
        {
            // Same visibility scoping as AddTicket: restrict the dropdown to
            // the groups the profile can reach; fall back to the raw list if
            // the profile lookup failed (the server check is the real gate).
            var groupsTask = ApiService.GetGroupsAsync();
            var profileTask = ApiService.GetCurrentUserProfileAsync();
            await Task.WhenAll(groupsTask, profileTask);

            var groupResponse = JsonSerializer.Deserialize<GetGroupResponse>(groupsTask.Result, JsonOptions);
            var rawGroups = groupResponse?.Groups ?? new List<Group>();
            var visibleGroupIds = profileTask.Result?.Groups;
            _groups = AddTicket.FilterGroupsByVisibility(rawGroups, visibleGroupIds);
            _noVisibleGroups = visibleGroupIds != null && _groups.Count == 0;
        }
        catch
        {
            Snackbar.Add(L.T("tickets.form_load_error"), Severity.Error);
        }
    }

    private async Task LoadTemplatesAsync()
    {
        try
        {
            var templatesJson = await ApiService.GetTicketTemplatesAsync();
            _templates = TicketTemplateParser.ParseTemplates(templatesJson);
        }
        catch
        {
            // Templates endpoint failed — the picker simply stays hidden.
        }
    }

    private async Task LoadTasksAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        StateHasChanged();
        try
        {
            var json = await ApiService.GetRecurringTasksAsync();
            _tasks = JsonHelper.DeserializeWrappedArray<RecurringTask>(json, "recurringTasks");
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            Snackbar.Add(message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowCreateDialog()
    {
        _editingTask = null;
        _formName = _formDescription = _formTicketSubject = _formTicketIssue = string.Empty;
        _formScheduleType = "monthly";
        _formDayOfMonth = 1;
        _formDaysBeforeDeadline = 7;
        _formEnabled = true;
        _formTypeId = null;
        _formPriorityId = null;
        _formGroupId = _groups.Count > 0 ? _groups[0].Id : null;
        _formChecklist = [];
        _selectedTemplate = null;
        StashFormState();
        _dialogVisible = true;
    }

    internal void ShowEditDialog(RecurringTask task)
    {
        _editingTask = task;
        _formName = task.Name ?? string.Empty;
        _formDescription = task.Description ?? string.Empty;
        _formTicketSubject = task.TicketSubject ?? string.Empty;
        _formTicketIssue = task.TicketIssue ?? string.Empty;
        _formScheduleType = task.ScheduleType ?? "monthly";
        _formDayOfMonth = task.DayOfMonth;
        _formDaysBeforeDeadline = task.DaysBeforeDeadline;
        _formEnabled = task.Enabled;
        _formTypeId = task.TicketType?.Id;
        _formPriorityId = task.TicketPriority?.Id;
        _formGroupId = task.TicketGroup?.Id;
        _formChecklist = task.Checklist
            .Where(c => !string.IsNullOrWhiteSpace(c.Title))
            .Select(c => c.Title!)
            .ToList();
        _selectedTemplate = null;
        StashFormState();
        _dialogVisible = true;
    }

    private void StashFormState()
    {
        _stashTicketSubject = _formTicketSubject;
        _stashTicketIssue = _formTicketIssue;
        _stashTypeId = _formTypeId;
        _stashPriorityId = _formPriorityId;
        _stashChecklist = new List<string>(_formChecklist);
    }

    internal void OnTemplateSelected(TicketTemplate? template)
    {
        _selectedTemplate = template;
        if (template == null)
        {
            // Clearing the picker restores the state captured when the
            // dialog opened — on edit that's the task's own checklist,
            // which must not be wiped (BuildPayload always sends it).
            _formTicketSubject = _stashTicketSubject;
            _formTicketIssue = _stashTicketIssue;
            _formTypeId = _stashTypeId;
            _formPriorityId = _stashPriorityId;
            _formChecklist = new List<string>(_stashChecklist);
            return;
        }

        _formTicketSubject = template.Subject;
        _formTicketIssue = template.Issue ?? string.Empty;
        // Apply Type + Priority only if they're set AND match a loaded
        // option (same guard as AddTicket).
        if (!string.IsNullOrEmpty(template.TypeId) && _types.Any(t => t.Id == template.TypeId))
            _formTypeId = template.TypeId;
        if (!string.IsNullOrEmpty(template.PriorityId) && _priorities.Any(p => p.Id == template.PriorityId))
            _formPriorityId = template.PriorityId;
        _formChecklist = new List<string>(template.Checklist);
    }

    private async Task SaveTaskAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add(L.T("recurring.name_required"), Severity.Warning);
            return;
        }

        // ticketType/ticketPriority/ticketGroup are required:true on the
        // server schema — a missing one would fail the save with a 500.
        if (string.IsNullOrWhiteSpace(_formTypeId) ||
            string.IsNullOrWhiteSpace(_formPriorityId) ||
            string.IsNullOrWhiteSpace(_formGroupId))
        {
            Snackbar.Add(L.T("recurring.refs_required"), Severity.Warning);
            return;
        }

        var data = BuildPayload(
            name: _formName,
            description: _formDescription,
            ticketSubject: _formTicketSubject,
            ticketIssue: _formTicketIssue,
            scheduleType: _formScheduleType,
            dayOfMonth: _formDayOfMonth,
            daysBeforeDeadline: _formDaysBeforeDeadline,
            enabled: _formEnabled,
            typeId: _formTypeId,
            priorityId: _formPriorityId,
            groupId: _formGroupId,
            checklist: _formChecklist);

        bool success;
        if (_editingTask != null)
            success = await ApiService.UpdateRecurringTaskAsync(_editingTask.Id, data);
        else
            success = await ApiService.CreateRecurringTaskAsync(data);

        if (success)
        {
            _dialogVisible = false;
            Snackbar.Add(L.T("common.success"), Severity.Success);
            await LoadTasksAsync();
        }
        else
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }

    private async Task DeleteTaskAsync(RecurringTask task)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L.T("common.delete") },
            { x => x.Message, L.T("recurring.delete_confirm") },
            { x => x.ConfirmText, L.T("common.delete") },
            { x => x.CancelText, L.T("common.cancel") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        if (await ApiService.DeleteRecurringTaskAsync(task.Id))
        {
            Snackbar.Add(L.T("common.success"), Severity.Success);
            await LoadTasksAsync();
        }
        else
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }

    private string FormatSchedule(RecurringTask task)
    {
        var type = task.ScheduleType switch
        {
            "monthly" => L.T("recurring.monthly"),
            "quarterly" => L.T("recurring.quarterly"),
            "annual" => L.T("recurring.annual"),
            _ => task.ScheduleType ?? "-"
        };
        return $"{type}, {L.T("recurring.day_of_month")} {task.DayOfMonth}";
    }

    // GET may return refs populated ({_id, name}) or as bare id strings —
    // prefer the populated name, otherwise look the id up in the loaded lists.
    private string? ResolveTypeName(RecurringTask task)
    {
        var typeName = task.TicketType?.Name;
        if (!string.IsNullOrEmpty(typeName)) return Translator.Translate(typeName);
        var typeId = task.TicketType?.Id;
        if (string.IsNullOrEmpty(typeId)) return null;
        return _types.FirstOrDefault(t => t.Id == typeId)?.TranslatedName;
    }

    private string? ResolvePriorityName(RecurringTask task)
    {
        var name = task.TicketPriority?.Name;
        var priorityId = task.TicketPriority?.Id;
        if (string.IsNullOrEmpty(name) && !string.IsNullOrEmpty(priorityId))
            name = _priorities.FirstOrDefault(p => p.Id == priorityId)?.Name;
        return string.IsNullOrEmpty(name) ? null : TrudeskTranslationHelper.TranslatePriority(name);
    }

    // Exposed for unit tests ---------------------------------------------

    internal IReadOnlyList<string> FormChecklistForTests => _formChecklist;
    internal string FormTicketSubjectForTests => _formTicketSubject;

    internal static Dictionary<string, object?> BuildPayload(
        string name, string description, string ticketSubject, string ticketIssue,
        string scheduleType, int dayOfMonth, int daysBeforeDeadline, bool enabled,
        string? typeId = null, string? priorityId = null, string? groupId = null,
        List<string>? checklist = null)
    {
        var payload = new Dictionary<string, object?>
        {
            ["name"] = name,
            ["description"] = description,
            ["ticketSubject"] = ticketSubject,
            ["ticketIssue"] = ticketIssue,
            ["scheduleType"] = scheduleType,
            ["dayOfMonth"] = dayOfMonth,
            ["daysBeforeDeadline"] = daysBeforeDeadline,
            ["enabled"] = enabled,
            // Always send the checklist (even empty): the server replaces
            // the whole array, [] clears, omitted = unchanged.
            ["checklist"] = (checklist ?? [])
                .Select(t => new Dictionary<string, object?> { ["title"] = t })
                .ToList()
        };
        // ticketType/ticketPriority/ticketGroup are required:true on the
        // server — never send null (it fails validation); omit instead.
        if (!string.IsNullOrWhiteSpace(typeId)) payload["ticketType"] = typeId;
        if (!string.IsNullOrWhiteSpace(priorityId)) payload["ticketPriority"] = priorityId;
        if (!string.IsNullOrWhiteSpace(groupId)) payload["ticketGroup"] = groupId;
        return payload;
    }
}
