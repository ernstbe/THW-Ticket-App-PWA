@page "/sync-conflicts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using THWTicketApp.Shared.Data
@using THWTicketApp.Shared.Services
@inject ISyncService SyncService
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.LocalizationService L

<PageTitle>@L.T("nav.syncconflicts") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L.T("nav.syncconflicts")</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" Class="mb-2" />
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" Class="mb-2" />
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" />
}
else if (_conflicts.Count == 0)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">
        @L.T("sync.no_conflicts")
    </MudAlert>
}
else
{
    <MudText Typo="Typo.body1" Class="mb-4">
        @string.Format(L.T("sync.conflicts_found"), _conflicts.Count)
    </MudText>

    @foreach (var conflict in _conflicts)
    {
        var branch = GetConflictBranch(conflict.ConflictType);
        <MudCard Class="mb-3" Elevation="2" data-conflict-type="@conflict.ConflictType">
            <MudCardContent>
                <div class="d-flex align-center gap-3 mb-2">
                    <MudIcon Icon="@branch.Icon" Color="@branch.IconColor" />
                    <MudText Typo="Typo.h6">@TranslateActionType(conflict.ActionType)</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@branch.IconColor" Variant="Variant.Outlined">
                        @branch.Label
                    </MudChip>
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                        @conflict.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </MudText>
                </div>
                <MudAlert Severity="@branch.AlertSeverity" Dense="true" Class="mb-2">
                    @(conflict.ConflictReason ?? branch.Label)
                </MudAlert>
                @if (branch.Advice is not null)
                {
                    <MudText Typo="Typo.caption" Class="mt-1">@branch.Advice</MudText>
                }
            </MudCardContent>
            <MudCardActions>
                @if (branch.AllowForceApply)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.PublishedWithChanges"
                               OnClick="@(() => ForceApplyAsync(conflict))"
                               Disabled="_processing">
                        @L.T("sync.force_apply")
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="@(() => DiscardAsync(conflict))"
                           Disabled="_processing" Class="ml-2">
                    @L.T("sync.discard")
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
}

@code {
    private List<PendingAction> _conflicts = new();
    private bool _loading = true;
    private bool _processing;

    protected override async Task OnInitializedAsync()
    {
        await LoadConflictsAsync();
    }

    private async Task LoadConflictsAsync()
    {
        _loading = true;
        try
        {
            _conflicts = await SyncService.GetConflictedActionsAsync();
        }
        catch
        {
            _conflicts = new();
        }
        _loading = false;
    }

    private async Task ForceApplyAsync(PendingAction conflict)
    {
        _processing = true;
        try
        {
            var success = await SyncService.ForceApplyAsync(conflict.Id);
            if (success)
            {
                _conflicts.Remove(conflict);
                Snackbar.Add(L.T("sync.applied"), Severity.Success);
            }
            else
            {
                Snackbar.Add(L.T("sync.apply_failed"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
        _processing = false;
    }

    private async Task DiscardAsync(PendingAction conflict)
    {
        _processing = true;
        try
        {
            await SyncService.DiscardActionAsync(conflict.Id);
            _conflicts.Remove(conflict);
            Snackbar.Add(L.T("sync.discarded"), Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
        }
        _processing = false;
    }

    internal record ConflictBranch(string Label, string Icon, Color IconColor, Severity AlertSeverity, bool AllowForceApply, string? Advice);

    internal ConflictBranch GetConflictBranch(ConflictType type) => type switch
    {
        ConflictType.TicketDeleted => new(
            Label: L.T("sync.type_deleted"),
            Icon: Icons.Material.Filled.DeleteForever,
            IconColor: Color.Error,
            AlertSeverity: Severity.Error,
            AllowForceApply: false,
            Advice: L.T("sync.advice_deleted")),

        ConflictType.PermissionRevoked => new(
            Label: L.T("sync.type_permission"),
            Icon: Icons.Material.Filled.Block,
            IconColor: Color.Error,
            AlertSeverity: Severity.Error,
            AllowForceApply: false,
            Advice: L.T("sync.advice_permission")),

        ConflictType.StatusChanged => new(
            Label: L.T("sync.type_status"),
            Icon: Icons.Material.Filled.SyncProblem,
            IconColor: Color.Warning,
            AlertSeverity: Severity.Warning,
            AllowForceApply: true,
            Advice: L.T("sync.advice_status")),

        ConflictType.TicketUpdated => new(
            Label: L.T("sync.type_updated"),
            Icon: Icons.Material.Filled.Warning,
            IconColor: Color.Warning,
            AlertSeverity: Severity.Warning,
            AllowForceApply: true,
            Advice: null),

        _ => new(
            Label: L.T("sync.type_conflict"),
            Icon: Icons.Material.Filled.Warning,
            IconColor: Color.Warning,
            AlertSeverity: Severity.Warning,
            AllowForceApply: true,
            Advice: null)
    };

    internal string TranslateActionType(string actionType) => actionType switch
    {
        "AddComment" => L.T("sync.action_add_comment"),
        "AddNote" => L.T("sync.action_add_note"),
        "AssignTicket" => L.T("sync.action_assign"),
        "UpdateStatus" => L.T("sync.action_update_status"),
        "CreateTicket" => L.T("sync.action_create"),
        "ClearAssignee" => L.T("sync.action_clear_assignee"),
        "UpdateTicketFields" => L.T("sync.action_update_fields"),
        "DeleteTicket" => L.T("sync.action_delete"),
        "UploadAttachment" => L.T("sync.action_upload"),
        _ => actionType
    };
}
