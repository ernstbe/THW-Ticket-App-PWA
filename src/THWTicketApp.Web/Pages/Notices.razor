@page "/notices"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using MudBlazor.Utilities
@using System.Text.Json
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.LocalizationService L

<PageTitle>@L.T("nav.notices") - THW Ticket App</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L.T("nav.notices")</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                   OnClick="ClearAllAsync" Disabled="@(!_notices.Any(n => n.Active))">
            @L.T("notices.clear_all")
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => { _editNotice = new NoticeItem(); _showDialog = true; })">
            @L.T("notices.new")
        </MudButton>
    </div>
</div>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_notices.Count == 0)
{
    <MudAlert Severity="Severity.Normal">@L.T("notices.empty")</MudAlert>
}
else
{
    <MudStack Spacing="2">
        @foreach (var notice in _notices)
        {
            var n = notice;
            <MudPaper Elevation="@(n.Active ? 3 : 1)" Class="pa-4"
                      Style="@(n.Active ? $"border-left: 4px solid {n.Color};" : "")">
                <div class="d-flex justify-space-between align-start">
                    <div class="flex-grow-1">
                        <div class="d-flex align-center gap-2 mb-1">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@n.Name</MudText>
                            @if (n.Active)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">@L.T("notices.active")</MudChip>
                            }
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@n.Message</MudText>
                        @if (!string.IsNullOrEmpty(n.Color))
                        {
                            <div class="d-flex align-center gap-2 mt-2">
                                <div style="width: 24px; height: 24px; border-radius: 4px; background-color: @n.Color;" />
                                <MudText Typo="Typo.caption">@n.Color</MudText>
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-1">
                        @if (!n.Active)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                           Color="Color.Success" OnClick="@(() => ActivateAsync(n.Id))"
                                           aria-label="@L.T("notices.activate")" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error" OnClick="@(() => DeleteAsync(n.Id))"
                                       aria-label="@L.T("common.delete")" />
                    </div>
                </div>
            </MudPaper>
        }
    </MudStack>
}

@if (_showDialog)
{
    <MudDialog @bind-Visible="_showDialog">
        <DialogContent>
            <MudTextField @bind-Value="_editNotice.Name" Label="@L.T("notices.name")" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_editNotice.Message" Label="@L.T("notices.message")" Variant="Variant.Outlined" Lines="3" Class="mb-3" />
            <MudColorPicker @bind-Value="_pickerColor" Label="@L.T("notices.bg_color")"
                            ColorPickerView="ColorPickerView.Palette" ShowAlpha="false"
                            Variant="Variant.Outlined" Class="mb-3" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showDialog = false)">@L.T("common.cancel")</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync"
                       Disabled="@(string.IsNullOrWhiteSpace(_editNotice.Name) || string.IsNullOrWhiteSpace(_editNotice.Message))">
                @L.T("common.save")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private bool _isLoading;
    private bool _showDialog;
    private List<NoticeItem> _notices = [];
    private NoticeItem _editNotice = new();
    private MudColor _pickerColor = new("#1976D2");

    protected override async Task OnInitializedAsync()
    {
        await LoadNoticesAsync();
    }

    private async Task LoadNoticesAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var json = await ApiService.GetNoticesAsync();
            _notices = ParseNotices(json);
        }
        catch (Exception ex) { Snackbar.Add(ErrorHelper.Categorize(ex).Message, Severity.Error); }
        finally { _isLoading = false; StateHasChanged(); }
    }

    private async Task CreateAsync()
    {
        var color = _pickerColor.ToString(MudColorOutputFormats.Hex);
        var fontColor = IsLightColor(color) ? "#000000" : "#FFFFFF";
        if (await ApiService.CreateNoticeAsync(_editNotice.Name, _editNotice.Message, color, fontColor))
        {
            _showDialog = false;
            _editNotice = new();
            Snackbar.Add(L.T("notices.created"), Severity.Success);
            await LoadNoticesAsync();
        }
        else Snackbar.Add(L.T("detail.add_failed"), Severity.Error);
    }

    private async Task ActivateAsync(string id)
    {
        if (await ApiService.ActivateNoticeAsync(id))
        {
            Snackbar.Add(L.T("notices.activated"), Severity.Success);
            await LoadNoticesAsync();
        }
    }

    private async Task ClearAllAsync()
    {
        if (await ApiService.ClearNoticesAsync())
        {
            foreach (var n in _notices) n.Active = false;
            Snackbar.Add(L.T("notices.cleared"), Severity.Info);
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(string id)
    {
        if (await ApiService.DeleteNoticeAsync(id))
        {
            _notices.RemoveAll(n => n.Id == id);
            Snackbar.Add(L.T("notices.deleted"), Severity.Success);
            StateHasChanged();
        }
    }

    internal static bool IsLightColor(string hex)
    {
        if (hex.Length < 7) return true;
        var r = Convert.ToInt32(hex[1..3], 16);
        var g = Convert.ToInt32(hex[3..5], 16);
        var b = Convert.ToInt32(hex[5..7], 16);
        return (r * 299 + g * 587 + b * 114) / 1000 > 128;
    }

    internal static List<NoticeItem> ParseNotices(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("notices", out var arr) || arr.ValueKind != JsonValueKind.Array)
                return new();
            var list = new List<NoticeItem>();
            foreach (var el in arr.EnumerateArray())
            {
                list.Add(new NoticeItem
                {
                    Id = el.TryGetProperty("_id", out var id) ? id.GetString() ?? "" : "",
                    Name = el.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "",
                    Message = el.TryGetProperty("message", out var m) ? m.GetString() ?? "" : "",
                    Color = el.TryGetProperty("color", out var c) ? c.GetString() ?? "#1976D2" : "#1976D2",
                    FontColor = el.TryGetProperty("fontColor", out var fc) ? fc.GetString() ?? "#FFFFFF" : "#FFFFFF",
                    Active = el.TryGetProperty("active", out var a) && a.ValueKind == JsonValueKind.True
                });
            }
            return list;
        }
        catch { return new(); }
    }

    internal sealed class NoticeItem
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public string Color { get; set; } = "#1976D2";
        public string FontColor { get; set; } = "#FFFFFF";
        public bool Active { get; set; }
    }
}
