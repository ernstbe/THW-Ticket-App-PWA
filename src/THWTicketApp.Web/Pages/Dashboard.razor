@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using System.Text.Json
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject THWTicketApp.Web.Services.LocalizationService L

<PageTitle>@L.T("nav.dashboard") - THW Ticket App</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">@_welcomeMessage</MudText>

@if (_hasError)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@_errorMessage</MudAlert>
}

@if (_isLoading)
{
    <MudGrid Class="mb-6">
        @for (var i = 0; i < 6; i++)
        {
            <MudItem xs="6" sm="4" md="2">
                <MudCard Elevation="2" Class="pa-4">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" Class="mb-2" />
                    <MudSkeleton Width="60%" />
                    <MudSkeleton Width="40%" />
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudGrid Class="mb-6">
        <MudItem xs="6" sm="4" md="2">
            <StatCard Icon="@Icons.Material.Filled.ConfirmationNumber" IconColor="Color.Primary"
                      Value="_totalTickets" Label="@L.T("dashboard.total")"
                      OnClick="@(() => Navigation.NavigateTo("tickets"))" />
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <StatCard Icon="@Icons.Material.Filled.FolderOpen" IconColor="Color.Info"
                      Value="_openTickets" Label="@L.T("dashboard.open")"
                      OnClick="@(() => Navigation.NavigateTo("tickets?filter=open"))" />
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <StatCard Icon="@Icons.Material.Filled.HourglassTop" IconColor="Color.Warning"
                      Value="_pendingTickets" Label="@L.T("dashboard.in_progress")"
                      OnClick="@(() => Navigation.NavigateTo("tickets?filter=pending"))" />
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <StatCard Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success"
                      Value="_closedTickets" Label="@L.T("dashboard.closed")"
                      OnClick="@(() => Navigation.NavigateTo("tickets?filter=closed"))" />
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <StatCard Icon="@Icons.Material.Filled.PersonPin" IconColor="Color.Secondary"
                      Value="_myTickets" Label="@L.T("dashboard.mine")" />
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <StatCard Icon="@Icons.Material.Filled.Warning" IconColor="Color.Error"
                      Value="_overdueTickets" Label="@L.T("dashboard.overdue")" ValueColor="Color.Error" />
        </MudItem>
    </MudGrid>
}

<MudGrid>
    <MudItem xs="12" md="8">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">@L.T("dashboard.recent")</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Primary"
                           OnClick="@(() => Navigation.NavigateTo("tickets"))">
                    @L.T("dashboard.view_all")
                </MudButton>
            </div>
            @if (_isLoading)
            {
                @for (var i = 0; i < 3; i++)
                {
                    <MudPaper Elevation="0" Class="pa-3 mb-2" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudSkeleton Width="70%" Class="mb-1" />
                        <MudSkeleton Width="40%" Height="16px" />
                    </MudPaper>
                }
            }
            else if (_recentTickets.Count == 0)
            {
                <MudText Color="Color.Secondary">@L.T("dashboard.no_tickets")</MudText>
            }
            else
            {
                @foreach (var ticket in _recentTickets)
                {
                    <TicketCard Ticket="ticket" ShowActions="true"
                                OnClick="NavigateToDetail"
                                OnAssignToMe="QuickAssignAsync"
                                OnClose="QuickCloseAsync" />
                }
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">@L.T("dashboard.quick_actions")</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Add" Class="mb-2"
                       OnClick="@(() => Navigation.NavigateTo("tickets/add"))">
                @L.T("tickets.new")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.ViewKanban" Class="mb-2"
                       OnClick="@(() => Navigation.NavigateTo("kanban"))">
                @L.T("nav.kanban")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.BarChart"
                       OnClick="@(() => Navigation.NavigateTo("reports"))">
                @L.T("nav.reports")
            </MudButton>
        </MudPaper>

        @if (_ticketsPerGroup.Count > 0)
        {
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">@L.T("dashboard.tickets_per_group")</MudText>
                @foreach (var g in _ticketsPerGroup)
                {
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.body2">@g.GroupName</MudText>
                        <div class="d-flex align-center gap-2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@g.Total</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">@g.Open @L.T("dashboard.open_suffix")</MudChip>
                        </div>
                    </div>
                }
            </MudPaper>
        }

        @* Widgets *@
        @if (_widgetsLoaded)
        {
            @if (_widgetBeschluesse > 0)
            {
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h4" Color="Color.Primary">@_widgetBeschluesse</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L.T("dashboard.beschluesse")</MudText>
                        </div>
                    </div>
                </MudPaper>
            }

            @if (_widgetRecurringTasks.Count > 0)
            {
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">@L.T("dashboard.upcoming_tasks")</MudText>
                    @foreach (var task in _widgetRecurringTasks)
                    {
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.body2">@task.Subject</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@task.NextRun?.ToString("dd.MM.yyyy")</MudText>
                        </div>
                    }
                </MudPaper>
            }

            @if (_widgetAssetTotal > 0)
            {
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center gap-3 mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Secondary" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h4">@_widgetAssetTotal</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L.T("dashboard.assets_total")</MudText>
                        </div>
                    </div>
                    @foreach (var cat in _widgetAssetCategories)
                    {
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.body2">@cat.Key</MudText>
                            <MudChip T="string" Size="Size.Small">@cat.Value</MudChip>
                        </div>
                    }
                </MudPaper>
            }
        }
    </MudItem>
</MudGrid>

@code {
    private bool _isLoading;
    private bool _hasError;
    private string _errorMessage = string.Empty;
    private string _welcomeMessage = string.Empty;
    private int _totalTickets, _openTickets, _pendingTickets, _closedTickets, _myTickets, _overdueTickets;
    private List<Ticket> _allTickets = [];
    private List<Ticket> _recentTickets = [];
    private List<GroupTicketCount> _ticketsPerGroup = [];

    // Widgets
    private bool _widgetsLoaded;
    private int _widgetBeschluesse;
    private int _widgetAssetTotal;
    private List<WidgetRecurringTask> _widgetRecurringTasks = [];
    private Dictionary<string, int> _widgetAssetCategories = new();

    protected override async Task OnInitializedAsync()
    {
        _welcomeMessage = string.IsNullOrEmpty(ApiService.CurrentUsername)
            ? L.T("dashboard.welcome")
            : $"{L.T("dashboard.welcome_user")}, {ApiService.CurrentUsername}!";
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _hasError = false;
        StateHasChanged();

        try
        {
            var json = await ApiService.GetTicketsAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var tickets = JsonHelper.DeserializeWrappedArray<Ticket>(json, "tickets", options);

            _allTickets = tickets.ToList();
            foreach (var t in _allTickets)
                TrudeskTranslationHelper.TranslateTicket(t);

            ComputeStatistics();
            _recentTickets = _allTickets.OrderByDescending(t => t.Updated).Take(5).ToList();
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            _hasError = true;
            _errorMessage = message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }

        // Load widgets separately (non-blocking)
        _ = LoadWidgetsAsync();
    }

    private async Task LoadWidgetsAsync()
    {
        try
        {
            var json = await ApiService.GetDashboardWidgetsAsync();
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("widgets", out var w))
            {
                _widgetBeschluesse = w.TryGetProperty("beschluesse", out var b) ? b.GetInt32() : 0;
                _widgetAssetTotal = w.TryGetProperty("assets", out var a) && a.TryGetProperty("total", out var at) ? at.GetInt32() : 0;

                if (a.ValueKind != JsonValueKind.Undefined && a.TryGetProperty("byCategory", out var bc) && bc.ValueKind == JsonValueKind.Object)
                {
                    _widgetAssetCategories = new();
                    foreach (var prop in bc.EnumerateObject())
                        _widgetAssetCategories[prop.Name] = prop.Value.GetInt32();
                }

                if (w.TryGetProperty("recurringTasks", out var rt) && rt.ValueKind == JsonValueKind.Array)
                {
                    _widgetRecurringTasks = new();
                    foreach (var el in rt.EnumerateArray())
                    {
                        _widgetRecurringTasks.Add(new WidgetRecurringTask
                        {
                            Subject = el.TryGetProperty("ticketSubject", out var ts) ? ts.GetString() ?? "" : "",
                            NextRun = el.TryGetProperty("nextRun", out var nr) && nr.ValueKind == JsonValueKind.String
                                ? DateTime.TryParse(nr.GetString(), out var d) ? d : null : null
                        });
                    }
                }

                _widgetsLoaded = true;
                StateHasChanged();
            }
        }
        catch { /* widgets are non-critical */ }
    }

    private void ComputeStatistics()
    {
        _totalTickets = _allTickets.Count;
        _openTickets = _allTickets.Count(t =>
            t.Status?.Name?.ToLowerInvariant() is "offen" or "open" or "neu" or "new");
        _pendingTickets = _allTickets.Count(t =>
            t.Status?.Name?.ToLowerInvariant() is "ausstehend" or "pending" or "in bearbeitung" or "in progress" or "wartend" or "on hold");
        _closedTickets = _allTickets.Count(t =>
            t.Status?.IsResolved == true ||
            t.Status?.Name?.ToLowerInvariant() is "geschlossen" or "closed" or "gelöst" or "resolved");
        var username = ApiService.CurrentUsername;
        if (!string.IsNullOrEmpty(username))
            _myTickets = _allTickets.Count(t =>
                t.Assignee?.Username?.Equals(username, StringComparison.OrdinalIgnoreCase) == true);
        _overdueTickets = _allTickets.Count(t =>
            t.DueDate != DateTime.MinValue && t.DueDate < DateTime.Now && t.Status?.IsResolved != true);

        _ticketsPerGroup = _allTickets
            .Where(t => t.Group != null && !string.IsNullOrEmpty(t.Group.Name))
            .GroupBy(t => t.Group!.Name!)
            .OrderByDescending(g => g.Count())
            .Select(g => new GroupTicketCount(g.Key, g.Count(), g.Count(t => t.Status?.IsResolved != true)))
            .ToList();
    }

    private void NavigateToDetail(Ticket ticket)
    {
        Navigation.NavigateTo($"tickets/{ticket.Uid}");
    }

    private async Task QuickAssignAsync(Ticket ticket)
    {
        var userId = ApiService.CurrentUserId;
        if (string.IsNullOrEmpty(userId)) return;
        try
        {
            if (await ApiService.AssignTicketAsync(ticket.Id, userId))
            {
                Snackbar.Add(L.T("tickets.assigned"), Severity.Success);
                await LoadDashboardAsync();
            }
        }
        catch { Snackbar.Add(L.T("tickets.assign_failed"), Severity.Error); }
    }

    private async Task QuickCloseAsync(Ticket ticket)
    {
        try
        {
            var statusJson = await ApiService.GetStatusesAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var statuses = JsonHelper.DeserializeWrappedArray<Status>(statusJson, "status", options);
            var closedStatus = statuses.FirstOrDefault(s => s.IsResolved);
            if (closedStatus != null && await ApiService.UpdateTicketStatusAsync(ticket.Id, closedStatus.Id!))
            {
                Snackbar.Add(L.T("tickets.closed_success"), Severity.Success);
                await LoadDashboardAsync();
            }
        }
        catch { Snackbar.Add(L.T("tickets.close_failed"), Severity.Error); }
    }

    private record GroupTicketCount(string GroupName, int Total, int Open);

    private sealed class WidgetRecurringTask
    {
        public string Subject { get; set; } = string.Empty;
        public DateTime? NextRun { get; set; }
    }
}
