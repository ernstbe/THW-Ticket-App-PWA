@page "/templates"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Text.Json
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Services
@inject ITrueDeskApiService ApiService
@inject ILookupService Lookup
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject THWTicketApp.Web.Services.LocalizationService L

<PageTitle>@L.T("nav.templates") - THW Ticket App</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L.T("nav.templates")</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowCreateDialog">@L.T("templates.new")</MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadTemplatesAsync" Disabled="_isLoading"
                       aria-label="@L.T("common.refresh")" />
    </div>
</div>

@if (_isLoading && _templates.Count == 0)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

@if (_templates.Count == 0 && !_isLoading)
{
    <EmptyState Icon="@Icons.Material.Outlined.Description"
                Title="@L.T("templates.none")"
                Description="@L.T("templates.empty_description")" />
}
else
{
    <MudTable Items="_templates" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
        <HeaderContent>
            <MudTh>@L.T("templates.name")</MudTh>
            <MudTh>@L.T("templates.subject")</MudTh>
            <MudTh>@L.T("detail.type")</MudTh>
            <MudTh>@L.T("detail.priority")</MudTh>
            <MudTh>@L.T("templates.issue_preview")</MudTh>
            <MudTh>@L.T("common.edit")</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L.T("templates.name")">
                @context.Name
                @if (context.Checklist.Count > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2"
                             Icon="@Icons.Material.Filled.Checklist">@context.Checklist.Count</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L.T("templates.subject")">@context.Subject</MudTd>
            <MudTd DataLabel="@L.T("detail.type")">
                @if (!string.IsNullOrEmpty(context.TypeName))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.TypeName</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L.T("detail.priority")">
                @if (!string.IsNullOrEmpty(context.PriorityName))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.PriorityName</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L.T("templates.issue_preview")">@TrimIssue(context.Issue)</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="() => ShowEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="() => DeleteTemplateAsync(context)"
                               data-testid="tpl-delete-btn" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog @bind-Visible="_dialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editing == null ? L.T("templates.new") : L.T("common.edit"))</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_formName" Label="@L.T("templates.name")"
                      Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
        <MudTextField @bind-Value="_formSubject" Label="@L.T("templates.subject")"
                      Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
        <MudSelect T="string" @bind-Value="_formTypeId" Label="@L.T("detail.type")"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mb-2">
            @foreach (var t in _types)
            {
                <MudSelectItem T="string" Value="@t.Id">@t.TranslatedName</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" @bind-Value="_formPriorityId" Label="@L.T("detail.priority")"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mb-2">
            @foreach (var p in _priorities)
            {
                <MudSelectItem T="string" Value="@p.Id">@p.TranslatedName</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_formIssue" Label="@L.T("templates.issue")"
                      Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />

        <MudText Typo="Typo.subtitle2">@L.T("templates.checklist")</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-2">
            @L.T("templates.checklist_hint")
        </MudText>
        <ChecklistEditor Items="_formChecklist" AllowAdd="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogVisible = false">@L.T("common.cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">@L.T("common.save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _isLoading;
    private List<TicketTemplate> _templates = new();
    private List<TicketType> _types = new();
    private List<Priority> _priorities = new();
    private bool _dialogVisible;
    private TicketTemplate? _editing;
    private string _formName = string.Empty;
    private string _formSubject = string.Empty;
    private string _formIssue = string.Empty;
    private string? _formTypeId;
    private string? _formPriorityId;
    private List<string> _formChecklist = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTypesAndPrioritiesAsync();
        await LoadTemplatesAsync();
    }

    private async Task LoadTypesAndPrioritiesAsync()
    {
        try
        {
            var (types, priorities) = await Lookup.GetTypesAndPrioritiesAsync();
            _types = types.ToList();
            _priorities = priorities.ToList();
        }
        catch
        {
            // Backend unreachable — dropdowns stay empty, user can still
            // create text-only templates.
        }
    }

    private async Task LoadTemplatesAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        StateHasChanged();
        try
        {
            var json = await ApiService.GetTicketTemplatesAsync();
            var templates = TicketTemplateParser.ParseTemplates(json);
            TranslatePriorityNames(templates);
            _templates = templates;
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            Snackbar.Add(message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowCreateDialog()
    {
        _editing = null;
        _formName = _formSubject = _formIssue = string.Empty;
        _formTypeId = null;
        _formPriorityId = null;
        _formChecklist = new();
        _dialogVisible = true;
    }

    private void ShowEditDialog(TicketTemplate template)
    {
        _editing = template;
        _formName = template.Name;
        _formSubject = template.Subject;
        _formIssue = template.Issue ?? string.Empty;
        _formTypeId = template.TypeId;
        _formPriorityId = template.PriorityId;
        _formChecklist = new List<string>(template.Checklist);
        _dialogVisible = true;
    }

    private async Task SaveAsync()
    {
        var validation = ValidateForm(_formName, _formSubject);
        if (validation != null)
        {
            Snackbar.Add(L.T(validation), Severity.Warning);
            return;
        }

        var data = BuildPayload(_formName, _formSubject, _formIssue, _formTypeId, _formPriorityId, _formChecklist);
        bool ok;
        try
        {
            ok = _editing is null
                ? await ApiService.CreateTicketTemplateAsync(data)
                : await ApiService.UpdateTicketTemplateAsync(_editing.Id, data);
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            Snackbar.Add(message, Severity.Error);
            return;
        }

        if (ok)
        {
            _dialogVisible = false;
            Snackbar.Add(L.T("common.success"), Severity.Success);
            await LoadTemplatesAsync();
        }
        else
        {
            Snackbar.Add(L.T("common.error"), Severity.Error);
        }
    }

    private async Task DeleteTemplateAsync(TicketTemplate template)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L.T("common.delete") },
            { x => x.Message, L.T("templates.delete_confirm") },
            { x => x.ConfirmText, L.T("common.delete") },
            { x => x.CancelText, L.T("common.cancel") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        try
        {
            if (await ApiService.DeleteTicketTemplateAsync(template.Id))
            {
                Snackbar.Add(L.T("common.success"), Severity.Success);
                await LoadTemplatesAsync();
            }
            else
            {
                Snackbar.Add(L.T("common.error"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            var (message, _) = ErrorHelper.Categorize(ex);
            Snackbar.Add(message, Severity.Error);
        }
    }

    private static string TrimIssue(string? issue)
    {
        if (string.IsNullOrEmpty(issue)) return string.Empty;
        return issue.Length <= 60 ? issue : issue[..60] + "…";
    }

    // Exposed for unit tests ---------------------------------------------

    // Presentation step on top of the shared parser: the table shows the
    // German priority label, but the parser deliberately returns raw
    // server values (translation is page concern, see TicketTemplateParser).
    internal static void TranslatePriorityNames(List<TicketTemplate> templates)
    {
        foreach (var t in templates)
        {
            // Generic Translator — same table the dialog dropdown uses via
            // TranslatedName, so table chips and dropdown stay in sync.
            if (!string.IsNullOrEmpty(t.PriorityName))
                t.PriorityName = Translator.Translate(t.PriorityName);
        }
    }

    internal static string? ValidateForm(string? name, string? subject)
    {
        if (string.IsNullOrWhiteSpace(name)) return "templates.name_required";
        if (string.IsNullOrWhiteSpace(subject)) return "templates.subject_required";
        return null;
    }

    internal static Dictionary<string, object?> BuildPayload(
        string name, string subject, string? issue,
        string? typeId = null, string? priorityId = null,
        List<string>? checklist = null)
    {
        var payload = new Dictionary<string, object?>
        {
            ["name"] = name.Trim(),
            ["subject"] = subject.Trim(),
            ["issue"] = string.IsNullOrWhiteSpace(issue) ? null : issue.Trim(),
            // Always send the checklist (even empty): the server replaces the
            // whole array on update, so omitting the key would make "delete
            // all items" silently not stick.
            ["checklist"] = (checklist ?? new List<string>())
                .Select(t => new Dictionary<string, object?> { ["title"] = t })
                .ToList()
        };
        if (!string.IsNullOrWhiteSpace(typeId)) payload["ticketType"] = typeId;
        if (!string.IsNullOrWhiteSpace(priorityId)) payload["priority"] = priorityId;
        return payload;
    }
}
