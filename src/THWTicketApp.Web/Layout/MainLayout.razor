@inherits LayoutComponentBase
@using MudBlazor
@inject NavigationManager Navigation
@inject THWTicketApp.Shared.Services.ITrueDeskApiService ApiService
@inject THWTicketApp.Web.Services.AuthStateProvider AuthStateProvider
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject THWTicketApp.Web.Services.RealtimeService RealtimeService
@inject THWTicketApp.Web.Services.LocalStorageService LocalStorage
@inject THWTicketApp.Web.Services.LocalizationService L
@inject THWTicketApp.Web.Services.BrowserNotificationService BrowserNotifications
@inject THWTicketApp.Web.Services.AppSettingsInitializer SettingsInit
@inject THWTicketApp.Shared.Services.ISyncService SyncService
@inject THWTicketApp.Web.Services.IdleLockService IdleLock
@inject THWTicketApp.Web.Services.CommandPaletteService Palette
@inject THWTicketApp.Web.Services.OnboardingService Onboarding
@inject THWTicketApp.Web.Services.NavigationHistoryService NavHistory
@inject IJSRuntime JsRuntime
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="true" Class="pwa-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" aria-label="@L.T("a11y.toggle_menu")" />
        <MudLink Href="./" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="ml-3 pwa-appbar-title" Style="cursor:pointer;">THW Ticket App</MudLink>
        <MudSpacer />
        @if (_isOffline)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.CloudOff"
                     Style="color:white;">
                Offline @if (_pendingActions > 0) { <text>(@_pendingActions)</text> }
            </MudChip>
        }
        <MudBadge Content="@_unreadNotifications" Visible="@(_unreadNotifications > 0)"
                  Color="Color.Error" Overlap="true">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                           OnClick="@(() => Navigation.NavigateTo("notifications"))"
                           aria-label="@L.T("a11y.notifications")" />
        </MudBadge>
        <MudIconButton Icon="@Icons.Material.Filled.DarkMode" Color="Color.Inherit"
                       OnClick="@ToggleDarkMode" aria-label="@L.T("a11y.toggle_darkmode")" />
        <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                       OnClick="@LogoutAsync" aria-label="@L.T("a11y.logout")" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu aria-label="@L.T("a11y.main_navigation")">
            <MudNavLink Href="./" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">@L.T("nav.dashboard")</MudNavLink>
            <MudNavLink Href="tickets" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.ConfirmationNumber">@L.T("nav.tickets")</MudNavLink>
            <MudNavLink Href="tickets/add" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Add">@L.T("nav.newticket")</MudNavLink>
            <MudNavLink Href="kanban" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.ViewKanban">@L.T("nav.kanban")</MudNavLink>
            @* Favoriten / Berichte ausgeblendet auf Nutzerwunsch — Pages bleiben im Code. *@
            @if (_showHiddenNavLinks)
            {
                <MudNavLink Href="favorites" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Star">@L.T("nav.favorites")</MudNavLink>
            }
            <MudNavLink Href="team" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Groups">@L.T("nav.team")</MudNavLink>
            @if (_showHiddenNavLinks)
            {
                <MudNavLink Href="reports" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.BarChart">@L.T("nav.reports")</MudNavLink>
            }
            <MudNavLink Href="assets" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Inventory2">@L.T("nav.assets")</MudNavLink>
            @* Dokumente-Upload deaktiviert auf Nutzerwunsch — Page bleibt im Code, nur ausgeblendet. *@
            @if (_showHiddenNavLinks)
            {
                <MudNavLink Href="documents" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.FolderOpen">@L.T("nav.documents")</MudNavLink>
            }
            @* Ankündigungen ausgeblendet auf Nutzerwunsch — Page bleibt im Code. *@
            @if (_showHiddenNavLinks)
            {
                <MudNavLink Href="notices" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Campaign">@L.T("nav.notices")</MudNavLink>
            }
            <MudNavLink Href="recurring-tasks" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.EventRepeat">@L.T("nav.recurring")</MudNavLink>
            <MudNavLink Href="templates" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Description">@L.T("nav.templates")</MudNavLink>
            @* Kalender ausgeblendet auf Nutzerwunsch — Page bleibt im Code. *@
            @if (_showHiddenNavLinks)
            {
                <MudNavLink Href="calendar" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.CalendarMonth">@L.T("nav.calendar")</MudNavLink>
            }
            <MudNavLink Href="scanner" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.QrCodeScanner">@L.T("nav.scanner")</MudNavLink>
            <MudNavLink Href="notifications" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Notifications">@L.T("nav.notifications")</MudNavLink>
            @* Sync-Konflikte sind nicht mehr in der Top-Level-Navigation
               sondern als Card unter Einstellungen erreichbar. Die Route
               /sync-conflicts bleibt bestehen für Deep-Links. *@
            <MudDivider Class="my-2" />
            @if (_isAdmin)
            {
                @* Only admins reach /bug-reports — backend returns 403 for
                   everyone else. Surfaced here so they don't have to wait
                   for a push to find unresolved reports. *@
                <MudNavLink Href="bug-reports" Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.BugReport">@L.T("nav.bugreports")</MudNavLink>
            }
            <MudNavLink Href="profile" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.AccountCircle">@L.T("nav.profile")</MudNavLink>
            <MudNavLink Href="settings" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Settings">@L.T("nav.settings")</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4" id="main-content">
        @if (_showInstallBanner)
        {
            <MudAlert Severity="Severity.Info" Class="mx-4 mt-4" Dense="true" ShowCloseIcon="true"
                      CloseIconClicked="DismissInstallBanner">
                <div class="d-flex align-center gap-3">
                    <MudText>@L.T("pwa.install_hint")</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="PromptInstallAsync" StartIcon="@Icons.Material.Filled.InstallMobile">
                        @L.T("pwa.install")
                    </MudButton>
                </div>
            </MudAlert>
        }
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="my-4" Variant="Variant.Filled">
                        <div class="d-flex flex-column gap-2">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                Ein Fehler ist aufgetreten
                            </MudText>
                            <MudText Typo="Typo.body2">@ex.Message</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small"
                                       OnClick="RecoverFromError" Class="align-self-start mt-1">
                                Wiederherstellen
                            </MudButton>
                        </div>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@* Global Ctrl+K command palette. Mounted once, visible when the service
   says so. Each page can call Palette.Register(...) to expose its own
   actions. *@
<CommandPalette />

@* Welcome tour shown once per device on first login. *@
<OnboardingTour />

@* Floating "+" Quick-Create button. Hidden on the AddTicket page itself
   to avoid covering the form submit button. Bug-report FAB stacks
   above it so both are accessible everywhere. *@
<AuthorizeView>
    <Authorized>
        @if (!_currentPath.StartsWith("/tickets/add", StringComparison.OrdinalIgnoreCase))
        {
            <MudFab Color="Color.Primary"
                    StartIcon="@Icons.Material.Filled.Add"
                    aria-label="@L.T("tickets.new")"
                    title="@L.T("tickets.new")"
                    OnClick="@(() => Navigation.NavigateTo("tickets/add"))"
                    Style="position: fixed; bottom: 24px; right: 24px; z-index: 1200;" />
        }
        <BugReportFab />
    </Authorized>
</AuthorizeView>

@if (_showShortcutHelp)
{
    <MudOverlay Visible="true" DarkBackground="true" OnClick="@(() => _showShortcutHelp = false)" ZIndex="9999">
        <MudPaper Elevation="8" Class="pa-6" Style="max-width: 400px; margin: auto; margin-top: 15vh;">
            <MudText Typo="Typo.h6" Class="mb-4">@L.T("shortcuts.title")</MudText>
            <MudSimpleTable Dense="true" Hover="true">
                <tbody>
                    <tr><td><kbd>Ctrl</kbd> + <kbd>K</kbd></td><td>@L.T("shortcuts.palette")</td></tr>
                    <tr><td><kbd>N</kbd></td><td>@L.T("shortcuts.new_ticket")</td></tr>
                    <tr><td><kbd>T</kbd></td><td>@L.T("shortcuts.tickets")</td></tr>
                    <tr><td><kbd>K</kbd></td><td>@L.T("shortcuts.kanban")</td></tr>
                    <tr><td><kbd>D</kbd></td><td>@L.T("shortcuts.dashboard")</td></tr>
                    <tr><td><kbd>R</kbd></td><td>@L.T("shortcuts.reports")</td></tr>
                    <tr><td><kbd>S</kbd></td><td>@L.T("shortcuts.settings")</td></tr>
                    <tr><td><kbd>/</kbd></td><td>@L.T("shortcuts.search")</td></tr>
                    <tr><td><kbd>?</kbd></td><td>@L.T("shortcuts.help")</td></tr>
                </tbody>
            </MudSimpleTable>
            <MudButton Class="mt-4" Variant="Variant.Text" OnClick="@(() => _showShortcutHelp = false)">
                @L.T("common.close")
            </MudButton>
        </MudPaper>
    </MudOverlay>
}

@code {
    private ErrorBoundary? _errorBoundary;
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _isOffline;
    private bool _showInstallBanner;
    private bool _isInstalled;
    private int _unreadNotifications;
    private int _pendingActions;
    private bool _showShortcutHelp;
    private bool _isAdmin;
    // Single re-enable switch for the nav entries that were hidden on
    // user request (Favoriten / Berichte / Dokumente / Ankündigungen /
    // Kalender). Kept as a non-const field so the Razor source generator
    // doesn't fold the `@if (...)` to constant-false and trip CS0162 in
    // the generated `.g.cs`. Never assigned anywhere — flip the literal
    // to `true` when re-enabling.
#pragma warning disable CS0649
    private readonly bool _showHiddenNavLinks;
#pragma warning restore CS0649

    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private IJSObjectReference? _shortcutModule;
    private string _currentPath = string.Empty;

    private string _primaryColor = "#003399";
    private string _primaryColorDark = "#4D7FCC";

    private MudTheme _theme = null!;

    private void RebuildTheme()
    {
        _theme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary = _primaryColor,
                // Secondary wird quer durch die App als Textfarbe für
                // gedämpfte Hinweise verwendet (Ticket-UIDs, Captions,
                // Datumsangaben). Auf Weiß braucht das WCAG-AA-Kontrast,
                // deshalb dunkles Goldenrod statt #FFD700.
                Secondary = "#8B6914",
                AppbarBackground = _primaryColor,
                AppbarText = "#FFFFFF",
            },
            PaletteDark = new PaletteDark
            {
                Primary = _primaryColorDark,
                Secondary = "#FFD700",
                AppbarBackground = "#1A1A2E",
                AppbarText = "#FFFFFF",
                Surface = "#1E1E2E",
                Background = "#121212",
            },
            Typography = new Typography
            {
                Default = new DefaultTypography
                {
                    FontFamily = ["Roboto", "Helvetica", "Arial", "sans-serif"]
                }
            }
        };
    }

    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        RebuildTheme();
        _unreadNotifications = await ApiService.GetNotificationCountAsync();
        _pendingActions = await SyncService.GetPendingCountAsync();
        RealtimeService.NotificationUpdate += OnNotificationUpdate;
        SyncService.PendingCountChanged += OnPendingCountChanged;
        L.LanguageChanged += OnLanguageChanged;
        // Track current path so the FAB can hide itself on the AddTicket page.
        _currentPath = new Uri(Navigation.Uri).AbsolutePath
            .Replace(new Uri(Navigation.BaseUri).AbsolutePath, "/", StringComparison.Ordinal);
        Navigation.LocationChanged += OnLocationChanged;
        RegisterPaletteActions();
        await RealtimeService.ConnectAsync();
        // Resolve admin status so the Bug-Reports nav entry can appear.
        // Fire-and-forget — the nav re-renders when this completes; we
        // don't want to block the rest of the layout on a network roundtrip.
        _ = Task.Run(async () =>
        {
            try
            {
                var isAdmin = await ApiService.IsCurrentUserAdminAsync();
                if (isAdmin != _isAdmin)
                {
                    _isAdmin = isAdmin;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { /* not the end of the world if the nav entry doesn't appear */ }
        });
    }

    private void RegisterPaletteActions()
    {
        // Navigation entries — match the drawer items so the palette is a
        // complete keyboard-only alternative to the side menu.
        var nav = L.T("palette.category_navigation");
        var act = L.T("palette.category_actions");
        Palette.RegisterMany(new[]
        {
            new PaletteAction { Id="nav-dashboard",     Title=L.T("nav.dashboard"),     Icon=Icons.Material.Filled.Dashboard,         Category=nav, Keywords=new[]{"home","start"},                ExecuteAsync=()=>{ Navigation.NavigateTo("./"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-tickets",       Title=L.T("nav.tickets"),       Icon=Icons.Material.Filled.ConfirmationNumber, Category=nav, Keywords=new[]{"liste","list"},                ExecuteAsync=()=>{ Navigation.NavigateTo("tickets"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-kanban",        Title=L.T("nav.kanban"),        Icon=Icons.Material.Filled.ViewKanban,        Category=nav, Keywords=new[]{"board","spalten"},             ExecuteAsync=()=>{ Navigation.NavigateTo("kanban"); return Task.CompletedTask; } },
            // Favoriten ausgeblendet auf Nutzerwunsch — Palette-Eintrag ebenfalls aus.
            // new PaletteAction { Id="nav-favorites",     Title=L.T("nav.favorites"),     Icon=Icons.Material.Filled.Star,              Category=nav, Keywords=new[]{"stern","favoriten"},           ExecuteAsync=()=>{ Navigation.NavigateTo("favorites"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-team",          Title=L.T("nav.team"),          Icon=Icons.Material.Filled.Groups,            Category=nav, Keywords=new[]{"mitglieder","leute"},          ExecuteAsync=()=>{ Navigation.NavigateTo("team"); return Task.CompletedTask; } },
            // Berichte ausgeblendet auf Nutzerwunsch — Palette-Eintrag ebenfalls aus.
            // new PaletteAction { Id="nav-reports",       Title=L.T("nav.reports"),       Icon=Icons.Material.Filled.BarChart,          Category=nav, Keywords=new[]{"statistik","report"},          ExecuteAsync=()=>{ Navigation.NavigateTo("reports"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-assets",        Title=L.T("nav.assets"),        Icon=Icons.Material.Filled.Inventory2,        Category=nav, Keywords=new[]{"ausrüstung","inventar"},       ExecuteAsync=()=>{ Navigation.NavigateTo("assets"); return Task.CompletedTask; } },
            // Dokumente-Upload deaktiviert auf Nutzerwunsch — Palette-Eintrag ebenfalls ausgeblendet.
            // new PaletteAction { Id="nav-documents",     Title=L.T("nav.documents"),     Icon=Icons.Material.Filled.FolderOpen,        Category=nav, Keywords=new[]{"dateien","docs"},              ExecuteAsync=()=>{ Navigation.NavigateTo("documents"); return Task.CompletedTask; } },
            // Ankündigungen ausgeblendet auf Nutzerwunsch — Palette-Eintrag ebenfalls aus.
            // new PaletteAction { Id="nav-notices",       Title=L.T("nav.notices"),       Icon=Icons.Material.Filled.Campaign,          Category=nav, Keywords=new[]{"mitteilungen","ankündigung"}, ExecuteAsync=()=>{ Navigation.NavigateTo("notices"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-recurring",     Title=L.T("nav.recurring"),     Icon=Icons.Material.Filled.EventRepeat,       Category=nav, Keywords=new[]{"wiederholend","cron"},         ExecuteAsync=()=>{ Navigation.NavigateTo("recurring-tasks"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-templates",     Title=L.T("nav.templates"),     Icon=Icons.Material.Filled.Description,       Category=nav, Keywords=new[]{"vorlage","template"},          ExecuteAsync=()=>{ Navigation.NavigateTo("templates"); return Task.CompletedTask; } },
            // Kalender ausgeblendet auf Nutzerwunsch — Palette-Eintrag ebenfalls aus.
            // new PaletteAction { Id="nav-calendar",      Title=L.T("nav.calendar"),      Icon=Icons.Material.Filled.CalendarMonth,     Category=nav, Keywords=new[]{"kalender","termine"},          ExecuteAsync=()=>{ Navigation.NavigateTo("calendar"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-scanner",       Title=L.T("nav.scanner"),       Icon=Icons.Material.Filled.QrCodeScanner,     Category=nav, Keywords=new[]{"qr","barcode"},                ExecuteAsync=()=>{ Navigation.NavigateTo("scanner"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-notifications", Title=L.T("nav.notifications"), Icon=Icons.Material.Filled.Notifications,     Category=nav, Keywords=new[]{"benachrichtigungen"},          ExecuteAsync=()=>{ Navigation.NavigateTo("notifications"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-profile",       Title=L.T("nav.profile"),       Icon=Icons.Material.Filled.AccountCircle,     Category=nav, Keywords=new[]{"benutzer","ich"},              ExecuteAsync=()=>{ Navigation.NavigateTo("profile"); return Task.CompletedTask; } },
            new PaletteAction { Id="nav-settings",      Title=L.T("nav.settings"),      Icon=Icons.Material.Filled.Settings,          Category=nav, Keywords=new[]{"einstellungen","config"},      ExecuteAsync=()=>{ Navigation.NavigateTo("settings"); return Task.CompletedTask; } },

            // Quick actions — high-frequency operations exposed as one-liners.
            new PaletteAction { Id="act-new-ticket",  Title=L.T("tickets.new"),         Subtitle=L.T("palette.subtitle_new_ticket"), Icon=Icons.Material.Filled.Add,    Category=act, Keywords=new[]{"erstellen","create","add","ticket"},     ExecuteAsync=()=>{ Navigation.NavigateTo("tickets/add"); return Task.CompletedTask; } },
            new PaletteAction { Id="act-toggle-dark", Title=L.T("settings.darkmode"),   Subtitle=L.T("palette.subtitle_toggle_dark"),Icon=Icons.Material.Filled.DarkMode, Category=act, Keywords=new[]{"theme","hell","dunkel","mode"},          ExecuteAsync=async ()=>{ await ToggleDarkMode(); } },
            new PaletteAction { Id="act-logout",      Title=L.T("common.logout"),       Icon=Icons.Material.Filled.Logout,             Category=act, Keywords=new[]{"abmelden","ausloggen","signout"},          ExecuteAsync=async ()=>{ await LogoutAsync(); } },
        });
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentPath = new Uri(e.Location).AbsolutePath
            .Replace(new Uri(Navigation.BaseUri).AbsolutePath, "/", StringComparison.Ordinal);
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await SettingsInit.InitializeAsync();
            await L.InitializeAsync();
            await BrowserNotifications.InitializeAsync();

            // Offline detection
            _isOffline = !await JsRuntime.InvokeAsync<bool>("pwaHelpers.isOnline");
            _dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("window.registerConnectivityHandler", _dotNetRef);

            // PWA install prompt
            _isInstalled = await JsRuntime.InvokeAsync<bool>("window.isPwaInstalled");
            if (!_isInstalled)
                await JsRuntime.InvokeVoidAsync("window.registerInstallHandler", _dotNetRef);

            // Keyboard shortcuts
            _shortcutModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/keyboard-shortcuts.js");
            await _shortcutModule.InvokeVoidAsync("register", _dotNetRef);

            // Dark mode: respect user override first, fall back to system preference.
            // The toggle in Settings stores "true" / "false". Anything else (null,
            // empty) means "follow the OS". Read from the synchronous preload
            // window.__preloadedDarkMode set in index.html — avoids the async
            // storage-interop module import that previously caused a Light→Dark
            // flash on reload (and stuck the user in Light if anything later in
            // OnAfterRenderAsync threw before StateHasChanged ran).
            string? darkMode = null;
            try { darkMode = await JsRuntime.InvokeAsync<string?>("pwaHelpers.getPreloadedDarkMode"); }
            catch { darkMode = await LocalStorage.GetItemAsync("settings_darkmode"); }
            if (darkMode == "true") _isDarkMode = true;
            else if (darkMode == "false") _isDarkMode = false;
            else
            {
                try
                {
                    _isDarkMode = await JsRuntime.InvokeAsync<bool>("pwaHelpers.prefersDarkMode");
                }
                catch { /* fall through with default */ }
            }

            var savedColor = await LocalStorage.GetItemAsync("settings_primary_color");
            if (!string.IsNullOrEmpty(savedColor))
            {
                _primaryColor = savedColor;
                _primaryColorDark = LightenColor(savedColor);
                RebuildTheme();
            }

            // Idle auto-lock: load setting and start the watcher if enabled.
            // Service itself no-ops if no passkey is registered.
            await IdleLock.LoadSettingsAsync();
            await IdleLock.StartAsync();

            // First-run onboarding tour. Service no-ops if the user has
            // already completed/skipped it on this device. Use InvokeAsync
            // (not Task.Run — Blazor WASM is single-threaded and Task.Run
            // can swallow exceptions silently) and log failures so we can
            // diagnose if it ever doesn't fire.
            _ = InvokeAsync(async () =>
            {
                try
                {
                    await Task.Delay(500);
                    await Onboarding.ShowIfFirstRunAsync();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[Onboarding] ShowIfFirstRunAsync failed: {ex.Message}");
                }
            });

            StateHasChanged();
        }
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void OnPendingCountChanged(int count)
    {
        _pendingActions = count;
        InvokeAsync(StateHasChanged);
    }

    private async void OnNotificationUpdate()
    {
        try
        {
            _unreadNotifications = await ApiService.GetNotificationCountAsync();
        }
        catch
        {
            _unreadNotifications++;
        }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnInstallAvailable()
    {
        _showInstallBanner = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnAppInstalled()
    {
        _showInstallBanner = false;
        _isInstalled = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task PromptInstallAsync()
    {
        await JsRuntime.InvokeVoidAsync("window.promptInstall");
        _showInstallBanner = false;
    }

    private void DismissInstallBanner() => _showInstallBanner = false;

    [JSInvokable]
    public void OnShortcut(string action)
    {
        InvokeAsync(() =>
        {
            switch (action)
            {
                case "new-ticket": Navigation.NavigateTo("tickets/add"); break;
                case "kanban": Navigation.NavigateTo("kanban"); break;
                case "tickets": Navigation.NavigateTo("tickets"); break;
                case "dashboard": Navigation.NavigateTo("/"); break;
                case "settings": Navigation.NavigateTo("settings"); break;
                case "reports": Navigation.NavigateTo("reports"); break;
                case "search": Navigation.NavigateTo("tickets"); break;
                case "help": _showShortcutHelp = !_showShortcutHelp; StateHasChanged(); break;
                case "palette": Palette.Toggle(); break;
            }
        });
    }

    public void ApplyThemeColor(string color)
    {
        _primaryColor = color;
        _primaryColorDark = LightenColor(color);
        RebuildTheme();
        InvokeAsync(StateHasChanged);
    }

    internal static string LightenColor(string hex)
    {
        if (hex.Length < 7) return hex;
        var r = Math.Min(255, Convert.ToInt32(hex[1..3], 16) + 40);
        var g = Math.Min(255, Convert.ToInt32(hex[3..5], 16) + 40);
        var b = Math.Min(255, Convert.ToInt32(hex[5..7], 16) + 40);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    [JSInvokable]
    public void OnConnectivityChanged(bool isOnline)
    {
        _isOffline = !isOnline;
        InvokeAsync(StateHasChanged);
    }

    private void RecoverFromError() => _errorBoundary?.Recover();

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await LocalStorage.SetItemAsync("settings_darkmode", _isDarkMode ? "true" : "false");
    }

    public void Dispose()
    {
        RealtimeService.NotificationUpdate -= OnNotificationUpdate;
        SyncService.PendingCountChanged -= OnPendingCountChanged;
        L.LanguageChanged -= OnLanguageChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        if (_shortcutModule != null)
            _ = _shortcutModule.InvokeVoidAsync("unregister");
        _dotNetRef?.Dispose();
    }

    private async Task LogoutAsync()
    {
        await IdleLock.StopAsync();
        await ApiService.LogoutAsync();
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("login");
    }
}
