@inherits LayoutComponentBase
@using MudBlazor
@inject NavigationManager Navigation
@inject THWTicketApp.Shared.Services.ITrueDeskApiService ApiService
@inject THWTicketApp.Web.Services.AuthStateProvider AuthStateProvider
@inject THWTicketApp.Web.Services.AppStateService AppState
@inject THWTicketApp.Web.Services.RealtimeService RealtimeService
@inject THWTicketApp.Web.Services.LocalStorageService LocalStorage
@inject THWTicketApp.Web.Services.LocalizationService L
@inject THWTicketApp.Web.Services.BrowserNotificationService BrowserNotifications
@inject THWTicketApp.Web.Services.AppSettingsInitializer SettingsInit
@inject THWTicketApp.Shared.Services.ISyncService SyncService
@inject IJSRuntime JsRuntime
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" aria-label="@L.T("a11y.toggle_menu")" />
        <MudLink Href="./" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="ml-3" Style="cursor:pointer;">THW Ticket App</MudLink>
        <MudSpacer />
        @if (_isOffline)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.CloudOff"
                     Style="color:white;">
                Offline @if (_pendingActions > 0) { <text>(@_pendingActions)</text> }
            </MudChip>
        }
        <MudBadge Content="@_unreadNotifications" Visible="@(_unreadNotifications > 0)"
                  Color="Color.Error" Overlap="true">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                           OnClick="@(() => Navigation.NavigateTo("notifications"))"
                           aria-label="@L.T("a11y.notifications")" />
        </MudBadge>
        <MudIconButton Icon="@Icons.Material.Filled.DarkMode" Color="Color.Inherit"
                       OnClick="@ToggleDarkMode" aria-label="@L.T("a11y.toggle_darkmode")" />
        <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                       OnClick="@LogoutAsync" aria-label="@L.T("a11y.logout")" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu aria-label="@L.T("a11y.main_navigation")">
            <MudNavLink Href="./" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">@L.T("nav.dashboard")</MudNavLink>
            <MudNavLink Href="tickets" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.ConfirmationNumber">@L.T("nav.tickets")</MudNavLink>
            <MudNavLink Href="tickets/add" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Add">@L.T("nav.newticket")</MudNavLink>
            <MudNavLink Href="kanban" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.ViewKanban">@L.T("nav.kanban")</MudNavLink>
            <MudNavLink Href="favorites" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Star">@L.T("nav.favorites")</MudNavLink>
            <MudNavLink Href="team" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Groups">@L.T("nav.team")</MudNavLink>
            <MudNavLink Href="reports" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.BarChart">@L.T("nav.reports")</MudNavLink>
            <MudNavLink Href="assets" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Inventory2">@L.T("nav.assets")</MudNavLink>
            <MudNavLink Href="documents" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.FolderOpen">@L.T("nav.documents")</MudNavLink>
            <MudNavLink Href="notices" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Campaign">@L.T("nav.notices")</MudNavLink>
            <MudNavLink Href="recurring-tasks" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.EventRepeat">@L.T("nav.recurring")</MudNavLink>
            <MudNavLink Href="templates" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Description">@L.T("nav.templates")</MudNavLink>
            <MudNavLink Href="calendar" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.CalendarMonth">@L.T("nav.calendar")</MudNavLink>
            <MudNavLink Href="scanner" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.QrCodeScanner">@L.T("nav.scanner")</MudNavLink>
            <MudNavLink Href="notifications" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Notifications">@L.T("nav.notifications")</MudNavLink>
            <MudNavLink Href="sync-conflicts" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.SyncProblem">@L.T("nav.syncconflicts")</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="profile" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.AccountCircle">@L.T("nav.profile")</MudNavLink>
            <MudNavLink Href="settings" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Settings">@L.T("nav.settings")</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4" id="main-content">
        @if (_showInstallBanner)
        {
            <MudAlert Severity="Severity.Info" Class="mx-4 mt-4" Dense="true" ShowCloseIcon="true"
                      CloseIconClicked="DismissInstallBanner">
                <div class="d-flex align-center gap-3">
                    <MudText>@L.T("pwa.install_hint")</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="PromptInstallAsync" StartIcon="@Icons.Material.Filled.InstallMobile">
                        @L.T("pwa.install")
                    </MudButton>
                </div>
            </MudAlert>
        }
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="my-4" Variant="Variant.Filled">
                        <div class="d-flex flex-column gap-2">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                Ein Fehler ist aufgetreten
                            </MudText>
                            <MudText Typo="Typo.body2">@ex.Message</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small"
                                       OnClick="RecoverFromError" Class="align-self-start mt-1">
                                Wiederherstellen
                            </MudButton>
                        </div>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@if (_showShortcutHelp)
{
    <MudOverlay Visible="true" DarkBackground="true" OnClick="@(() => _showShortcutHelp = false)" ZIndex="9999">
        <MudPaper Elevation="8" Class="pa-6" Style="max-width: 400px; margin: auto; margin-top: 15vh;">
            <MudText Typo="Typo.h6" Class="mb-4">@L.T("shortcuts.title")</MudText>
            <MudSimpleTable Dense="true" Hover="true">
                <tbody>
                    <tr><td><kbd>N</kbd></td><td>@L.T("shortcuts.new_ticket")</td></tr>
                    <tr><td><kbd>T</kbd></td><td>@L.T("shortcuts.tickets")</td></tr>
                    <tr><td><kbd>K</kbd></td><td>@L.T("shortcuts.kanban")</td></tr>
                    <tr><td><kbd>D</kbd></td><td>@L.T("shortcuts.dashboard")</td></tr>
                    <tr><td><kbd>R</kbd></td><td>@L.T("shortcuts.reports")</td></tr>
                    <tr><td><kbd>S</kbd></td><td>@L.T("shortcuts.settings")</td></tr>
                    <tr><td><kbd>/</kbd></td><td>@L.T("shortcuts.search")</td></tr>
                    <tr><td><kbd>?</kbd></td><td>@L.T("shortcuts.help")</td></tr>
                </tbody>
            </MudSimpleTable>
            <MudButton Class="mt-4" Variant="Variant.Text" OnClick="@(() => _showShortcutHelp = false)">
                @L.T("common.close")
            </MudButton>
        </MudPaper>
    </MudOverlay>
}

@code {
    private ErrorBoundary? _errorBoundary;
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _isOffline;
    private bool _showInstallBanner;
    private bool _isInstalled;
    private int _unreadNotifications;
    private int _pendingActions;
    private bool _showShortcutHelp;
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private IJSObjectReference? _shortcutModule;

    private string _primaryColor = "#003399";
    private string _primaryColorDark = "#4D7FCC";

    private MudTheme _theme = null!;

    private void RebuildTheme()
    {
        _theme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary = _primaryColor,
                Secondary = "#FFD700",
                AppbarBackground = _primaryColor,
                AppbarText = "#FFFFFF",
            },
            PaletteDark = new PaletteDark
            {
                Primary = _primaryColorDark,
                Secondary = "#FFD700",
                AppbarBackground = "#1A1A2E",
                AppbarText = "#FFFFFF",
                Surface = "#1E1E2E",
                Background = "#121212",
            },
            Typography = new Typography
            {
                Default = new DefaultTypography
                {
                    FontFamily = ["Roboto", "Helvetica", "Arial", "sans-serif"]
                }
            }
        };
    }

    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        RebuildTheme();
        _unreadNotifications = await ApiService.GetNotificationCountAsync();
        _pendingActions = await SyncService.GetPendingCountAsync();
        RealtimeService.NotificationUpdate += OnNotificationUpdate;
        SyncService.PendingCountChanged += OnPendingCountChanged;
        L.LanguageChanged += OnLanguageChanged;
        await RealtimeService.ConnectAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await SettingsInit.InitializeAsync();
            await L.InitializeAsync();
            await BrowserNotifications.InitializeAsync();

            // Offline detection
            _isOffline = !await JsRuntime.InvokeAsync<bool>("eval", "navigator.onLine");
            _dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("window.registerConnectivityHandler", _dotNetRef);

            // PWA install prompt
            _isInstalled = await JsRuntime.InvokeAsync<bool>("window.isPwaInstalled");
            if (!_isInstalled)
                await JsRuntime.InvokeVoidAsync("window.registerInstallHandler", _dotNetRef);

            // Keyboard shortcuts
            _shortcutModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/keyboard-shortcuts.js");
            await _shortcutModule.InvokeVoidAsync("register", _dotNetRef);

            var darkMode = await LocalStorage.GetItemAsync("settings_darkmode");
            if (darkMode == "true") _isDarkMode = true;

            var savedColor = await LocalStorage.GetItemAsync("settings_primary_color");
            if (!string.IsNullOrEmpty(savedColor))
            {
                _primaryColor = savedColor;
                _primaryColorDark = LightenColor(savedColor);
                RebuildTheme();
            }
            StateHasChanged();
        }
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void OnPendingCountChanged(int count)
    {
        _pendingActions = count;
        InvokeAsync(StateHasChanged);
    }

    private async void OnNotificationUpdate()
    {
        try
        {
            _unreadNotifications = await ApiService.GetNotificationCountAsync();
        }
        catch
        {
            _unreadNotifications++;
        }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnInstallAvailable()
    {
        _showInstallBanner = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnAppInstalled()
    {
        _showInstallBanner = false;
        _isInstalled = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task PromptInstallAsync()
    {
        await JsRuntime.InvokeVoidAsync("window.promptInstall");
        _showInstallBanner = false;
    }

    private void DismissInstallBanner() => _showInstallBanner = false;

    [JSInvokable]
    public void OnShortcut(string action)
    {
        InvokeAsync(() =>
        {
            switch (action)
            {
                case "new-ticket": Navigation.NavigateTo("tickets/add"); break;
                case "kanban": Navigation.NavigateTo("kanban"); break;
                case "tickets": Navigation.NavigateTo("tickets"); break;
                case "dashboard": Navigation.NavigateTo("/"); break;
                case "settings": Navigation.NavigateTo("settings"); break;
                case "reports": Navigation.NavigateTo("reports"); break;
                case "search": Navigation.NavigateTo("tickets"); break;
                case "help": _showShortcutHelp = !_showShortcutHelp; StateHasChanged(); break;
            }
        });
    }

    public void ApplyThemeColor(string color)
    {
        _primaryColor = color;
        _primaryColorDark = LightenColor(color);
        RebuildTheme();
        InvokeAsync(StateHasChanged);
    }

    internal static string LightenColor(string hex)
    {
        if (hex.Length < 7) return hex;
        var r = Math.Min(255, Convert.ToInt32(hex[1..3], 16) + 40);
        var g = Math.Min(255, Convert.ToInt32(hex[3..5], 16) + 40);
        var b = Math.Min(255, Convert.ToInt32(hex[5..7], 16) + 40);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    [JSInvokable]
    public void OnConnectivityChanged(bool isOnline)
    {
        _isOffline = !isOnline;
        InvokeAsync(StateHasChanged);
    }

    private void RecoverFromError() => _errorBoundary?.Recover();

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await LocalStorage.SetItemAsync("settings_darkmode", _isDarkMode ? "true" : "false");
    }

    public void Dispose()
    {
        RealtimeService.NotificationUpdate -= OnNotificationUpdate;
        SyncService.PendingCountChanged -= OnPendingCountChanged;
        L.LanguageChanged -= OnLanguageChanged;
        if (_shortcutModule != null)
            _ = _shortcutModule.InvokeVoidAsync("unregister");
        _dotNetRef?.Dispose();
    }

    private async Task LogoutAsync()
    {
        await ApiService.LogoutAsync();
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("login");
    }
}
