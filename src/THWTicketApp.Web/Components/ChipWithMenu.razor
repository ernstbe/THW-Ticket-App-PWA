@*
    A clickable chip that opens a menu of options on click. Replaces the
    "open dropdown -> select -> click save" sequence with a single click.
    Used in the ticket detail header for status/priority/assignee/group.

    Implementation note (MudBlazor 9): two earlier attempts failed —
    1) MudMenu's ActivatorContent swallowed clicks because MudChip stops
       click propagation internally,
    2) calling _menu.OpenMenuAsync from an @onclick wrapper looked clean
       in source but did not actually open the popup on the deployed
       build.

    Current approach: bind Open/OpenChanged on MudMenu, drive it from the
    chip's own OnClick handler. The chip is the *anchor* of the menu
    (`AnchorRef`) so the popup positions over the chip even though it's
    rendered separately. Click on a menu item invokes the parent
    callback and closes the popup.

    Usage:
        <ChipWithMenu Label="@_ticket.Status?.Name"
                      Icon="@Icons.Material.Filled.Circle"
                      Color="@StatusColor(...)"
                      Items="_statuses"
                      ItemTitle="@(s => s.Name)"
                      OnSelected="OnStatusChanged" />
*@

@typeparam T

<MudChip @ref="_chip" T="string" Size="Size.Small"
         Color="@(string.IsNullOrEmpty(BackgroundColor) ? Color : MudBlazor.Color.Default)"
         Variant="Variant.Filled"
         Icon="@Icon"
         Style="@ChipStyle"
         OnClick="@OpenAsync">
    @if (string.IsNullOrEmpty(Label))
    {
        <em style="opacity:0.7;">@(EmptyLabel ?? "—")</em>
    }
    else
    {
        @Label
    }
</MudChip>

<MudMenu @bind-Open="_open" AnchorOrigin="Origin.BottomLeft"
         TransformOrigin="Origin.TopLeft" Dense="true"
         PositionAtCursor="true">
    @if (Items != null && Items.Any())
    {
        @foreach (var item in Items)
        {
            var local = item;
            <MudMenuItem OnClick="@(() => OnItemSelected(local))">
                @ItemTitle(local)
            </MudMenuItem>
        }
    }
    else
    {
        <MudMenuItem Disabled="true">
            <em>@(EmptyMenuLabel ?? "—")</em>
        </MudMenuItem>
    }
    @if (OnClear.HasDelegate && !string.IsNullOrEmpty(Label))
    {
        <MudDivider />
        <MudMenuItem Icon="@Icons.Material.Filled.Close"
                     OnClick="@OnClearClicked">
            @(ClearLabel ?? "Entfernen")
        </MudMenuItem>
    }
</MudMenu>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? EmptyLabel { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Default;
    /// <summary>
    /// CSS color used as the chip's background. Overrides the MudBlazor
    /// <see cref="Color"/> enum when set, so callers can honour the
    /// trudesk-configured HtmlColor of a Status/Priority/etc. instead of
    /// mapping it to a coarse palette slot.
    /// </summary>
    [Parameter] public string? BackgroundColor { get; set; }
    [Parameter] public IEnumerable<T>? Items { get; set; }
    [Parameter, EditorRequired] public Func<T, string> ItemTitle { get; set; } = _ => "";
    [Parameter] public EventCallback<T> OnSelected { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }
    [Parameter] public string? ClearLabel { get; set; }
    [Parameter] public string? EmptyMenuLabel { get; set; }

    private MudChip<string>? _chip;
    private bool _open;

    private string ChipStyle => string.IsNullOrEmpty(BackgroundColor)
        ? "cursor:pointer;"
        : $"cursor:pointer; background-color: {BackgroundColor}; color: white;";

    private Task OpenAsync()
    {
        _open = !_open;
        return Task.CompletedTask;
    }

    private async Task OnItemSelected(T item)
    {
        _open = false;
        await OnSelected.InvokeAsync(item);
    }

    private async Task OnClearClicked()
    {
        _open = false;
        await OnClear.InvokeAsync();
    }
}
