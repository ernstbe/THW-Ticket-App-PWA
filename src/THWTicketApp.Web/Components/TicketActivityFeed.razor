@*
    Chronological merged feed of everything that has happened on a ticket:
    comments, notes (internal), status/field changes from history, and
    file uploads. Newest event at the top, threaded by author avatar.

    The parent passes the raw Ticket; this component computes the merged
    list locally so we don't keep three near-identical loops around.
*@

@using THWTicketApp.Shared.Models
@using THWTicketApp.Shared.Services
@using Markdig

@if (Items.Count == 0)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="my-4 text-center">
        @L.T("detail.activity_empty")
    </MudText>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var ev in Items)
        {
            <div class="d-flex align-start gap-3" data-event-kind="@ev.Kind">
                <UserAvatar Name="@ev.AuthorName" ImageUrl="@Api.GetUserAvatarUrl(ev.AuthorImage)" Size="Size.Small" />
                <div style="flex:1; min-width:0;">
                    <div class="d-flex align-center gap-2 flex-wrap">
                        <MudText Typo="Typo.subtitle2">@ev.AuthorName</MudText>
                        @if (ev.Kind == ActivityKind.Note)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                     Variant="Variant.Filled" Class="ml-1">
                                @L.T("detail.activity_internal")
                            </MudChip>
                        }
                        else if (ev.Kind == ActivityKind.History)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @ev.HistoryAction
                            </MudText>
                        }
                        <MudSpacer />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @FormatRelative(ev.Date)
                        </MudText>
                    </div>
                    @if (!string.IsNullOrEmpty(ev.Body))
                    {
                        <MudPaper Elevation="0" Class="pa-3 mt-1"
                                  Style="@($"background: {(ev.Kind == ActivityKind.Note ? "rgba(255,193,7,0.08)" : "var(--mud-palette-background-gray)")};")">
                            @if (ev.Kind == ActivityKind.History)
                            {
                                <MudText Typo="Typo.body2">@ev.Body</MudText>
                            }
                            else
                            {
                                @((MarkupString)Markdown.ToHtml(ev.Body, _md))
                            }
                        </MudPaper>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    // Injected explicitly (rather than via @inject) so unit tests can supply
    // a LocalizationService instance when exercising FormatRelative directly.
    [Inject] internal LocalizationService L { get; set; } = default!;
    [Inject] internal ITrueDeskApiService Api { get; set; } = default!;

    [Parameter, EditorRequired] public Ticket? Ticket { get; set; }

    // Limit the feed to a subset of activity kinds. The detail page renders
    // two feeds: comments+notes prominently, history collapsed below.
    [Parameter] public ActivityKind[]? Kinds { get; set; }

    private List<ActivityEvent> Items => BuildFeed(Ticket, Kinds);
    // UseSoftlineBreakAsHardlineBreak: keep single newlines visible as <br>
    // (matches TicketDetail/Reports — trudesk stores plain-text edits with
    // raw \n, which Markdig would otherwise collapse to spaces).
    private static readonly MarkdownPipeline _md = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseSoftlineBreakAsHardlineBreak()
        // DisableHtml: comment/note bodies are attacker-controllable and rendered
        // via (MarkupString), so raw HTML must be escaped, not passed through (XSS).
        .DisableHtml()
        .Build();

    internal static List<ActivityEvent> BuildFeed(Ticket? ticket, ActivityKind[]? kinds = null)
    {
        var list = new List<ActivityEvent>();
        if (ticket == null) return list;

        bool Wants(ActivityKind k) => kinds == null || Array.IndexOf(kinds, k) >= 0;

        if (Wants(ActivityKind.Comment) && ticket.Comments != null)
            list.AddRange(ticket.Comments.Select(c => new ActivityEvent
            {
                Kind = ActivityKind.Comment,
                Date = c.Date,
                AuthorName = c.Owner?.Fullname,
                AuthorImage = c.Owner?.Image,
                Body = c.Text
            }));

        if (Wants(ActivityKind.Note) && ticket.Notes != null)
            list.AddRange(ticket.Notes.Select(n => new ActivityEvent
            {
                Kind = ActivityKind.Note,
                Date = n.Date,
                AuthorName = n.Owner?.Fullname,
                AuthorImage = n.Owner?.Image,
                Body = n.Content
            }));

        if (Wants(ActivityKind.History) && ticket.History != null)
            list.AddRange(ticket.History.Select(h => new ActivityEvent
            {
                Kind = ActivityKind.History,
                Date = h.Date,
                AuthorName = h.Owner?.Fullname ?? "System",
                AuthorImage = h.Owner?.Image,
                HistoryAction = h.TranslatedAction,
                // Translate the English description and drop it when it just
                // restates the action label (e.g. "Ticket was created.").
                Body = TrudeskTranslationHelper.TranslateHistoryDescription(h.Description)
            }));

        // Newest first — matches the inline editor at the top of the page.
        return list.OrderByDescending(e => e.Date).ToList();
    }

    // Instance (not static) so it can use the injected LocalizationService —
    // a static method can't reach L, which is why this used to be hardcoded
    // German and ignored the language switch (same fix as Dashboard/Profile).
    internal string FormatRelative(DateTime when)
    {
        var local = when.Kind switch
        {
            DateTimeKind.Utc => when.ToLocalTime(),
            DateTimeKind.Local => when,
            _ => DateTime.SpecifyKind(when, DateTimeKind.Utc).ToLocalTime()
        };
        var diff = DateTime.Now - local;
        if (diff.TotalSeconds < 60) return L.T("time.just_now");
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} {L.T("time.minutes_ago")}";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} {L.T("time.hours_ago")}";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} {L.T("time.days_ago")}";
        return local.ToString("dd.MM.yyyy HH:mm");
    }

    public enum ActivityKind { Comment, Note, History }

    internal sealed class ActivityEvent
    {
        public ActivityKind Kind { get; init; }
        public DateTime Date { get; init; }
        public string? AuthorName { get; init; }
        public string? AuthorImage { get; init; }
        public string? Body { get; init; }
        public string? HistoryAction { get; init; }
    }
}
