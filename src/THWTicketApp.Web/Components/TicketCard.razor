@using MudBlazor
@using THWTicketApp.Shared.Helpers
@using THWTicketApp.Shared.Models
@inject THWTicketApp.Web.Services.LocalizationService L

<MudCard Elevation="@(IsSelected ? 3 : 1)" Class="@($"mb-2 ticket-card{(IsSelected ? " mud-border-primary" : "")}")"
         Style="cursor: pointer;" @onclick="HandleClick"
         role="article" aria-label="@($"Ticket #{Ticket.Uid}: {Ticket.Subject}")">
    <MudCardContent Class="pa-3">
        <div class="d-flex justify-space-between align-start">
            @if (IsSelectable)
            {
                <MudCheckBox T="bool" Value="@IsSelected" Dense="true" Class="mr-2 mt-n1"
                             ValueChanged="@(v => OnSelectedChanged.InvokeAsync(v))"
                             @onclick:stopPropagation="true" />
            }
            <div class="flex-grow-1">
                <div class="d-flex align-center gap-2 mb-1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        #@Ticket.Uid
                    </MudText>
                    <StatusBadge Status="@Ticket.Status" />
                    <PriorityBadge Priority="@Ticket.Priority" />
                </div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">@Ticket.Subject</MudText>
                <div class="d-flex align-center gap-3">
                    @if (Ticket.Assignee != null)
                    {
                        <div class="d-flex align-center gap-1">
                            <UserAvatar Name="@Ticket.Assignee.Fullname" Size="Size.Small"
                                        Style="width:20px;height:20px;font-size:10px;" />
                            <MudText Typo="Typo.caption">@Ticket.Assignee.Fullname</MudText>
                        </div>
                    }
                    @if (Ticket.AdditionalAssignees.Count > 0)
                    {
                        @* Compact overlapping avatar stack for the additional
                           assignees — max 3, the rest collapses into "+n". *@
                        <div class="d-flex align-center"
                             title="@string.Join(", ", Ticket.AdditionalAssignees.Select(a => a.Fullname))">
                            @{ var stackIndex = 0; }
                            @foreach (var extra in Ticket.AdditionalAssignees.Take(3))
                            {
                                <UserAvatar Name="@extra.Fullname" Size="Size.Small"
                                            Style="@($"width:18px;height:18px;font-size:9px;{(stackIndex++ > 0 ? "margin-left:-6px;" : "")}")" />
                            }
                            @if (Ticket.AdditionalAssignees.Count > 3)
                            {
                                <MudText Typo="Typo.caption" Class="ml-1">+@(Ticket.AdditionalAssignees.Count - 3)</MudText>
                            }
                        </div>
                    }
                    @if (Ticket.Group != null)
                    {
                        <MudText Typo="Typo.caption">
                            <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-1" />
                            @Ticket.Group.Name
                        </MudText>
                    }
                    @if (Ticket.DueDate != DateTime.MinValue)
                    {
                        var overdue = TicketDueDateHelper.IsOverdue(Ticket.DueDate) && Ticket.Status?.IsResolved != true;
                        <MudText Typo="Typo.caption" Color="@(overdue ? Color.Error : Color.Default)"
                                 Style="@(overdue ? "font-weight:600;" : null)">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-1" />
                            @Ticket.DueDate.ToLocalDisplayString("dd.MM.yyyy")
                        </MudText>
                    }
                    <MudText Typo="Typo.caption" Color="Color.Default">
                        @Ticket.LastActivityAt.ToLocalDisplayString("dd.MM.yyyy HH:mm")
                    </MudText>
                </div>
            </div>
            @if (ShowActions && !IsSelectable)
            {
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         aria-label="@L.T("tickets.actions")"
                         @onclick:stopPropagation="true">
                    <MudMenuItem OnClick="() => OnAssignToMe.InvokeAsync(Ticket)">@L.T("tickets.assign_me")</MudMenuItem>
                    @if (AvailableStatuses?.Count > 0 && OnChangeStatus.HasDelegate)
                    {
                        <MudDivider />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="px-3 py-1">
                            @L.T("tickets.change_status")
                        </MudText>
                        @foreach (var status in AvailableStatuses)
                        {
                            var s = status;
                            <MudMenuItem Icon="@Icons.Material.Filled.SwapHoriz"
                                         OnClick="@(() => OnChangeStatus.InvokeAsync((Ticket, s)))">
                                @s.Name
                            </MudMenuItem>
                        }
                        <MudDivider />
                    }
                    <MudMenuItem OnClick="() => OnClose.InvokeAsync(Ticket)">@L.T("common.close")</MudMenuItem>
                </MudMenu>
            }
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public Ticket Ticket { get; set; } = null!;
    [Parameter] public bool ShowActions { get; set; }
    [Parameter] public bool IsSelectable { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<Ticket> OnClick { get; set; }
    [Parameter] public EventCallback<Ticket> OnAssignToMe { get; set; }
    [Parameter] public EventCallback<Ticket> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnSelectedChanged { get; set; }
    /// <summary>Statuses offered in the quick-change submenu. Empty/null hides the submenu.</summary>
    [Parameter] public IReadOnlyList<Status>? AvailableStatuses { get; set; }
    [Parameter] public EventCallback<(Ticket Ticket, Status Status)> OnChangeStatus { get; set; }

    private async Task HandleClick()
    {
        if (IsSelectable)
            await OnSelectedChanged.InvokeAsync(!IsSelected);
        else
            await OnClick.InvokeAsync(Ticket);
    }
}
