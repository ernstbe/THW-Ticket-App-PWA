@*
    Reusable empty-state placeholder. Replaces the bare "Keine X gefunden"
    MudAlert pattern with a centered illustration + headline + body + CTA.

    Usage:

        <EmptyState Icon="@Icons.Material.Filled.ConfirmationNumber"
                    Title="@L.T("tickets.none")"
                    Description="@L.T("tickets.empty_description")"
                    ActionLabel="@L.T("tickets.new")"
                    ActionHref="tickets/add" />

    `ActionHref` is optional — drop it for purely informational empty states.
    `Icon` defaults to a generic inbox if not provided.
*@

<MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center text-center" Style="background: transparent;">
    <MudIcon Icon="@(string.IsNullOrEmpty(Icon) ? Icons.Material.Outlined.Inbox : Icon)"
             Size="Size.Large" Color="Color.Default"
             Style="font-size: 5rem; opacity: 0.4; margin-bottom: 16px;" />
    <MudText Typo="Typo.h6" Class="mb-2">@Title</MudText>
    @if (!string.IsNullOrEmpty(Description))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width: 400px;">
            @Description
        </MudText>
    }
    @if (!string.IsNullOrEmpty(ActionLabel) && !string.IsNullOrEmpty(ActionHref))
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@(string.IsNullOrEmpty(ActionIcon) ? Icons.Material.Filled.Add : ActionIcon)"
                   Href="@ActionHref"
                   Class="mt-4">
            @ActionLabel
        </MudButton>
    }
    else if (!string.IsNullOrEmpty(ActionLabel) && ActionCallback.HasDelegate)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@(string.IsNullOrEmpty(ActionIcon) ? Icons.Material.Filled.Add : ActionIcon)"
                   OnClick="@(() => ActionCallback.InvokeAsync())"
                   Class="mt-4">
            @ActionLabel
        </MudButton>
    }
</MudPaper>

@code {
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? ActionLabel { get; set; }
    [Parameter] public string? ActionHref { get; set; }
    [Parameter] public string? ActionIcon { get; set; }
    [Parameter] public EventCallback ActionCallback { get; set; }
}
