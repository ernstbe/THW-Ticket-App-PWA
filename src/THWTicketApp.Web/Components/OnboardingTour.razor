@*
    Welcome tour shown once per device on first login. Eight steps walk
    a new OV member through the parts of the app they actually need to
    know about: ticket list, creating a ticket, detail-page editing,
    Kanban, search/command-palette, biometric login, and where to find
    more. Skipped via X / Esc / Skip — either way we mark it complete.
*@

@inject OnboardingService Onboarding
@inject LocalizationService L
@inject NavigationManager Navigation
@inject WebPushService WebPush
@inject LocalStorageService LocalStorage
@inject ISnackbar Snackbar
@implements IDisposable

@if (Onboarding.IsVisible)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="10500" AutoClose="false">
        <div style="position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); width:90%; max-width:560px;">
            <MudPaper Elevation="16" Class="pa-6" Style="border-radius:12px;">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @L.T("onboarding.step") @( _step + 1) / @StepCount
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   aria-label="@L.T("common.close")"
                                   OnClick="SkipAsync" />
                </div>

                <div class="d-flex flex-column align-center text-center mb-4">
                    <MudIcon Icon="@CurrentIcon" Size="Size.Large" Color="Color.Primary"
                             Style="font-size:4rem; margin-bottom:16px;" />
                    <MudText Typo="Typo.h5" Class="mb-2">@L.T($"onboarding.step{_step + 1}_title")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width:400px;">
                        @L.T($"onboarding.step{_step + 1}_body")
                    </MudText>

                    @* Push opt-in lives on the final step. The browser only
                       grants push after an explicit gesture + permission, so
                       this is the moment we ask. *@
                    @if (_step == StepCount - 1)
                    {
                        <div class="mt-4 d-flex flex-column align-center gap-2" style="width:100%;">
                            @if (!_pushSupported)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L.T("onboarding.push_unsupported")</MudText>
                            }
                            else if (_pushSubscribed)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Text"
                                         Icon="@Icons.Material.Filled.CheckCircle">@L.T("onboarding.push_enabled")</MudChip>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.NotificationsActive"
                                           OnClick="OnEnablePushAsync" Disabled="_pushBusy">
                                    @L.T("onboarding.push_enable")
                                </MudButton>
                            }
                        </div>
                    }
                </div>

                @* Progress dots — visual stepper without taking space *@
                <div class="d-flex justify-center gap-1 mb-4">
                    @for (var i = 0; i < StepCount; i++)
                    {
                        var idx = i;
                        <span style="@($"width:8px;height:8px;border-radius:50%;background:{(idx == _step ? "var(--mud-palette-primary)" : "var(--mud-palette-action-disabled)")}")" />
                    }
                </div>

                <div class="d-flex justify-space-between gap-2">
                    <MudButton Variant="Variant.Text" OnClick="SkipAsync">
                        @L.T("onboarding.skip")
                    </MudButton>
                    <div class="d-flex gap-2">
                        @if (_step > 0)
                        {
                            <MudButton Variant="Variant.Outlined" OnClick="PrevStep">
                                @L.T("common.back")
                            </MudButton>
                        }
                        @if (_step < StepCount - 1)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       EndIcon="@Icons.Material.Filled.ArrowForward"
                                       OnClick="NextStep">
                                @L.T("onboarding.next")
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       OnClick="FinishAsync">
                                @L.T("onboarding.finish")
                            </MudButton>
                        }
                    </div>
                </div>
            </MudPaper>
        </div>
    </MudOverlay>
}

@code {
    private const int StepCount = 9;
    private int _step;

    // Push opt-in step state (lazily loaded when the user reaches it).
    private bool _pushSupported;
    private bool _pushSubscribed;
    private bool _pushBusy;
    private bool _pushStateLoaded;

    private string CurrentIcon => _step switch
    {
        0 => Icons.Material.Filled.WavingHand,
        1 => Icons.Material.Filled.Dashboard,
        2 => Icons.Material.Filled.AddCircle,
        3 => Icons.Material.Filled.EditNote,
        4 => Icons.Material.Filled.ViewKanban,
        5 => Icons.Material.Filled.Keyboard,
        6 => Icons.Material.Filled.Fingerprint,
        7 => Icons.Material.Filled.TipsAndUpdates,
        8 => Icons.Material.Filled.NotificationsActive,
        _ => Icons.Material.Filled.CheckCircle
    };

    protected override void OnInitialized()
    {
        Onboarding.StateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        // Reset to first step every time the tour is opened — re-runs from
        // Settings always start at step 0, and the push state is re-read.
        if (Onboarding.IsVisible)
        {
            _step = 0;
            _pushStateLoaded = false;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task NextStep()
    {
        _step = Math.Min(StepCount - 1, _step + 1);
        if (_step == StepCount - 1) await EnsurePushStateAsync();
    }

    private void PrevStep() => _step = Math.Max(0, _step - 1);

    private async Task SkipAsync() => await Onboarding.SkipAsync();
    private async Task FinishAsync() => await Onboarding.CompleteAsync();

    // Read support/subscription state once when the push step is first shown.
    private async Task EnsurePushStateAsync()
    {
        if (_pushStateLoaded) return;
        _pushStateLoaded = true;
        _pushSupported = await WebPush.IsSupportedAsync();
        if (_pushSupported) _pushSubscribed = await WebPush.IsSubscribedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnEnablePushAsync()
    {
        _pushBusy = true;
        try
        {
            if (await WebPush.EnableAsync())
            {
                // Keep the Settings screen consistent: the push toggle lives
                // under the master notifications switch, so turn that on too.
                await LocalStorage.SetItemAsync("settings_notifications", "true");
                _pushSubscribed = true;
                Snackbar.Add(L.T("onboarding.push_enabled"), Severity.Success);
            }
            else
            {
                Snackbar.Add(L.T("settings.push_enable_failed"), Severity.Error);
            }
        }
        finally { _pushBusy = false; }
    }

    public void Dispose() => Onboarding.StateChanged -= OnStateChanged;
}
